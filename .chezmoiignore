# Repo-only contents — tracked in git, NOT deployed to home by chezmoi.
arch-install
arch-install/**

# Omarchy generated state — `omarchy-theme-set` rewrites .config/omarchy/
# current/ on every theme switch (rendered theme/, theme.name, next-theme/).
# chezmoi mustn't track or revert these. The user-owned source-of-truth
# lives in .config/omarchy/themes/ (theme overlays) and .config/omarchy/
# themed/*.tpl (user templates that override built-in renderers); both ARE
# tracked.
.config/omarchy/current
.config/omarchy/current/**

# Walker emergencies state, omarchy toggles (waybar-off, etc.) — runtime.
.local/state/omarchy
.local/state/omarchy/**

# omarchy backgrounds override path — `omarchy-theme-bg-next` reads
# ~/.config/omarchy/backgrounds/<theme>/ before the theme dir's own
# backgrounds/. We aggregate ~80MB of wallpapers under nullsense/ here so
# the active nullsense theme cycles through every shipped wallpaper. Way
# too much to track in dotfiles — bootstrap repopulates on demand via
# `~/.local/bin/omarchy-bg-aggregate [theme-name]`.
.config/omarchy/backgrounds
.config/omarchy/backgrounds/**

# python build artifacts
**/__pycache__
**/*.pyc
