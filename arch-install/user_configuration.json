    "custom_commands": [
        "systemctl enable bluetooth.service",
        "systemctl enable NetworkManager.service",
        "systemctl enable docker.service",
        "systemctl enable systemd-oomd.service",
        "systemctl enable firewalld.service",
        "systemctl enable tailscaled.service",
        "echo i2c-dev > /etc/modules-load.d/i2c-dev.conf",
        "groupadd -f i2c",
        "printf 'KERNEL==\"i2c-[0-9]*\", GROUP=\"i2c\", MODE=\"0660\"\\n' > /etc/udev/rules.d/45-ddcutil-i2c.rules",
        "systemctl enable fstrim.timer",
        "systemctl enable paccache.timer",
        "systemctl enable reflector.timer",
        "systemctl enable fwupd-refresh.timer",
        "mkdir -p /etc/docker && printf '{\\n  \"log-driver\": \"local\",\\n  \"log-opts\": {\"max-size\": \"10m\", \"max-file\": \"3\"},\\n  \"storage-driver\": \"overlay2\"\\n}\\n' > /etc/docker/daemon.json",
        "sed -i 's/^#ParallelDownloads.*/ParallelDownloads = 8/' /etc/pacman.conf",
        "sed -i 's/^#Color/Color/' /etc/pacman.conf",
        "grep -q '^ILoveCandy' /etc/pacman.conf || sed -i '/^Color/a ILoveCandy' /etc/pacman.conf",
        "mkdir -p /etc/systemd/journald.conf.d && printf '[Journal]\\nSystemMaxUse=500M\\nSystemMaxFileSize=50M\\nMaxRetentionSec=1month\\n' > /etc/systemd/journald.conf.d/00-size.conf",
        "passwd -l root"
    ]
}
