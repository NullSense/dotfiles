#!/usr/bin/env bash
# Internal dispatcher shared by the ~/bin/{claude,codex,opencode} shims.
# Each shim invokes us as:  _agent-shim <agent> "$@"
#
# Why this exists: shell-function wrappers (the old approach, defined in
# dot_zshrc) only work in interactive zsh. Any non-zsh shell, any script,
# any `exec()` syscall that resolves <agent> via PATH lookup would skip the
# wrapper and reach the real binary directly. By turning ~/bin/<agent> into
# a real on-disk script that PATH-shadows the real binary, we get
# system-level enforcement regardless of how the agent is invoked.
#
# The shim lifts known wrapper flags (--ssh / --gpg / --rbw / --agent-vault
# / --dotfiles / --gpu / --no-gpu) from "$@" so `claude --ssh` reaches agent-isolated correctly — its arg
# parser breaks out of flag parsing the moment it sees the agent name.
#
# Bypasses (intentional, for emergency use):
#   • AGENT_UNSANDBOX=1 claude …   — env-var gate inside agent-isolated
#   • ~/.local/bin/claude …        — invoke real binary by full path
# `command claude` does NOT bypass anymore — it still resolves through PATH
# and hits this shim. Before this change, `command claude` skipped the
# zsh function and reached the real binary; that hole is now closed.

set -euo pipefail

agent="$1"; shift

wrapper_flags=()
passthrough=()
saw_terminator=0

for arg in "$@"; do
    if (( saw_terminator )); then
        passthrough+=("$arg")
        continue
    fi
    case "$arg" in
        --) saw_terminator=1; passthrough+=("$arg") ;;
        --ssh|--gpg|--rbw|--agent-vault|--dotfiles|--gpu|--no-gpu)
            wrapper_flags+=("$arg") ;;
        *) passthrough+=("$arg") ;;
    esac
done

# Infisical injection layer (outermost). Pulls vault secrets into env so
# agent-isolated's allowlist + --setenv pipeline can forward the per-agent
# API keys (OPENROUTER_API_KEY, OPENCODE_API_KEY, ANTHROPIC_API_KEY, …)
# into the bwrap sandbox. Vault secrets never touch disk.
#
# Layering: infisical run → agent-isolated → bwrap → agent. The user is
# authenticated interactively via `infisical login`; non-interactive callers
# (systemd/cron) must export INFISICAL_TOKEN or INFISICAL_UNIVERSAL_AUTH_*
# beforehand. Set AGENT_NO_INFISICAL=1 to skip (e.g. when vault is offline).
infisical_prefix=()
if [[ -z "${AGENT_NO_INFISICAL:-}" ]] && command -v infisical >/dev/null 2>&1; then
    infisical_prefix=(infisical run --silent --)
fi

exec "${infisical_prefix[@]}" "$HOME/bin/agent-isolated" "${wrapper_flags[@]}" "$agent" "${passthrough[@]}"
