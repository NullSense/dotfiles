#!/usr/bin/env bash
# agent-isolated — bubblewrap sandbox for AI coding agents (claude, codex, opencode).
#
# Usage:
#   agent-isolated <agent> [--ssh] [--gpg] [--rbw] [--no-docker] [--agent-vault] [--dotfiles] [--no-gpu] [--dry-run] [-- <agent args>]
#   agent-isolated sh                            # interactive shell inside the sandbox
#   agent-isolated --self-test                   # run negative + positive verifications
#   AGENT_UNSANDBOX=1 agent-isolated <agent> …   # bypass the sandbox entirely (escape hatch)
#
# Default behaviour (read-broad, secrets-masked model): agent runs with tmpfs `/`
# plus a READ-WRITE bind of all of `$HOME`, so it can read the whole codebase and
# write the way normal tools expect (atomic temp+rename saves to dotfiles like
# ~/.claude.json work — the old read-only floor broke those with EROFS). Secrets
# are carved back OUT with tmpfs/null overlays that hide the real inode, so they
# stay both unreadable and unwritable. It cannot see ~/.ssh, ~/.gnupg,
# the rbw/Bitwarden/atuin stores, browser profiles, keyrings, the cliphist DB,
# the chezmoi source tree (SECRETS.md + private_*), or any secret-bearing env
# var (BW_SESSION, AGENT_VAULT_SESSION_TOKEN, etc.).
#
# Escape hatches re-mount specific surfaces when a workflow legitimately needs
# them; all default off:
#   --ssh           Bind ~/.bitwarden-ssh-agent.sock + set SSH_AUTH_SOCK.
#                   Use for `git push` over SSH or SSH-signed commits.
#   --gpg           Bind $XDG_RUNTIME_DIR/gnupg + set GPG_TTY.
#   --rbw           Bind $XDG_RUNTIME_DIR/rbw + the rbw binary.
#                   Use sparingly; defeats most of the isolation goal.
#   --agent-vault   Set HTTPS_PROXY/CA cert/session token for credential
#                   injection on outbound HTTPS via the host's agent-vault.
#                   Agent talks to APIs but never sees upstream tokens.
#   --dotfiles      Flip the config surface to READ-WRITE so the agent can
#                   manage your dotfiles: chezmoi source + ~/.config + the
#                   $HOME rc files + ~/bin. Supports the edit-source →
#                   `chezmoi apply` loop from inside the sandbox. Secrets
#                   (SECRETS.md, private_*, ~/.config/rbw, …) STAY masked —
#                   this is NOT *-raw. Use for "update my hypr/waybar/zsh
#                   config" tasks; default-off because configs are read-only
#                   normally (writes confined to projects).
#
# Default-on (per user request — NOT low-risk):
#   docker          Bind /run/docker.sock + set DOCKER_HOST so the agent can
#                   drive the host Docker daemon (build/run/compose,
#                   testcontainers) with no flag. DANGER: the daemon runs as
#                   root, so socket access = host root — an agent can
#                   `docker run -v /:/host …` and escape the sandbox entirely.
#                   Opt out with --no-docker for untrusted/unsupervised runs.
#                   Rootless Docker or a throwaway VM is the safer path.
#
# Default-on (low-risk, broadly useful):
#   plannotator     Bind ~/.{local/share,config,cache}/plannotator so the
#                   agent can run `plannotator last` / `plannotator review`
#                   from inside the sandbox. Sets BROWSER=/usr/bin/echo so
#                   plannotator prints its URL instead of trying xdg-open
#                   (which would need dbus, which stays hidden). Open the
#                   printed URL manually in your existing browser. Opt out
#                   with --no-plannotator if you want zero plannotator
#                   surface in this invocation.
#   gpu             Bind /dev/kfd + /dev/dri so the agent can run GPU
#                   compute (ROCm/HIP: local LLM inference, embedding/
#                   rerank, PyTorch). Without it `--dev /dev` builds a
#                   minimal devtmpfs that omits the GPU nodes →
#                   "No HIP GPUs are available". The nodes are 0666 and
#                   credential-free, so exposing them adds no secret
#                   surface. Opt out with --no-gpu.
#
# Architecture and rationale documented in:
#   ~/.claude/projects/-home-nullsense/memory/reference_agent_isolation.md
#   ~/.claude/plans/okay-can-you-please-cozy-meteor.md (original design)

set -euo pipefail

# ───────────────────────────── Bypass ─────────────────────────────
# AGENT_UNSANDBOX=1 → exec the real agent binary, skipping bwrap entirely.
# `command -v` is the WRONG lookup here: ~/bin/ is first in PATH so it would
# resolve to the shim, recursing back into agent-isolated forever. Real
# agent binaries live in ~/.local/bin/ (claude is a symlink there, codex/
# opencode are direct files or symlinks). Use that explicitly.
if [[ "${AGENT_UNSANDBOX:-0}" == "1" ]]; then
    if [[ $# -ge 1 ]]; then
        agent="$1"; shift
        case "$agent" in
            claude|codex|opencode)
                real="$HOME/.local/bin/$agent"
                if [[ -x "$real" || -L "$real" ]]; then
                    exec "$real" "$@"
                fi
                # fallback: scrub ~/bin from PATH then look up via env
                clean_path="${PATH//$HOME\/bin:/}"
                clean_path="${clean_path//:$HOME\/bin/}"
                exec env -u AGENT_UNSANDBOX PATH="$clean_path" "$agent" "$@"
                ;;
            *) exec "$agent" "$@" ;;
        esac
    fi
fi

# ─────────────────────── Argument parsing ─────────────────────────
ALLOW_SSH=0
ALLOW_GPG=0
ALLOW_RBW=0
# Default-on (per user request): bind the host Docker socket so container dev
# work (build/run/compose/testcontainers) works with no flag. This is a real
# security relaxation — the daemon is root, so socket access = host root and an
# agent can escape the sandbox via `docker run -v /:/host`. Opt out per-run with
# --no-docker for untrusted/unsupervised sessions.
ALLOW_DOCKER=1
# Default-on: every agent runs under agent-vault so outbound HTTPS gets
# credential injection (agent talks to APIs, never sees upstream tokens).
# Opt out per-invocation with --no-agent-vault; bypass all isolation with
# AGENT_UNSANDBOX=1 or the *-raw aliases.
ALLOW_AGENT_VAULT=1
ALLOW_DOTFILES=0
# Default-on: plannotator's binds are narrow (3 dirs under $HOME, no
# secrets), broadly useful (review / annotate flows), and harmless when
# the binary isn't installed. Flip with --no-plannotator for the rare
# case where you want a completely surface-minimized run.
ALLOW_PLANNOTATOR=1
# Default-on: GPU device nodes (/dev/kfd, /dev/dri) are world-accessible
# (0666) and credential-free, so exposing them is harmless and broadly
# useful for local LLM / ROCm inference work. Opt out with --no-gpu.
ALLOW_GPU=1
DRY_RUN=0
SELF_TEST=0
AGENT=""

# ─────────────────────── Auto-vault (self-acquire) ─────────────────────────
# agent-vault is default-on, so if we are not already inside a vault session
# (no ambient HTTPS_PROXY) and not opted out, re-exec the whole shim under
# `agent-vault vault run` to ACQUIRE a session — then the second pass sees the
# proxy env and forwards it across bwrap's --clearenv (see the --agent-vault
# block below). Without this, `claude` alone could only forward an ambient
# session that a plain shell never has. The AGENT_VAULT_WRAPPED sentinel breaks
# the loop if vault run can't provide a proxy; --no-agent-vault / AGENT_UNSANDBOX
# skip it; a missing agent-vault binary falls through (no hard dependency).
if [[ -z "${AGENT_VAULT_WRAPPED:-}" && -z "${HTTPS_PROXY:-}" && -z "${AGENT_UNSANDBOX:-}" ]]; then
    _want_vault=1
    for _a in "$@"; do
        case "$_a" in
            --no-agent-vault) _want_vault=0 ;;
            --) break ;;
        esac
    done
    if (( _want_vault )) && command -v agent-vault >/dev/null 2>&1; then
        export AGENT_VAULT_WRAPPED=1
        exec agent-vault vault run --vault "${AGENT_VAULT_VAULT:-default}" -- "$0" "$@"
    fi
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --ssh)            ALLOW_SSH=1; shift ;;
        --gpg)            ALLOW_GPG=1; shift ;;
        --rbw)            ALLOW_RBW=1; shift ;;
        --docker)         ALLOW_DOCKER=1; shift ;;  # accepted for symmetry
        --no-docker)      ALLOW_DOCKER=0; shift ;;
        --agent-vault)    ALLOW_AGENT_VAULT=1; shift ;;
        --no-agent-vault) ALLOW_AGENT_VAULT=0; shift ;;
        --dotfiles)       ALLOW_DOTFILES=1; shift ;;
        --plannotator)    ALLOW_PLANNOTATOR=1; shift ;;  # accepted for symmetry
        --no-plannotator) ALLOW_PLANNOTATOR=0; shift ;;
        --gpu)            ALLOW_GPU=1; shift ;;  # accepted for symmetry
        --no-gpu)         ALLOW_GPU=0; shift ;;
        --dry-run)        DRY_RUN=1; shift ;;
        --self-test)      SELF_TEST=1; AGENT="sh"; shift; break ;;
        -h|--help)
            sed -n '2,30p' "$0" | sed 's/^# \?//'
            exit 0 ;;
        --) shift; break ;;
        claude|codex|opencode|sh|bash)
            AGENT="$1"; shift; break ;;
        *)
            echo "agent-isolated: unknown arg: $1" >&2
            exit 64 ;;
    esac
done

if [[ -z "${AGENT:-}" ]]; then
    echo "agent-isolated: missing agent name (claude|codex|opencode|sh|bash)" >&2
    exit 64
fi

case "$AGENT" in
    claude)   AGENT_BIN="$HOME/.local/bin/claude" ;;
    codex)    AGENT_BIN="/usr/bin/codex" ;;
    opencode) AGENT_BIN="/usr/bin/opencode" ;;
    sh)       AGENT_BIN="/bin/sh" ;;
    bash)     AGENT_BIN="/bin/bash" ;;
esac

if [[ ! -x "$AGENT_BIN" ]]; then
    echo "agent-isolated: $AGENT_BIN not found or not executable" >&2
    exit 65
fi

# ─────────────────────── Pre-flight checks ────────────────────────
command -v bwrap >/dev/null 2>&1 || {
    echo "agent-isolated: bwrap not installed (pacman -S bubblewrap)" >&2
    exit 66
}

UID_NUM="$(id -u)"
XRD="${XDG_RUNTIME_DIR:-/run/user/$UID_NUM}"
CHEZMOI_ROOT="$HOME/.local/share/chezmoi"

# Decide whether to bind cwd as the WRITABLE workspace. Under the read floor
# below, all of $HOME is already readable — this only governs WRITE access.
# We refuse to make bare $HOME or a secret-bearing root writable (you don't
# want an agent writing across your whole home, and secret dirs are masked
# anyway). When refused, $HOME stays readable and the agent simply gets no
# extra write scope — cd into a project, or pass AGENT_BIND.
WORKSPACE="${PWD:-$HOME}"
WORKSPACE_DENY_SUBTREE=(
    "$HOME/.local/share/chezmoi"           # SECRETS.md, private_dot_ssh
    "$HOME/.ssh"
    "$HOME/.gnupg"
    "$HOME/.config"                        # too broad to make writable
    "$HOME/.agent-vault"
    "$HOME/.local/share/keyrings"
    "$HOME/.password-store"
    "$HOME/.aws"
    "$HOME/.kube"
    "$HOME/.docker"
    "$HOME/.cache"
    "$HOME/.mozilla"
)
WORKSPACE_BIND=0
case "$WORKSPACE" in
    "$HOME")
        echo "agent-isolated: cwd is bare \$HOME — all of \$HOME is read-write (secrets stay masked); cd into a project if you want a tighter scope." >&2
        ;;
    "$HOME"/*)
        WORKSPACE_BIND=1
        for _deny in "${WORKSPACE_DENY_SUBTREE[@]}"; do
            if [[ "$WORKSPACE" == "$_deny" ]] || [[ "$WORKSPACE" == "$_deny"/* ]]; then
                WORKSPACE_BIND=0
                echo "agent-isolated: cwd ($WORKSPACE) is under a secret/denied subtree ($_deny); not binding it writable." >&2
                break
            fi
        done
        ;;
    *)
        echo "agent-isolated: cwd outside \$HOME ($WORKSPACE); not mounted. Running from \$HOME — set AGENT_BIND=$WORKSPACE to mount it." >&2
        ;;
esac
(( WORKSPACE_BIND == 0 )) && WORKSPACE="$HOME"

# ─────────────────────── Build bwrap argv ─────────────────────────
ARGS=()

# Namespaces — max isolation, keep network for API access.
# NOTE: --as-pid-1 is deliberately OMITTED. It disables bwrap's built-in PID-1
# reaper, which made the agent (node) PID 1 in the namespace; orphaned grandchildren
# from tool calls (mold/sccache/git/wl-copy/dbus-launch) reparent to it and it never
# wait()s them → zombie pileup (hit 775 zombies / swap-death 2026-06-18). Letting bwrap
# run its default init-as-pid-1 reaps them automatically; --die-with-parent still handles
# teardown on parent death. Re-add --as-pid-1 only if a tool genuinely needs to BE pid 1.
ARGS+=(
    --unshare-all
    --share-net
    --new-session
    --die-with-parent
    --cap-drop ALL
)

# Empty filesystem, layered from here.
ARGS+=(
    --tmpfs /
    --proc /proc
    --dev /dev
    --tmpfs /tmp
    --tmpfs /var/tmp
    --tmpfs /run
    --dir "/run/user/$UID_NUM"
)

# System read-only.
ARGS+=(
    --ro-bind /usr /usr
    --symlink usr/lib   /lib
    --symlink usr/lib64 /lib64
    --symlink usr/bin   /bin
    --symlink usr/sbin  /sbin
    --ro-bind /etc /etc
    --ro-bind-try /opt /opt
)

# Mask known secret-extraction binaries that exist in /usr/bin. Even though
# their backends (sockets, DBs, D-Bus services) are hidden, having the
# binary on $PATH is a footgun. /dev/null is bound over each — calling them
# fails immediately. Defense in depth.
for _bin in rbw rofi-rbw bw secret-tool keyctl op doppler vault ykman \
            gpg-connect-agent gnome-keyring gnome-keyring-daemon; do
    [[ -e "/usr/bin/$_bin" ]] && ARGS+=( --ro-bind /dev/null "/usr/bin/$_bin" )
done
unset _bin

# ── HOME: writable floor, secrets masked out ───────────────────────
# Floor: bind ALL of $HOME READ-WRITE so the agent can read the whole codebase
# AND apps that save via atomic temp+rename (Claude Code's ~/.claude.json,
# editors, `chezmoi apply` to rc files) work — a single-file bind mount can't be
# rename-replaced and its RO parent can't hold the temp, so the old ro-floor
# broke every such writer with EROFS. Secret masks layer on TOP (tmpfs/dev-null
# overlays hide the real inode regardless of floor rw/ro), so READ-protection is
# unchanged; only WRITE scope widened. Order is load-bearing (later args win):
#   (1) bind $HOME (rw)    write floor  [was --ro-bind; flipped 2026-05-29]
#   (2) rw binds           redundant now but harmless (dir mounts don't block
#                          rename of files inside them) — kept for clarity
#   (3) secret masks       carve secrets back out (THE boundary)
#   (4) --ssh/--rbw/--gpg  re-expose one surface on explicit request (later)
# NB: do NOT add single-FILE --bind lines under this floor — they become
# mountpoints that re-break atomic-rename. Dir binds are fine.
ARGS+=( --bind "$HOME" "$HOME" )

# (2) Writable carve-outs — each agent's own state/auth (expected writable;
# we hide *other* secrets, never the agent's own API access).
ARGS+=(
    --bind     "$HOME/.claude"               "$HOME/.claude"
    --bind-try "$HOME/.local/state/claude"   "$HOME/.local/state/claude"
    --bind-try "$HOME/.codex"                "$HOME/.codex"
    --bind-try "$HOME/.config/opencode"      "$HOME/.config/opencode"
    --bind-try "$HOME/.local/share/opencode" "$HOME/.local/share/opencode"
    --bind-try "$HOME/.local/state/opencode" "$HOME/.local/state/opencode"
)

# Tool caches (rw). Build/test tooling (uv, sigstore-rust, lefthook, go, npx,
# cargo, mise, pip…) writes to ~/.cache; read-only here breaks "regular
# coding" with EROFS. Bound RW wholesale — secret-bearing cache children
# (cliphist, rbw, browser profiles) are re-masked in the secret-mask block
# below, so this exposes only non-secret tool caches.
ARGS+=( --bind-try "$HOME/.cache" "$HOME/.cache" )

# Dev-tool state/install dirs that live OUTSIDE ~/.cache. Read-only here breaks
# any tool that writes its install/build cache — bun in particular dies with
# "Unexpected accessing temporary directory" because its default BUN_INSTALL=
# ~/.bun is read-only (that's the recurring claude-mem-hook failure). These hold
# caches + downloaded toolchains/packages, not secrets; the token files (.npmrc,
# .cargo/credentials*) are masked in the secret block (3) below.
ARGS+=(
    --bind-try "$HOME/.bun"        "$HOME/.bun"
    --bind-try "$HOME/.npm"        "$HOME/.npm"
    --bind-try "$HOME/.pnpm-store" "$HOME/.pnpm-store"
    --bind-try "$HOME/.deno"       "$HOME/.deno"
    --bind-try "$HOME/.cargo"      "$HOME/.cargo"
    --bind-try "$HOME/.rustup"     "$HOME/.rustup"
    --bind-try "$HOME/go"          "$HOME/go"
    --bind-try "$HOME/.ansible"    "$HOME/.ansible"
)

# XDG_STATE_HOME (rw) — tool runtime state lives here, not just caches. mise
# keeps its trusted-config + tool state under ~/.local/state/mise; read-only
# meant mise refused to trust project mise.toml in a fresh worktree, so every
# mise-shimmed pre-commit tool (gitleaks, lefthook, ansible-lint) failed. Bound
# wholesale like ~/.local/share above; no secrets live here (keyrings/atuin/rbw
# are under ~/.local/share and stay masked in (3)).
ARGS+=( --bind-try "$HOME/.local/state" "$HOME/.local/state" )

# Workspace roots (rw). ~/Programming is always writable so agents reach any
# project regardless of launch cwd. Ad-hoc dirs via AGENT_BIND (colon-
# separated absolute paths), e.g. AGENT_BIND=/srv/data:/mnt/scratch codex.
# bwrap seals its mount namespace at launch, so this is the ONLY way to grant
# access — there is no in-session "add a folder" once running. Secret masks
# (3) are applied AFTER these, so AGENT_BIND can't re-expose a masked secret;
# use the --ssh/--rbw/--gpg hatches for that.
ARGS+=( --bind-try "$HOME/Programming" "$HOME/Programming" )
if [[ -n "${AGENT_BIND:-}" ]]; then
    IFS=':' read -ra _extra_binds <<< "$AGENT_BIND"
    for _b in "${_extra_binds[@]}"; do
        [[ -n "$_b" ]] && ARGS+=( --bind-try "$_b" "$_b" )
    done
    unset _b _extra_binds
fi

# cwd workspace (rw) — only when it's a real project dir (see checks above).
if (( WORKSPACE_BIND )); then
    ARGS+=( --bind "$WORKSPACE" "$WORKSPACE" )
fi

# Config surface (rw, DEFAULT-ON as of 2026-05-28). Agents can edit dotfiles +
# run the edit-source → `chezmoi apply` loop in-sandbox. Previously gated behind
# --dotfiles and otherwise masked as an empty tmpfs — which made agents' chezmoi
# edits silently vanish on exit (the recurring "agents get confused" bug). Now
# always RW. These binds go BEFORE the secret masks (3), so every secret child
# is re-hidden afterwards — config-writable, secrets still invisible (NOT *-raw).
# ~/.local/{bin,share} are included so `chezmoi apply` can write its targets.
# (--dotfiles is now a no-op kept for back-compat.)
ARGS+=(
    --bind-try "$CHEZMOI_ROOT"      "$CHEZMOI_ROOT"
    --bind-try "$HOME/.config"      "$HOME/.config"
    --bind-try "$HOME/bin"          "$HOME/bin"
    --bind-try "$HOME/.local/bin"   "$HOME/.local/bin"
    --bind-try "$HOME/.local/share" "$HOME/.local/share"
)
# (rc-file single-file binds removed 2026-05-29 with the rw floor: those dotfiles
# are now writable via the floor, and as bind mounts they BROKE atomic-rename
# writers — `chezmoi apply`/editors saving ~/.zshrc etc. failed exactly like
# ~/.claude.json did. Normal writable files under the floor; no bind needed.)

# (3) Secret masks — THE security boundary under the read floor. The floor
# made all of $HOME readable; these overlays carve the secrets back out, so
# this is a fail-CLOSED denylist: anything NOT listed here stays readable by
# the agent. Add new secret locations as they appear. tmpfs hides a dir; a
# /dev/null overlay hides an individual file/socket (can't tmpfs a non-dir).
# return 0 explicitly: a bare `[[ -e ]] && …` makes the function return 1 when
# the path is absent, which would trip `set -e` at the call site (unlike the
# same expression written inline, which bash exempts as part of an && list).
mask_dir()  { [[ -e "$1" ]] && ARGS+=( --tmpfs "$1" ); return 0; }
mask_file() { [[ -e "$1" ]] && ARGS+=( --ro-bind /dev/null "$1" ); return 0; }

# chezmoi source secrets. The source tree is RW-bound above (config surface),
# so re-mask just the secret-bearing entries: SECRETS.md + every private_* /
# encrypted_* at any depth (dirs → tmpfs, files → /dev/null). Replaces the old
# wholesale-tmpfs mask that made agents' chezmoi edits silently vanish.
mask_file "$CHEZMOI_ROOT/SECRETS.md"
while IFS= read -r _p; do
    if [[ -d "$_p" ]]; then ARGS+=( --tmpfs "$_p" )
    else ARGS+=( --ro-bind /dev/null "$_p" ); fi
done < <(find "$CHEZMOI_ROOT" \( -name 'private_*' -o -name 'encrypted_*' \) -prune 2>/dev/null)
unset _p

# Home-level credential stores + sensitive caches.
for _m in .ssh .gnupg .aws .kube .docker .password-store .agent-vault \
          .mozilla .local/share/keyrings .local/share/rbw .cache/cliphist \
          .cache/rbw .cache/chromium .cache/google-chrome \
          .cache/BraveSoftware .cache/mozilla; do
    mask_dir "$HOME/$_m"
done

# atuin shell-history DB + timestamped backups.
for _m in "$HOME/.local/share/atuin" "$HOME"/.local/share/atuin.bak.*; do
    mask_dir "$_m"
done

# ~/.config secret children (the rest of ~/.config stays readable).
for _m in rbw Bitwarden "Bitwarden CLI" atuin op 1Password gh gh-cli gnupg \
          agent-vault sops age doppler google-chrome chromium BraveSoftware \
          Vivaldi; do
    mask_dir "$HOME/.config/$_m"
done

# Secret files / sockets.
for _m in .git-credentials .netrc .npmrc .pypirc .bitwarden-ssh-agent.sock \
          .cargo/credentials.toml .cargo/credentials \
          .cache/rofi-rbw.runcache; do
    mask_file "$HOME/$_m"
done
unset _m

# Runtime sockets (selective).
ARGS+=(
    --ro-bind-try "$XRD/hypr"      "$XRD/hypr"        # hyprctl reload
    --ro-bind-try "$XRD/wayland-1" "$XRD/wayland-1"   # wl-copy / notifications
)
# NEVER bound: $XRD/{rbw,gnupg,bus,dbus-1,pulse,pipewire-0}.

# Env: scrub everything, then setenv allowlist.
ARGS+=(
    --clearenv
    --setenv HOME             "$HOME"
    --setenv USER             "$USER"
    --setenv LOGNAME          "$USER"
    --setenv TERM             "${TERM:-xterm-256color}"
    --setenv COLORTERM        "${COLORTERM:-truecolor}"
    --setenv LANG             "${LANG:-C.UTF-8}"
    --setenv PATH             "$HOME/bin:$HOME/.local/bin:$HOME/.local/share/mise/shims:/usr/local/bin:/usr/bin:/usr/local/sbin:/usr/sbin"
    --setenv XDG_RUNTIME_DIR  "$XRD"
    --setenv WAYLAND_DISPLAY  "${WAYLAND_DISPLAY:-wayland-1}"
    --setenv EDITOR           "${EDITOR:-nvim}"
    --setenv VISUAL           "${VISUAL:-${EDITOR:-nvim}}"
    --setenv AGENT_ISOLATED   "1"
)
[[ -n "${LC_ALL:-}"     ]] && ARGS+=( --setenv LC_ALL     "$LC_ALL" )
[[ -n "${LC_CTYPE:-}"   ]] && ARGS+=( --setenv LC_CTYPE   "$LC_CTYPE" )
[[ -n "${LC_MESSAGES:-}" ]] && ARGS+=( --setenv LC_MESSAGES "$LC_MESSAGES" )

# Per-agent API key (only the one for the agent we're launching).
case "$AGENT" in
    claude)
        [[ -n "${ANTHROPIC_API_KEY:-}" ]] && ARGS+=( --setenv ANTHROPIC_API_KEY "$ANTHROPIC_API_KEY" )
        [[ -n "${ANTHROPIC_BASE_URL:-}" ]] && ARGS+=( --setenv ANTHROPIC_BASE_URL "$ANTHROPIC_BASE_URL" )
        ;;
    codex)
        [[ -n "${OPENAI_API_KEY:-}"  ]] && ARGS+=( --setenv OPENAI_API_KEY  "$OPENAI_API_KEY" )
        [[ -n "${OPENAI_API_BASE:-}" ]] && ARGS+=( --setenv OPENAI_API_BASE "$OPENAI_API_BASE" )
        ;;
    opencode)
        [[ -n "${OPENROUTER_API_KEY:-}" ]] && ARGS+=( --setenv OPENROUTER_API_KEY "$OPENROUTER_API_KEY" )
        [[ -n "${OPENAI_API_KEY:-}"     ]] && ARGS+=( --setenv OPENAI_API_KEY    "$OPENAI_API_KEY" )
        [[ -n "${OPENCODE_API_KEY:-}"   ]] && ARGS+=( --setenv OPENCODE_API_KEY  "$OPENCODE_API_KEY" )
        ;;
esac

# Shared litellm gateway key — claude/codex/opencode all reach the local litellm
# MCP gateway (litellm.lan:4000/mcp). Forward the virtual key so the MCP
# `${LLM_MCP_KEY}` Authorization header expands inside the sandbox. Raw key lives
# in Infisical (Personal project root), injected by the shim's `infisical run`.
[[ -n "${LLM_MCP_KEY:-}" ]] && ARGS+=( --setenv LLM_MCP_KEY "$LLM_MCP_KEY" )

# Default signing agent: bind the sign-only ssh-agent socket
# (git-sign-agent.service) and point SSH_AUTH_SOCK at it, so agents make SIGNED
# commits with no flag. NOT the Bitwarden agent — this key can't auth anywhere
# (registered on GitHub as a Signing key only, not an authorized key). Guarded:
# if the socket isn't up yet, SSH_AUTH_SOCK stays unset (signing then needs
# --ssh). The --ssh hatch below runs later and overrides SSH_AUTH_SOCK with the
# full Bitwarden agent when explicitly requested.
_sign_sock="$XRD/git-sign-agent.sock"
if [[ -S "$_sign_sock" ]]; then
    ARGS+=(
        --ro-bind "$_sign_sock" "$_sign_sock"
        --setenv  SSH_AUTH_SOCK "$_sign_sock"
    )
fi
unset _sign_sock

# Escape-hatch: SSH agent (host: Bitwarden SSH agent at ~/.bitwarden-ssh-agent.sock)
if (( ALLOW_SSH )); then
    sock="${SSH_AUTH_SOCK:-$HOME/.bitwarden-ssh-agent.sock}"
    if [[ -S "$sock" ]]; then
        ARGS+=(
            --bind "$sock" "$sock"
            --setenv SSH_AUTH_SOCK "$sock"
        )
    else
        echo "agent-isolated: --ssh requested but $sock missing" >&2
    fi
fi

# Escape-hatch: GPG.
if (( ALLOW_GPG )); then
    ARGS+=(
        --ro-bind-try "$XRD/gnupg" "$XRD/gnupg"
        --setenv GPG_TTY "${GPG_TTY:-/dev/pts/0}"
    )
fi

# Escape-hatch: rbw.
if (( ALLOW_RBW )); then
    ARGS+=(
        --ro-bind-try "$XRD/rbw"          "$XRD/rbw"
        --ro-bind-try "$HOME/.config/rbw" "$HOME/.config/rbw"
    )
    rbw_bin="$(command -v rbw 2>/dev/null || true)"
    [[ -n "$rbw_bin" ]] && ARGS+=( --ro-bind "$rbw_bin" "$rbw_bin" )
fi

# Escape-hatch: agent-vault credential-injection proxy.
if (( ALLOW_AGENT_VAULT )); then
    ca="$HOME/.agent-vault/mitm-ca.pem"
    if [[ -e "$ca" ]]; then
        ARGS+=(
            --ro-bind "$ca" "$ca"
            --setenv NODE_EXTRA_CA_CERTS "$ca"
            --setenv SSL_CERT_FILE       "$ca"
            --setenv REQUESTS_CA_BUNDLE  "$ca"
        )
    fi
    # Forward the host's REAL proxy env verbatim. agent-vault exports
    # HTTPS_PROXY pointing at the MITM listener (…:14322) with the session token
    # embedded in the URL — this is DISTINCT from the control-plane
    # AGENT_VAULT_ADDR (…:14321). Reconstructing HTTPS_PROXY from AGENT_VAULT_ADDR
    # (the old behaviour) aimed the sandbox at the control plane and silently
    # disabled credential injection. Fall back to reconstruction only when the
    # host did not export HTTPS_PROXY (older agent-vault that exported only ADDR).
    _proxy="${HTTPS_PROXY:-${HTTP_PROXY:-}}"
    if [[ -z "$_proxy" && -n "${AGENT_VAULT_ADDR:-}" ]]; then
        _proxy="$AGENT_VAULT_ADDR"
        case "$_proxy" in http*://*) : ;; *) _proxy="http://$_proxy" ;; esac
    fi
    # Node/undici (WebFetch, remote MCP connectors, any global fetch) REFUSES to
    # set the TLS SNI/servername to a bare IP, so an https-scheme proxy pointed at
    # 127.0.0.1 dies with ERR_INVALID_ARG_VALUE and every node fetch "socket
    # closes" — surfacing as Vercel/Exa MCP "invalid/expired session" and WebFetch
    # HTTP 000. curl is unaffected (it happily SNIs an IP), which is the tell.
    # The MITM cert's SAN already covers DNS:localhost, so rewriting the proxy host
    # IP→localhost gives undici a valid non-IP servername while keeping the chain
    # verifiable. Verified 2026-07-05: node fetch via proxy 127.0.0.1→ERR, localhost→302.
    _proxy="${_proxy//127.0.0.1:/localhost:}"
    if [[ -n "$_proxy" ]]; then
        ARGS+=(
            --setenv HTTPS_PROXY "$_proxy"
            --setenv HTTP_PROXY  "$_proxy"
            --setenv NO_PROXY    "${NO_PROXY:+$NO_PROXY,}127.0.0.1,localhost,api.anthropic.com"
            --setenv NODE_USE_ENV_PROXY "1"
        )
    fi
    # Control-plane token for /discover + proposals. agent-vault renamed this
    # (AGENT_VAULT_SESSION_TOKEN → AGENT_VAULT_TOKEN); forward whichever the host
    # exports, under both names so the in-sandbox client finds it either way.
    _tok="${AGENT_VAULT_TOKEN:-${AGENT_VAULT_SESSION_TOKEN:-}}"
    if [[ -n "$_tok" ]]; then
        ARGS+=(
            --setenv AGENT_VAULT_TOKEN         "$_tok"
            --setenv AGENT_VAULT_SESSION_TOKEN "$_tok"
        )
    fi
    [[ -n "${AGENT_VAULT_ADDR:-}" ]]  && ARGS+=( --setenv AGENT_VAULT_ADDR  "$AGENT_VAULT_ADDR" )
    [[ -n "${AGENT_VAULT_VAULT:-}" ]] && ARGS+=( --setenv AGENT_VAULT_VAULT "$AGENT_VAULT_VAULT" )
fi

# --plannotator: bind plannotator's three state dirs so the agent can
# invoke `plannotator last` / `plannotator review` from inside the
# sandbox. dbus and the desktop's default-app registry stay HIDDEN —
# we just point $BROWSER at a stub that prints the URL for the human
# to open manually in their existing browser tab. Network is already
# shared (--share-net above) so the localhost server plannotator
# starts is reachable from the host's browser without further wiring.
#
# Surface added: three RW binds under $HOME, nothing else. No dbus,
# no display weakening, no socket exposure beyond the loopback already
# reachable for any --share-net agent.
if (( ALLOW_PLANNOTATOR )); then
    for _d in "$HOME/.local/share/plannotator" \
              "$HOME/.config/plannotator" \
              "$HOME/.cache/plannotator"; do
        # Create the host-side dir if missing so plannotator's first
        # run doesn't fail before it can write its state.
        mkdir -p "$_d"
        ARGS+=( --bind "$_d" "$_d" )
    done
    unset _d
    # (Browser/URL forwarding is wired unconditionally just below, so
    # plannotator's review URLs open in the host browser like anything else.)
fi

# Browser URL forwarding (host handoff). A sandboxed agent can't launch the
# host browser directly: the Helium AppImage needs /dev/fuse and its Chromium
# singleton IPC socket lives under the host /tmp, both hidden by our fresh
# --tmpfs /tmp. So instead of a browser, point $BROWSER — and shadow the
# /usr/bin/xdg-open the agent would otherwise call — at ~/bin/agent-open-url,
# which drops the URL into a spool dir under $HOME (already RW-shared). The
# host-side agent-url-opener.path unit watches that dir and runs the real
# browser. Surface added: the agent can ask the host to open an arbitrary URL
# in your logged-in browser — a deliberate, minor escalation over the old
# print-only stub. No dbus, no /tmp singleton-socket exposure, no /dev/fuse.
if [[ -x "$HOME/bin/agent-open-url" ]]; then
    ARGS+=( --setenv BROWSER "$HOME/bin/agent-open-url" )
    ARGS+=( --ro-bind-try "$HOME/bin/agent-open-url" /usr/bin/xdg-open )
else
    # Forwarder missing — fall back to the old print-only behaviour.
    ARGS+=( --setenv BROWSER "/usr/bin/echo" )
fi

# Default-on: GPU passthrough. Bind the AMD (ROCm/HIP) and NVIDIA (CUDA)
# compute device nodes so GPU compute (rocminfo, PyTorch, llama.cpp) can see
# the GPU from inside the sandbox. The earlier `--dev /dev` builds a minimal
# devtmpfs that OMITS these, which is why a sandboxed agent saw "No HIP GPUs
# are available" (AMD) / "no CUDA-capable device is detected" (NVIDIA) even
# with sandboxing off-by-flag. Binding onto the already-mounted /dev devtmpfs
# is the standard GPU-in-container pattern (mirrors Docker's
# `--device=/dev/kfd --device=/dev/dri` / nvidia-container-runtime). The nodes
# are 0666 and credential-free, so this adds no secret surface; --dev-bind-try
# is a no-op on hosts missing a node, so the wrapper stays portable across the
# AMD->NVIDIA transition. --no-gpu opts out for a run that wants zero device
# access.
#
# NOTE: the DRM render node (/dev/dri) alone only satisfies *Vulkan*. CUDA
# additionally needs the /dev/nvidia* character devices below — without
# /dev/nvidiactl + /dev/nvidia-uvm, CUDA init fails while Vulkan still works.
if (( ALLOW_GPU )); then
    ARGS+=(
        --dev-bind-try /dev/kfd /dev/kfd
        --dev-bind-try /dev/dri /dev/dri
        --dev-bind-try /dev/nvidiactl /dev/nvidiactl
        --dev-bind-try /dev/nvidia-uvm /dev/nvidia-uvm
        --dev-bind-try /dev/nvidia-uvm-tools /dev/nvidia-uvm-tools
        --dev-bind-try /dev/nvidia-modeset /dev/nvidia-modeset
        --dev-bind-try /dev/nvidia-caps /dev/nvidia-caps
    )
    # Per-GPU device nodes (/dev/nvidia0, /dev/nvidia1, …) — enumerate so
    # multi-GPU hosts work; the -e guard keeps it a no-op when none exist.
    for _nv in /dev/nvidia[0-9]*; do
        [[ -e "$_nv" ]] && ARGS+=( --dev-bind-try "$_nv" "$_nv" )
    done
fi

# Default-on (per user request): Docker daemon socket. This is the single
# biggest hole this sandbox can open — the daemon runs as root, so anything that
# can talk to /run/docker.sock can `docker run -v /:/host …` and take over the
# host, bypassing every mask/cap-drop above. Kept on for frictionless container
# dev work; drop it per-run with --no-docker. The socket lands on the
# --tmpfs /run mounted earlier (later
# args win). We also point DOCKER_HOST at the canonical /run path so the CLI
# doesn't chase the default context's /var/run/docker.sock (which /var/run,
# absent on the tmpfs root, wouldn't resolve). ~/.docker is re-exposed (it was
# tmpfs-masked above) so registry auth + contexts work; --bind-try is a no-op
# when it doesn't exist. Rootless Docker ($XDG_RUNTIME_DIR/docker.sock, non-root
# daemon) is the safer alternative if you want this always-on.
if (( ALLOW_DOCKER )); then
    _dhost="${DOCKER_HOST:-}"
    _dsock="${_dhost#unix://}"
    [[ "$_dsock" == "$_dhost" || -z "$_dsock" ]] && _dsock="/run/docker.sock"
    if [[ -S "$_dsock" ]]; then
        ARGS+=(
            --bind "$_dsock" "$_dsock"
            --setenv DOCKER_HOST "unix://$_dsock"
            --bind-try "$HOME/.docker" "$HOME/.docker"
        )
    else
        echo "agent-isolated: --docker requested but $_dsock is not a socket" >&2
    fi
    unset _dsock _dhost
fi

# chdir
ARGS+=( --chdir "$WORKSPACE" )

# Optional per-host override.
USER_OVERRIDE="$HOME/.config/agent-isolated/config.sh"
if [[ -f "$USER_OVERRIDE" ]]; then
    declare -a EXTRA_BWRAP_ARGS=()
    # shellcheck disable=SC1090
    . "$USER_OVERRIDE"
    if [[ ${#EXTRA_BWRAP_ARGS[@]} -gt 0 ]]; then
        ARGS+=( "${EXTRA_BWRAP_ARGS[@]}" )
    fi
fi

# ────────────────────────── Self-test ─────────────────────────────
if (( SELF_TEST )); then
    pass=0; fail=0
    run() {
        # $1 = direction (neg|pos), $2 = description, rest = sh -c command
        local dir="$1" desc="$2"; shift 2
        local out rc
        set +e
        out="$(bwrap "${ARGS[@]}" /bin/sh -c "$*" 2>&1)"; rc=$?
        set -e
        if [[ "$dir" == "neg" ]]; then
            if (( rc != 0 )) || [[ -z "$out" ]] || \
               [[ "$out" == *"No such file"* ]] || \
               [[ "$out" == *"command not found"* ]] || \
               [[ "$out" == *"cannot access"* ]] || \
               [[ "$out" == *"not found"* ]]; then
                printf "  \033[32m✓\033[0m %s\n" "$desc"; pass=$((pass+1))
            else
                printf "  \033[31m✗\033[0m %s — UNEXPECTED: %s\n" "$desc" "${out:0:100}"; fail=$((fail+1))
            fi
        else
            if (( rc == 0 )) && [[ -n "$out" ]]; then
                printf "  \033[32m✓\033[0m %s — %s\n" "$desc" "${out:0:60}"; pass=$((pass+1))
            else
                printf "  \033[31m✗\033[0m %s — FAILED rc=%d: %s\n" "$desc" "$rc" "${out:0:100}"; fail=$((fail+1))
            fi
        fi
    }

    echo "── NEGATIVE: must fail / be empty / be missing ─────────────────"
    run neg "rbw not in PATH"                  'command -v rbw'
    run neg "bw not in PATH"                   'command -v bw'
    run neg "secret-tool not in PATH"          'command -v secret-tool'
    run neg "~/.ssh hidden"                    "ls $HOME/.ssh"
    run neg "~/.gnupg hidden"                  "ls $HOME/.gnupg"
    run neg "~/.config/rbw hidden"             "ls $HOME/.config/rbw"
    run neg "~/.config/Bitwarden hidden"       "ls $HOME/.config/Bitwarden"
    run neg "~/.config/atuin hidden"           "ls $HOME/.config/atuin"
    run neg "bitwarden-ssh sock neutralized"   "test -S $HOME/.bitwarden-ssh-agent.sock && echo LIVE"
    run neg "SECRETS.md hidden"                "cat $CHEZMOI_ROOT/SECRETS.md"
    run neg "private_dot_ssh hidden"           "ls $CHEZMOI_ROOT/private_dot_ssh"
    run neg "~/.cache/cliphist hidden"         "ls $HOME/.cache/cliphist"
    run neg "~/.local/share/keyrings hidden"   "ls $HOME/.local/share/keyrings"
    run neg "~/.local/share/atuin hidden"      "ls $HOME/.local/share/atuin"
    run neg "~/.local/share/rbw hidden"        "ls $HOME/.local/share/rbw"
    run neg "~/.cache/rbw hidden"              "ls $HOME/.cache/rbw"
    run neg "~/.config/chromium hidden"        "ls $HOME/.config/chromium"
    run neg "~/.config/Bitwarden hidden (2)"   "ls '$HOME/.config/Bitwarden CLI'"
    run neg "~/.git-credentials hidden"        "cat $HOME/.git-credentials"
    run neg "rbw socket hidden"                "ls $XRD/rbw"
    run neg "dbus session hidden"              "ls $XRD/bus"
    run neg "agent-vault dir hidden"           "ls $HOME/.agent-vault"
    run neg "full Bitwarden SSH agent not exposed" 'test "$SSH_AUTH_SOCK" = "$HOME/.bitwarden-ssh-agent.sock" && echo LEAK'
    run neg "BW_SESSION env scrubbed"          'test -n "$BW_SESSION" && echo SET'
    run neg "AGENT_VAULT_SESSION_TOKEN scrubbed" 'test -n "$AGENT_VAULT_SESSION_TOKEN" && echo SET'

    echo
    echo "── POSITIVE: must succeed and produce output ───────────────────"
    run pos "/usr/bin readable"                'ls /usr/bin | head -1'
    run pos "chezmoi binary visible"           'command -v chezmoi'
    run pos "hypr config dir bound"            "ls $HOME/.config/hypr | head -1"
    run pos "home dotfiles readable"           "head -1 $HOME/.gitconfig"
    run pos "non-secret config readable"       "ls $HOME/.config/nvim | head -1"
    run pos "Wayland socket reachable"         "ls $XRD/wayland-1"
    run pos "agent state dir writable"         "touch $HOME/.claude/.sandbox-test && rm $HOME/.claude/.sandbox-test && echo ok"
    run pos "chezmoi source writable"          "touch $CHEZMOI_ROOT/.sandbox-test && rm $CHEZMOI_ROOT/.sandbox-test && echo ok"
    run pos "~/.local/bin writable"            "touch $HOME/.local/bin/.sandbox-test && rm $HOME/.local/bin/.sandbox-test && echo ok"
    # GPU passthrough — only assert on hosts that actually have the device,
    # so the self-test stays green on GPU-less machines.
    [[ -e /dev/kfd ]] && \
      run pos "GPU /dev/kfd exposed (ROCm)"    'test -e /dev/kfd && echo present'
    [[ -e /dev/dri/renderD128 ]] && \
      run pos "GPU render node exposed"        'test -e /dev/dri/renderD128 && echo present'
    [[ -e /dev/nvidiactl ]] && \
      run pos "GPU /dev/nvidiactl exposed (CUDA)" 'test -e /dev/nvidiactl && echo present'
    [[ -e /dev/nvidia-uvm ]] && \
      run pos "GPU /dev/nvidia-uvm exposed (CUDA)" 'test -e /dev/nvidia-uvm && echo present'

    echo
    printf "── %d passed, %d failed ──\n" "$pass" "$fail"
    exit "$fail"
fi

# ──────────────────────────── Dry run ─────────────────────────────
if (( DRY_RUN )); then
    printf '%q ' bwrap "${ARGS[@]}" "$AGENT_BIN" "$@"
    echo
    exit 0
fi

# ─────────────────────────────  Exec  ─────────────────────────────
exec bwrap "${ARGS[@]}" "$AGENT_BIN" "$@"
