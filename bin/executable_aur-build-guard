#!/usr/bin/env bash
# aur-build-guard — paru PreBuildCommand gate against compromised AUR PKGBUILDs.
#
# Scans the PKGBUILD + *.install scriptlets in the build dir for the IOC
# families seen in the 2026-06 "Atomic Arch" supply-chain attack (npm/bun
# preinstall droppers: atomic-lockfile / js-digest) plus classic malicious-
# PKGBUILD patterns. Wired into paru via:
#     [bin]
#     PreBuildCommand = /home/nullsense/bin/aur-build-guard
# Exit 0 = allow build, non-zero = abort the build.
#
# Modes:
#   aur-build-guard                 scan CWD, interactive gate (paru calls this)
#   aur-build-guard --report DIR    scan DIR, print findings, no prompt;
#                                     exit code = number of GATE-tier hits
#
# Bypass one build:  AUR_GUARD_DISABLE=1 paru -S pkg
# Unattended "yes":  AUR_GUARD_ASSUME=yes   (CI only — never in cron)
#
# Managed by chezmoi (bin/executable_aur-build-guard). Companion: aur-audit.
set -uo pipefail

mode="gate"; dir="."
case "${1:-}" in
  --report) mode="report"; dir="${2:-.}" ;;
  "" ) : ;;
  * ) dir="$1" ;;
esac

[ "${AUR_GUARD_DISABLE:-0}" = "1" ] && exit 0   # explicit per-build bypass

cd "$dir" 2>/dev/null || exit 0                  # fail-open: never break unreadable builds

shopt -s nullglob
files=( PKGBUILD *.install *.sh )
[ ${#files[@]} -eq 0 ] && exit 0

# Rule format:  SEVERITY@@@description@@@extended-regex
#   GATE = unambiguous / matches live threat -> hard block (or top of prompt)
#   WARN = suspicious   -> surface and prompt
rules=(
  # --- Atomic Arch (2026-06) npm/bun preinstall dropper family ---
  "GATE@@@known Atomic-Arch malicious npm package@@@atomic-lockfile|js-digest|crypto-javascript|js-deobfuscator|crypto-encrypt-ts|herbsobering"
  "WARN@@@npm/pnpm install invoked from a package script@@@\\b(npm|pnpm)\\b[[:space:]]+(install|i|ci|add)\\b"
  "WARN@@@npx remote-package execution@@@\\bnpx\\b"
  "WARN@@@bun install/exec invoked from a package script@@@\\b(bun|bunx)\\b[[:space:]]+(install|add|x|run)\\b"
  "WARN@@@yarn install invoked from a package script@@@\\byarn\\b[[:space:]]+(add|install)\\b"
  # --- remote content execution ---
  "GATE@@@pipe-to-shell (curl/wget | sh)@@@(curl|wget)[^|]*\\|[[:space:]]*(sudo[[:space:]]+)?(ba)?sh"
  "GATE@@@process-substitution pipe to shell@@@(ba)?sh[[:space:]]+<\\([[:space:]]*(curl|wget)"
  "GATE@@@eval of a remote download@@@eval[[:space:]]+\"?\\\$\\((curl|wget)"
  "GATE@@@base64-decode piped to shell@@@base64[[:space:]]+-d.*\\|[[:space:]]*(ba)?sh"
  # --- reverse shells ---
  "GATE@@@/dev/tcp reverse-shell primitive@@@/dev/tcp/"
  "GATE@@@netcat reverse shell@@@\\bnc\\b[^\$]*-e\\b|mkfifo[^\$]*\\|[^\$]*\\bnc\\b"
  # --- exfil / paste / C2 hosts ---
  "GATE@@@Tor .onion endpoint@@@\\.onion\\b"
  "WARN@@@paste / anonymous-upload host@@@\\b(temp\\.sh|transfer\\.sh|0x0\\.st|paste\\.ee|ix\\.io|termbin\\.com)\\b"
  "WARN@@@URL shortener (hides real source)@@@\\b(bit\\.ly|tinyurl\\.com|is\\.gd|cutt\\.ly)\\b"
  # --- persistence (mostly seen in .install scriptlets, run as root) ---
  "GATE@@@writes SSH authorized_keys@@@authorized_keys"
  "WARN@@@cron persistence@@@\\bcrontab\\b|/etc/cron"
  "WARN@@@shell-rc persistence@@@(~|\\\$HOME)/\\.(bashrc|zshrc|profile)"
  "WARN@@@account manipulation@@@\\buseradd\\b|\\busermod\\b"
  # --- destructive ---
  "GATE@@@destructive rm of / or HOME@@@rm[[:space:]]+-[rfRF]+[[:space:]]+(/|\\\$HOME|~)([[:space:]]|\$)"
  "GATE@@@dd to a raw block device@@@dd[[:space:]][^\$]*of=/dev/(sd|nvme|mmc)"
  "GATE@@@filesystem format command@@@\\bmkfs\\."
  # --- privilege escalation / suid inside build ---
  "WARN@@@sudo inside PKGBUILD/.install (builds should never need it)@@@\\bsudo\\b"
  "WARN@@@setuid/setgid bit@@@chmod[[:space:]]+([ug]*\\+s|[0-7]*[4-7][0-7][0-7][0-7])"
)

gate_hits=(); warn_hits=()
for entry in "${rules[@]}"; do
  sev="${entry%%@@@*}"; rest="${entry#*@@@}"
  desc="${rest%%@@@*}"; pat="${rest#*@@@}"
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    if [ "$sev" = GATE ]; then gate_hits+=("$desc :: $line")
    else warn_hits+=("$desc :: $line"); fi
  done < <(grep -nEi -- "$pat" "${files[@]}" 2>/dev/null)
done

ngate=${#gate_hits[@]}; nwarn=${#warn_hits[@]}

# --report: print findings, exit code = number of gate hits, no prompt.
if [ "$mode" = report ]; then
  for h in "${gate_hits[@]:-}"; do [ -n "$h" ] && printf '  [BLOCK] %s\n' "$h"; done
  for h in "${warn_hits[@]:-}"; do [ -n "$h" ] && printf '  [warn ] %s\n' "$h"; done
  exit "$ngate"
fi

# gate mode (paru PreBuildCommand)
[ "$ngate" -eq 0 ] && [ "$nwarn" -eq 0 ] && exit 0   # clean -> build silently

pkg="$(basename "$PWD")"
{
  printf '\n\033[1;33m┌─ aur-build-guard: findings for %s ─\033[0m\n' "$pkg"
  for h in "${gate_hits[@]:-}"; do [ -n "$h" ] && printf '\033[1;31m│ [BLOCK] %s\033[0m\n' "$h"; done
  for h in "${warn_hits[@]:-}"; do [ -n "$h" ] && printf '\033[33m│ [warn ] %s\033[0m\n' "$h"; done
  printf '\033[1;33m└─ review the diff above carefully before continuing ─\033[0m\n'
} >&2

# Hard block on any GATE hit unless explicitly forced.
if [ "$ngate" -gt 0 ] && [ "${AUR_GUARD_ASSUME:-}" != "yes" ]; then
  printf '\033[1;31maur-build-guard: %d hard-block indicator(s) — aborting build.\033[0m\n' "$ngate" >&2
  printf 'Override (only if you have audited it): AUR_GUARD_DISABLE=1 paru -S %s\n' "$pkg" >&2
  exit 1
fi

# WARN-only -> prompt over the controlling terminal.
if [ -e /dev/tty ]; then
  printf '\033[1mProceed with building %s? [y/N] \033[0m' "$pkg" >/dev/tty
  read -r ans </dev/tty || ans=""
  case "$ans" in [yY]|[yY][eE][sS]) exit 0 ;; *) echo "aur-build-guard: aborted by user." >&2; exit 1 ;; esac
fi

# No tty: block unless told to assume yes.
[ "${AUR_GUARD_ASSUME:-}" = "yes" ] && exit 0
echo "aur-build-guard: findings present and no terminal to confirm — aborting." >&2
exit 1
