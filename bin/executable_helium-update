#!/usr/bin/env bash
# helium-update — keep ~/.local/bin/helium.AppImage in sync with the latest
# release at github.com/imputnet/helium-linux. Run on demand or via the
# helium-update.timer systemd user unit (weekly).
#
# Helium has no built-in updater (intentional, no telemetry). This is the
# replacement: query GitHub releases API, compare versions, download if
# different, atomic-replace.

set -euo pipefail

REPO="imputnet/helium-linux"
ARCH="x86_64"
APPIMAGE_DIR="${HOME}/.local/bin"
APPIMAGE_PATH="${APPIMAGE_DIR}/helium.AppImage"
COMMAND_PATH="${APPIMAGE_DIR}/helium"
DESKTOP_DIR="${HOME}/.local/share/applications"
ICON_DIR="${HOME}/.local/share/icons/hicolor/512x512/apps"
VERSION_FILE="${APPIMAGE_DIR}/.helium.version"

mkdir -p "$APPIMAGE_DIR" "$DESKTOP_DIR" "$ICON_DIR"

command -v jq >/dev/null || { echo "helium-update: jq is required" >&2; exit 1; }

RELEASE_JSON=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest")
LATEST=$(jq -r '.tag_name // empty' <<<"$RELEASE_JSON")
URL=$(jq -r --arg arch "$ARCH" '
  .assets[]
  | select(.name | test("^helium-.*-" + $arch + "\\.AppImage$"))
  | .browser_download_url
' <<<"$RELEASE_JSON" | head -1)
[[ -n "$LATEST" ]] || { echo "helium-update: failed to find latest release tag" >&2; exit 1; }
[[ -n "$URL" ]] || { echo "helium-update: failed to find ${ARCH} AppImage asset for ${LATEST}" >&2; exit 1; }

CURRENT=""
[[ -f "$VERSION_FILE" ]] && CURRENT=$(cat "$VERSION_FILE")

if [[ "$CURRENT" == "$LATEST" ]] && [[ -x "$APPIMAGE_PATH" ]]; then
  echo "helium-update: already at $LATEST"
  exit 0
fi

echo "helium-update: ${CURRENT:-<none>} -> $LATEST"

TMP=$(mktemp --suffix=.AppImage)
trap 'rm -f "$TMP"' EXIT

curl -fsSL --progress-bar -o "$TMP" "$URL"
chmod +x "$TMP"

# Extract bundled icon + .desktop on first install, then drop the squashfs dir
if [[ ! -f "${DESKTOP_DIR}/helium.desktop" ]] || [[ "$CURRENT" != "$LATEST" ]]; then
  WORK=$(mktemp -d)
  ( cd "$WORK" && "$TMP" --appimage-extract >/dev/null 2>&1 ) || true
  if [[ -d "${WORK}/squashfs-root" ]]; then
    # Icon
    find "${WORK}/squashfs-root" -maxdepth 3 -name 'helium*.png' -size +10k \
      -exec cp -f {} "${ICON_DIR}/helium.png" \; 2>/dev/null | head -1 || true
    # Desktop file (rewrite Exec to point at our stable AppImage path)
    DSK=$(find "${WORK}/squashfs-root" -maxdepth 2 -name '*.desktop' | head -1 || true)
    if [[ -n "$DSK" ]]; then
      sed -E "s|^Exec=.*|Exec=${APPIMAGE_PATH} %U|; s|^Icon=.*|Icon=helium|" \
        "$DSK" > "${DESKTOP_DIR}/helium.desktop"
    fi
  fi
  rm -rf "$WORK"
fi

mv -f "$TMP" "$APPIMAGE_PATH"
ln -sfn "$APPIMAGE_PATH" "$COMMAND_PATH"
echo "$LATEST" > "$VERSION_FILE"

# Refresh desktop database + icon cache (silent if missing)
update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true
gtk-update-icon-cache -f -t "${HOME}/.local/share/icons/hicolor" 2>/dev/null || true

echo "helium-update: installed $LATEST at $APPIMAGE_PATH"
