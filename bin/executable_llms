#!/usr/bin/env python3
"""llms — show which local LLM servers are live, which model each has loaded, on
which port, and the GPU's VRAM use. Pairs the self-labeled llama-server processes
(argv[0] set via `exec -a` in the llama-* wrappers) with their live OpenAI API so a
process row in btop / Mission Center maps to a model at a glance.

Probes the usual local inference ports; add ports via `llms 9000 9001`.
"""
import json, os, re, subprocess, sys, urllib.request

PORTS = [int(a) for a in sys.argv[1:] if a.isdigit()] or [9292, 4000, 8080, 8081, 8082, 8083, 8084, 8085, 1234]


def get(url, t=1.0):
    try:
        with urllib.request.urlopen(url, timeout=t) as r:
            return json.load(r)
    except Exception:
        return None


# port -> (pid, argv0-label, model-file) from the running llama-server processes
proc = {}
try:
    ps = subprocess.run(["ps", "-eo", "pid,args"], capture_output=True, text=True, timeout=4).stdout
    for line in ps.splitlines():
        if "llama-server" not in line:
            continue
        parts = line.split(None, 1)
        if len(parts) < 2:
            continue
        pid, args = parts
        argv0 = args.split()[0]
        mp = re.search(r"--port\s+(\d+)", args)
        mm = re.search(r"--model\s+(\S+)", args)
        if mp:
            proc[int(mp.group(1))] = (pid, argv0, os.path.basename(mm.group(1)) if mm else "?")
except Exception:
    pass

rows = []
for p in PORTS:
    d = get(f"http://127.0.0.1:{p}/v1/models")
    pid, label, mf = proc.get(p, ("-", "", "-"))
    if not d and label == "":
        continue  # nothing here
    ids = []
    if d:
        for m in (d.get("data") or d.get("models") or []):
            ids.append(m.get("id") or m.get("name") or "")
    alias = ", ".join(filter(None, ids)) or "?"
    shown = label or alias
    note = "" if d else "  (process up, API not ready?)"
    rows.append((p, shown, pid, mf if mf != "-" else alias, note))

if not rows:
    print("no local LLM servers responding on", ", ".join(map(str, PORTS)))
else:
    print(f"{'PORT':<6}{'LABEL / ALIAS':<34}{'PID':<8}{'MODEL'}")
    for p, shown, pid, mf, note in sorted(rows):
        print(f"{p:<6}{shown[:32]:<34}{pid:<8}{mf}{note}")

# VRAM line (AMD) — best effort; needs amdgpu_top installed.
try:
    out = subprocess.run(["amdgpu_top", "-d"], capture_output=True, text=True, timeout=3).stdout
    vram = next((l.strip() for l in out.splitlines() if re.search(r"VRAM", l, re.I)), None)
    gtt = next((l.strip() for l in out.splitlines() if re.search(r"\bGTT\b", l, re.I)), None)
    if vram or gtt:
        print("\nGPU:", " | ".join(filter(None, [vram, gtt])))
except Exception:
    pass
