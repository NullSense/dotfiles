#!/usr/bin/env bash
# psf — package install/uninstall fuzzy-finder.
#
# Sources:
#   pacman repos      → `pacman -Slq` (instant, plain text)
#   AUR               → fetched on demand from aur.archlinux.org/packages.gz
#                       and cached at ~/.cache/psf/aur-packages.txt
#                       (paru's own cache at ~/.cache/paru/packages.aur is a
#                       custom binary format and `paru -Slq --aur` itself
#                       outputs raw bytes — verified on paru v2.1.0 — so we
#                       don't touch either, that was the binary-garbage bug.)
#
# Bindings:
#   ^Space  install ↔ uninstall toggle
#   ^A      pacman ↔ AUR source toggle (only meaningful in install mode)
#   Enter   act on selection
#
# Install always goes through `paru -S` so AUR packages resolve. Default
# flags `--skipreview --noupgrademenu` for non-interactive (omarchy menu
# launches this in a one-shot floating terminal). Set PSF_INTERACTIVE=1
# to get full paru prompts.

set -uo pipefail

paru_install_flags=( --skipreview --noupgrademenu )
[[ ${PSF_INTERACTIVE:-0} == 1 ]] && paru_install_flags=()

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/psf"
mkdir -p "$cache_dir"
aur_cache="$cache_dir/aur-packages.txt"
aur_max_age_min=720  # refetch after 12h

refresh_aur_cache() {
    [[ -s $aur_cache ]] && [[ -z $(find "$aur_cache" -mmin +"$aur_max_age_min" 2>/dev/null) ]] && return 0

    printf 'fetching AUR package list…\r' >&2
    if curl -sf --max-time 15 'https://aur.archlinux.org/packages.gz' \
        | gunzip 2>/dev/null \
        | grep -v '^#' > "$aur_cache.tmp" 2>/dev/null && [[ -s $aur_cache.tmp ]]; then
        mv "$aur_cache.tmp" "$aur_cache"
        printf '\033[K' >&2  # clear progress line
        return 0
    else
        rm -f "$aur_cache.tmp"
        printf 'AUR fetch failed; using stale cache or empty\n' >&2
        [[ -s $aur_cache ]] && return 0 || return 1
    fi
}

mode=install
src=pacman
while true; do
    case "$mode-$src" in
        install-pacman)
            pkg_list=$(pacman -Slq 2>/dev/null)
            tag='⬇️  Install · 📦 pacman'
            ;;
        install-aur)
            refresh_aur_cache || { sleep 1; src=pacman; continue; }
            pkg_list=$(cat "$aur_cache")
            tag='⬇️  Install · 🌟 AUR'
            ;;
        uninstall-*)
            pkg_list=$(pacman -Qq 2>/dev/null)
            tag='🗑️  Remove'
            ;;
    esac

    if [[ -z $pkg_list ]]; then
        printf 'package list empty\n' >&2
        read -r -p 'Press Enter to retry, Ctrl-C to exit '
        continue
    fi

    header="$tag │ ^Space toggle install/remove │ ^A toggle pacman/AUR"

    result=$(printf '%s\n' "$pkg_list" | fzf \
        --multi \
        --preview 'paru --color=always -Si {1} 2>/dev/null || pacman -Si {1}' \
        --preview-window='right:60%:wrap' \
        --expect=ctrl-space,ctrl-a \
        --header="$header" \
        --prompt='🔍 ' \
        --pointer='▶' \
        --marker='✓' \
        --border=rounded)

    key=$(head -1 <<<"$result")
    mapfile -t pkgs < <(tail -n +2 <<<"$result")

    case "$key" in
        ctrl-space)
            mode=$([[ $mode == install ]] && echo uninstall || echo install)
            ;;
        ctrl-a)
            src=$([[ $src == pacman ]] && echo aur || echo pacman)
            ;;
        *)
            (( ${#pkgs[@]} == 0 )) && break
            if [[ $mode == install ]]; then
                paru -S "${paru_install_flags[@]}" "${pkgs[@]}" </dev/tty >/dev/tty 2>&1 && break
            else
                paru -Rns "${pkgs[@]}" </dev/tty >/dev/tty 2>&1 && break
            fi
            ;;
    esac
done
