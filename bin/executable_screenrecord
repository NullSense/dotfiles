#!/usr/bin/env bash
# Screen recording via gpu-screen-recorder — Omarchy's flow, adapted.
#
# This is the SINGLE recording implementation for the box. Both entry points
# route here:
#   - Keybinds (SUPER+ALT+r etc.)      → ~/bin/screenrecord directly
#   - Elephant menu → omarchy-menu     → omarchy-capture-screenrecording, which
#                                         is shimmed to this script via ~/bin
#                                         (PATH shadows omarchy's own copy).
# Keeping one implementation means region-select, the privacy dot, and the
# start notification behave identically no matter how recording was launched.
#
# Behavior:
#   - First invocation:  pick monitor or region with slurp (same UX as the
#                        screenshot tool), start recording. Saves to
#                        ~/Videos/screenrecording-TIMESTAMP.mp4
#   - Second invocation: stops the recording, normalizes audio (-14 LUFS),
#                        trims warmup frame, sends a clickable preview.
#
# Args (optional, can combine):
#   --with-desktop-audio        record system audio
#   --with-microphone-audio     record mic
#   --with-webcam               overlay a floating webcam preview (ffplay)
#   --webcam-device=/dev/videoN pick the webcam (auto-detects first if omitted)
#   --resolution=WxH            cap resolution
#   --stop-recording            stop if recording, else no-op (menu probe)
#
# Privacy dot:
#   gpu-screen-recorder captures via DRM/KMS, which PipeWire never sees — so the
#   privacy-dots backend can't light the "screen" dot for our own recordings.
#   Instead, waybar's xt3-status.sh lights the dot whenever a gpu-screen-recorder
#   process is alive, and we fire `pkill -RTMIN+8 waybar` on start/stop so it
#   flips instantly. This is why portal mode is no longer needed for the dot.
#
# Requirements (install via paru if missing):
#   - gpu-screen-recorder       (AUR; hardware-accelerated capture)
#   - hyprpicker, slurp, grim   (already on the box)
#   - ffmpeg, jq                (already on the box)
#   - v4l2-ctl, ffplay          (only for --with-webcam)

set -uo pipefail

if ! command -v gpu-screen-recorder >/dev/null 2>&1; then
    notify-send -u critical "Screen recording" \
        "gpu-screen-recorder not installed. Run:  paru -S gpu-screen-recorder"
    exit 1
fi

[[ -f ~/.config/user-dirs.dirs ]] && source ~/.config/user-dirs.dirs
OUTPUT_DIR="${XDG_VIDEOS_DIR:-$HOME/Videos}"
mkdir -p "$OUTPUT_DIR"

DESKTOP_AUDIO=false
MIC_AUDIO=false
WEBCAM=false
WEBCAM_DEVICE=""
RESOLUTION=""
STOP=false
FPS=60
RECORDING_FILE="/tmp/screenrecord-current"

for arg in "$@"; do
    case "$arg" in
        --with-desktop-audio)    DESKTOP_AUDIO=true ;;
        --with-microphone-audio) MIC_AUDIO=true ;;
        --with-webcam)           WEBCAM=true ;;
        --webcam-device=*)       WEBCAM_DEVICE="${arg#--webcam-device=}" ;;
        --resolution=*)          RESOLUTION="${arg#--resolution=}" ;;
        --stop-recording)        STOP=true ;;
    esac
done

is_recording() { pgrep -f "^gpu-screen-recorder" >/dev/null; }
toggle_indicator() { pkill -RTMIN+8 waybar 2>/dev/null || true; }

default_resolution() {
    read -r w h < <(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | "\(.width) \(.height)"')
    if (( w > 3840 || h > 2160 )); then echo "3840x2160"; else echo "0x0"; fi
}

# Floating webcam preview via ffplay (cropped to the right half + downscaled).
# Window title "WebcamOverlay" is matched by a Hyprland float rule and by cleanup.
start_webcam_overlay() {
    cleanup_webcam
    if [[ -z $WEBCAM_DEVICE ]]; then
        WEBCAM_DEVICE=$(v4l2-ctl --list-devices 2>/dev/null | grep -m1 "^[[:space:]]*/dev/video" | tr -d '\t')
        if [[ -z $WEBCAM_DEVICE ]]; then
            notify-send "No webcam devices found" -u critical -t 3000
            return 1
        fi
    fi
    local scale
    scale=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | .scale')
    local target_width
    target_width=$(awk "BEGIN {printf \"%.0f\", 360 * $scale}")
    local preferred_resolutions=("640x360" "1280x720" "1920x1080")
    local video_size_arg=""
    local available_formats
    available_formats=$(v4l2-ctl --list-formats-ext -d "$WEBCAM_DEVICE" 2>/dev/null)
    for resolution in "${preferred_resolutions[@]}"; do
        if echo "$available_formats" | grep -q "$resolution"; then
            video_size_arg="-video_size $resolution"
            break
        fi
    done
    # shellcheck disable=SC2086
    ffplay -f v4l2 $video_size_arg -framerate 30 "$WEBCAM_DEVICE" \
        -vf "crop=iw/2:ih,scale=${target_width}:-1" \
        -window_title "WebcamOverlay" -noborder \
        -fflags nobuffer -flags low_delay -probesize 32 -analyzeduration 0 \
        -loglevel quiet &
    sleep 1
}

cleanup_webcam() { pkill -f "WebcamOverlay" 2>/dev/null; }

get_rectangles() {
    local ws=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | .activeWorkspace.id')
    hyprctl monitors -j | jq -r --arg ws "$ws" '.[] | select(.activeWorkspace.id == ($ws | tonumber)) |
        "\(.x),\(.y) \(.width / .scale | floor)x\(.height / .scale | floor)"'
    hyprctl clients -j | jq -r --arg ws "$ws" '.[] | select(.workspace.id == ($ws | tonumber)) |
        "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"'
}

select_target() {
    local rects=$(get_rectangles)
    hyprpicker -r -z >/dev/null 2>&1 &
    local pid=$!
    sleep 0.1
    local sel=$(echo "$rects" | slurp 2>/dev/null)
    kill "$pid" 2>/dev/null

    [[ $sel =~ ^(-?[0-9]+),(-?[0-9]+)[[:space:]]([0-9]+)x([0-9]+)$ ]] || return 1
    local sx=${BASH_REMATCH[1]} sy=${BASH_REMATCH[2]} sw=${BASH_REMATCH[3]} sh=${BASH_REMATCH[4]}

    # Tiny click → snap to underlying rectangle
    if (( sw * sh < 20 )); then
        while IFS= read -r r; do
            [[ $r =~ ^(-?[0-9]+),(-?[0-9]+)[[:space:]]([0-9]+)x([0-9]+)$ ]] || continue
            local rx=${BASH_REMATCH[1]} ry=${BASH_REMATCH[2]} rw=${BASH_REMATCH[3]} rh=${BASH_REMATCH[4]}
            if (( sx >= rx && sx < rx+rw && sy >= ry && sy < ry+rh )); then
                sx=$rx sy=$ry sw=$rw sh=$rh; break
            fi
        done <<<"$rects"
    fi

    # Exact-monitor match → use -w MONITORNAME for native res, no scaling
    local mon=$(hyprctl monitors -j | jq -r --argjson x $sx --argjson y $sy --argjson w $sw --argjson h $sh '
        .[] | select(.x == $x and .y == $y and (.width / .scale | floor) == $w and (.height / .scale | floor) == $h) | .name' | head -1)
    if [[ -n $mon ]]; then echo "monitor:$mon"; else echo "region:${sw}x${sh}+${sx}+${sy}"; fi
}

# Human-readable summary for the start notification.
audio_label() {
    if [[ $DESKTOP_AUDIO == true && $MIC_AUDIO == true ]]; then echo "Desktop + Microphone"
    elif [[ $DESKTOP_AUDIO == true ]]; then echo "Desktop"
    elif [[ $MIC_AUDIO == true ]]; then echo "Microphone"
    else echo "None (muted)"; fi
}

target_label() {
    case $1 in
        monitor:*) echo "Monitor ${1#monitor:} (full)" ;;
        region:*)  echo "Region ${1#region:}" | sed -E 's/\+.*$//' ;;
        *)         echo "$1" ;;
    esac
}

start_recording() {
    local target
    target=$(select_target) || return 1   # user cancelled slurp → no notification

    local capture_args=()
    local res_label
    case $target in
        monitor:*)
            res_label="${RESOLUTION:-$(default_resolution)}"
            capture_args=(-w "${target#monitor:}" -s "$res_label") ;;
        region:*)
            capture_args=(-w "${target#region:}")
            res_label="native"
            if [[ -n $RESOLUTION ]]; then capture_args+=(-s "$RESOLUTION"); res_label="$RESOLUTION"; fi ;;
    esac
    [[ $res_label == "0x0" ]] && res_label="native"

    local audio_devs=""
    [[ $DESKTOP_AUDIO == true ]] && audio_devs="default_output"
    if [[ $MIC_AUDIO == true ]]; then
        [[ -n $audio_devs ]] && audio_devs+="|"
        audio_devs+="default_input"
    fi
    local audio_args=()
    [[ -n $audio_devs ]] && audio_args=(-a "$audio_devs" -ac aac)

    [[ $WEBCAM == true ]] && start_webcam_overlay

    local file="$OUTPUT_DIR/screenrecording-$(date +'%Y-%m-%d_%H-%M-%S').mp4"
    gpu-screen-recorder "${capture_args[@]}" -k auto -f "$FPS" -fm cfr \
        -fallback-cpu-encoding yes -o "$file" "${audio_args[@]}" 2>/dev/null &
    local pid=$!

    # Wait until file actually appears (gsr opens it lazily)
    while kill -0 $pid 2>/dev/null && [[ ! -f $file ]]; do sleep 0.2; done
    if kill -0 $pid 2>/dev/null; then
        echo "$file" > "$RECORDING_FILE"
        toggle_indicator
        local body
        body="Capture:  $(target_label "$target")"$'\n'
        body+="Audio:    $(audio_label)"$'\n'
        body+="Quality:  ${res_label} · ${FPS} fps"
        [[ $WEBCAM == true ]] && body+=$'\n'"Webcam:   on"
        body+=$'\n'"File:     $(basename "$file")"$'\n'
        body+=$'\n'"⏹  Stop: Super+Alt+R  ·  or Menu → Screenrecord"
        notify-send -t 8000 -u normal -i media-record "  Recording started" "$body"
    else
        # gsr died before opening the file (e.g. encoder/capture failure)
        cleanup_webcam
        notify-send -u critical -t 5000 "Screen recording" \
            "Failed to start. Run with OMARCHY_SCREENRECORD_DEBUG to inspect."
        return 1
    fi
}

finalize() {
    local f=$(cat "$RECORDING_FILE" 2>/dev/null)
    [[ -f $f ]] || return

    # Trim 100ms warmup, normalize audio if present
    local args=(-y -ss 0.1 -i "$f" -c:v copy)
    if ffprobe -v error -select_streams a -show_entries stream=codec_type -of csv=p=0 "$f" 2>/dev/null | grep -q audio; then
        args+=(-af "volume=enable='lt(t,0.4)':volume=0,afade=t=in:st=0.4:d=0.05,loudnorm=I=-14:TP=-1.5:LRA=11")
    fi
    local proc="${f%.mp4}-processed.mp4"
    if ffmpeg "${args[@]}" "$proc" -loglevel quiet 2>/dev/null; then
        mv "$proc" "$f"
    else
        rm -f "$proc"
    fi
}

stop_recording() {
    pkill -SIGINT -f "^gpu-screen-recorder"
    local n=0
    while pgrep -f "^gpu-screen-recorder" >/dev/null && (( n < 50 )); do
        sleep 0.1; n=$((n+1))
    done
    pgrep -f "^gpu-screen-recorder" >/dev/null && pkill -9 -f "^gpu-screen-recorder"

    cleanup_webcam
    toggle_indicator
    finalize

    local f=$(cat "$RECORDING_FILE" 2>/dev/null)
    rm -f "$RECORDING_FILE"
    [[ -f $f ]] || return

    # Generate first-frame preview thumbnail
    local prev="${f%.mp4}-preview.png"
    ffmpeg -y -i "$f" -ss 0.1 -vframes 1 -q:v 2 "$prev" -loglevel quiet 2>/dev/null

    (
        ACTION=$(notify-send "Recording saved" "Click to play" -t 10000 \
            -i "${prev:-$f}" -A "default=open")
        [[ $ACTION == "default" ]] && mpv "$f"
        rm -f "$prev"
    ) &
}

if is_recording; then
    stop_recording
elif [[ $STOP == true ]]; then
    exit 1
else
    start_recording
fi
