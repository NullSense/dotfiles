#!/usr/bin/env bash
# Localhost services launcher (Super+S). Ports + titles are AUTO-DISCOVERED by
# ~/bin/discover-services — the SAME engine the Glance dashboard uses (DRY).
# Titles: ~/.config/services.toml overrides > docker name > HTML <title> > process.
# Friendly names / databases live in services.toml. Pick a row → opens the port.
set -euo pipefail

rows=$(~/bin/discover-services \
  | jq -r '.[] | "\(.port)\t\(.title // "(no label)")\t\(.proc)"' \
  | awk -F'\t' '{printf "%-6s  %-34.34s  %s\n", $1, $2, $3}')

[[ -z "${rows:-}" ]] && { notify-send services "No localhost listeners found"; exit 0; }

choice=$(printf '%s\n' "$rows" | /home/nullsense/bin/launch-walker \
    --dmenu --width 780 --placeholder 'localhost') || exit 0
[[ -z "${choice:-}" ]] && exit 0

port=$(awk '{print $1}' <<<"$choice")
[[ "$port" =~ ^[0-9]+$ ]] || exit 1

xdg-open "http://localhost:$port" >/dev/null 2>&1 &
notify-send -t 2000 services "Opened http://localhost:$port"
