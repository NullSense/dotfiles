#!/usr/bin/env bash
# stack — bring up the whole local dev stack with one command.
#   observability :3000 — grafana/otel-lgtm (OTel collector + Tempo/Loki/Prometheus/Grafana)
#   llama-swap    :9292 — model swapper (loads/unloads models per-request via TTL)
#   litellm       :4000 — OpenAI gateway (logical names → local/cloud; traces → :4318 collector)
#   glance        :8088 — dashboard (systemd --user unit)
#   uptime-kuma   :3009 — uptime/SLA (docker container)
# llama-swap frees VRAM on idle, so the LLM half is on-demand. Observability + dashboards are
# monitoring — `up` ensures them, `down` LEAVES them. See ~/notes/LLM-STACK.md.
#
# Secrets: litellm's cloud routes need OPENROUTER_API_KEY + LITELLM_MASTER_KEY, injected from
# Infisical via `infisical run` (NOT agent-vault — that's for agent tool-calls).
set -euo pipefail

LLMSTACK="${LLMSTACK:-$HOME/Programming/llm-stack}"   # central repo: composes, collector, benches
LSWAP_CFG="${LSWAP_CFG:-$HOME/.config/llama-swap/config.yaml}"
LITELLM_CFG="${LITELLM_CFG:-$HOME/.config/litellm/config.yaml}"
OBS_COMPOSE="${OBS_COMPOSE:-$LLMSTACK/stack/observability/docker-compose.yml}"
LANGFUSE_COMPOSE="${LANGFUSE_COMPOSE:-$LLMSTACK/stack/langfuse/docker-compose.yml}"
COLLECTOR_COMPOSE="${COLLECTOR_COMPOSE:-$LLMSTACK/stack/collector/docker-compose.yml}"
OWUI_COMPOSE="${OWUI_COMPOSE:-$LLMSTACK/stack/open-webui/docker-compose.yml}"
RUN="${RUN:-$HOME/.cache/llm-stack}"; mkdir -p "$RUN"

# up = got any HTTP code (401 from litellm still means "alive"); 000 = not listening.
is_up() { local c; c=$(curl -s -o /dev/null -w '%{http_code}' --max-time 2 "$1" 2>/dev/null || true); [ -n "$c" ] && [ "$c" != "000" ]; }
wait_tcp() { local h="${1%:*}" p="${1#*:}" i; for i in $(seq 1 "${2:-15}"); do (exec 3<>"/dev/tcp/$h/$p") 2>/dev/null && { exec 3>&- 3<&-; return 0; }; sleep 1; done; return 1; }
kill_port() {  # kill whatever LISTENS on a TCP port — reliable, no fuser/pattern guessing
  local port="$1" pids
  pids=$(ss -tlnpH "sport = :$port" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | sort -u)
  [ -n "$pids" ] || return 1
  kill $pids 2>/dev/null; sleep 1
  pids=$(ss -tlnpH "sport = :$port" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | sort -u)
  [ -n "$pids" ] && kill -9 $pids 2>/dev/null || true
  return 0
}

sweep_swap_children() {  # llama-swap spawns llama-server backends as its OWN children; `down`
  # kills only the :9292 listener (llama-swap itself), orphaning those children — they reparent
  # to systemd, keep pinning VRAM, and the next llama-swap can't see them (/running lies). Kill
  # the subtree FIRST, while llama-swap is alive so we can find them. This now includes the dictation
  # rewriter (the `rewrite` E4B model) — as of 2026-07-20 it's a llama-swap-managed vLLM container
  # (name vllm-gemma4b), not a standalone systemd service; the `down` case also `docker stop`s it
  # explicitly since a --rm container can outlive the reaped `docker run` client.
  local swap_pids p kids
  swap_pids=$(ss -tlnpH "sport = :9292" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | sort -u)
  [ -n "$swap_pids" ] || swap_pids=$(pgrep -x llama-swap 2>/dev/null || true)
  for p in $swap_pids; do
    kids=$(pgrep -P "$p" 2>/dev/null || true)
    [ -n "$kids" ] || continue
    kill $kids 2>/dev/null || true; sleep 1
    kids=$(pgrep -P "$p" 2>/dev/null || true)
    [ -n "$kids" ] && kill -9 $kids 2>/dev/null || true
  done
}

start_one() { # name  health-url  command...
  local name="$1" url="$2"; shift 2
  if is_up "$url"; then
    if [ -f "$RUN/$name.pid" ]; then echo "  • $name already up"
    else echo "  ⚠ $name's port is held by a process stack didn't start (likely a stray docker"
         echo "    container). Free it:  docker ps --filter publish=<port> -q | xargs -r docker stop"; fi
    return
  fi
  nohup "$@" >"$RUN/$name.log" 2>&1 &
  echo $! >"$RUN/$name.pid"
  echo "  ▶ $name started (pid $(cat "$RUN/$name.pid")) → log: $RUN/$name.log"
}

ensure_gateway_db() {  # ONLY litellm-db — the always-on bit the gateway needs. The rest of
  # observability (otel-lgtm + Langfuse + collector) is ~6 GB of RAM only needed while you're
  # actually inspecting traces, so it's off by default. Bring it up on demand with `stack obs`.
  command -v docker >/dev/null 2>&1 || { echo "  ⚠ docker not found — skipping gateway DB"; return; }
  docker network inspect llmstack >/dev/null 2>&1 || docker network create llmstack >/dev/null
  docker compose -f "$OBS_COMPOSE" up -d litellm-db >/dev/null 2>&1 \
    && echo "  ▶ gateway DB → litellm-db :5433  (obs off — run 'stack obs' for Grafana/Langfuse)" \
    || echo "  ⚠ litellm-db compose up failed"
}

ensure_obs() {  # FULL observability (Grafana/Tempo) + Langfuse + the collector that fans out to both
  command -v docker >/dev/null 2>&1 || { echo "  ⚠ docker not found — skipping observability"; return; }
  docker network inspect llmstack >/dev/null 2>&1 || docker network create llmstack >/dev/null
  docker compose -f "$OBS_COMPOSE" up -d >/dev/null 2>&1 \
    && echo "  ▶ observability → Grafana :3000 · Tempo :3200 · Prom :9090 · litellm-db :5433" \
    || echo "  ⚠ observability compose up failed"
  if [ -s "$(dirname "$LANGFUSE_COMPOSE")/.env" ]; then
    ( cd "$(dirname "$LANGFUSE_COMPOSE")" && docker compose --env-file .env up -d >/dev/null 2>&1 ) \
      && echo "  ▶ langfuse → http://localhost:3002 (LLM traces + eval datasets)" \
      || echo "  ⚠ langfuse compose up failed"
  else echo "  ⚠ langfuse .env missing — run: bash $LLMSTACK/stack/langfuse/gen-env.sh"; fi
  ( cd "$(dirname "$COLLECTOR_COMPOSE")" && docker compose --env-file ../langfuse/.env up -d >/dev/null 2>&1 ) \
    && echo "  ▶ otel-collector → OTLP :4317/:4318 → fans out to Tempo + Langfuse" \
    || echo "  ⚠ collector compose up failed"
}

ensure_dashboards() {
  if is_up http://127.0.0.1:8088/; then echo "  • glance already up"
  elif systemctl --user start glance 2>/dev/null; then echo "  ▶ glance → :8088 (systemd)"
  else start_one glance http://127.0.0.1:8088/ "$HOME/.local/bin/glance" --config "$HOME/.config/glance/glance.yml"; fi
  if is_up http://127.0.0.1:3009/; then echo "  • uptime-kuma already up"
  elif command -v docker >/dev/null 2>&1 && docker start uptime-kuma >/dev/null 2>&1; then echo "  ▶ uptime-kuma → :3009 (docker)"
  else echo "  ⚠ uptime-kuma not running (one-time: docker run -d --restart=unless-stopped -p 3009:3001 -v uptime-kuma:/app/data --name uptime-kuma louislam/uptime-kuma:1)"; fi
  # Open WebUI (chat front-end for the gateway). Retired 2026-07-09 — no longer used.
  # Opt back in with STACK_OWUI=1 (its compose still lives in stack/open-webui/).
  if [ "${STACK_OWUI:-0}" = "1" ]; then
    if is_up http://127.0.0.1:8090/; then echo "  • open-webui already up"
    elif [ -s "$(dirname "$OWUI_COMPOSE")/.env" ] && command -v docker >/dev/null 2>&1; then
      ( cd "$(dirname "$OWUI_COMPOSE")" && docker compose --env-file .env up -d >/dev/null 2>&1 ) \
        && echo "  ▶ open-webui → :8090 (docker · tailnet http://100.121.121.37:8090)" \
        || echo "  ⚠ open-webui failed to start (docker compose)"
    else echo "  ⚠ open-webui not started (missing stack/open-webui/.env or docker)"; fi
  fi
  # Refresh Glance's auto-discovered service cards (DRY: same ~/bin/discover-services the
  # Super+S picker uses). Glance hot-reloads on file change. Non-fatal.
  if [ -f "$HOME/Programming/llm-stack/stack/gen-glance-services.py" ]; then
    python3 "$HOME/Programming/llm-stack/stack/gen-glance-services.py" >/dev/null 2>&1 \
      && echo "  • glance service cards refreshed (auto-discovered)" || true
  fi
}

case "${1:-status}" in
  up)
    # obs is ~6 GB and only needed to VIEW traces → off by default. `stack obs` (or STACK_OBS=1
    # stack up) brings up otel-lgtm + Langfuse + collector; otherwise just the gateway DB.
    if [ "${STACK_OBS:-0}" = 1 ]; then ensure_obs; else ensure_gateway_db; fi
    start_one llama-swap http://127.0.0.1:9292/health llama-swap --config "$LSWAP_CFG" --watch-config --listen 127.0.0.1:9292
    wait_tcp 127.0.0.1:5433 15 && echo "  • gateway DB ready :5433" \
      || echo "  ⚠ litellm-db not ready — virtual keys (/key/generate) may fail until it is"
    # local LLM-call tracing → otel-lgtm collector. House standard is gRPC :4317 (matches
    # sift/oracle); collector accepts 4317/4318 either way. gRPC needs grpcio in litellm's
    # venv — fall back to OTEL_EXPORTER=otlp_http + :4318 if it's missing.
    export LITELLM_OTEL_V2=true OTEL_EXPORTER="${OTEL_EXPORTER:-otlp_grpc}" \
      OTEL_ENDPOINT="${OTEL_ENDPOINT:-http://localhost:4317}" \
      OTEL_SERVICE_NAME=litellm OTEL_ENVIRONMENT_NAME="${OTEL_ENV:-local}"
    # THE SWITCH: which deployment each switchable name (summarize-cheap/strong, oracle-llm)
    # resolves to. development=LOCAL (llama-swap, default), production=CLOUD (OpenRouter).
    # Flip the whole gateway to cloud:  LITELLM_ENVIRONMENT=production stack restart
    export LITELLM_ENVIRONMENT="${LITELLM_ENVIRONMENT:-development}"
    echo "  • litellm environment: $LITELLM_ENVIRONMENT ($([ "$LITELLM_ENVIRONMENT" = production ] && echo 'CLOUD/OpenRouter' || echo 'LOCAL/llama-swap'))"
    LITELLM_CMD=(litellm --config "$LITELLM_CFG" --port 4000)
    # agent-vault proxy for the MCP subprocesses litellm spawns (NOT litellm core egress).
    # Surgical: only the stdio MCP env blocks reference AV_HTTPS_PROXY (see docs/SECRETS-AND-MCP.md).
    if command -v agent-vault >/dev/null 2>&1 && _AVT="$(agent-vault vault token --vault default 2>/dev/null)" && [ -n "$_AVT" ]; then
      export AV_HTTPS_PROXY="https://${_AVT}:default@127.0.0.1:14322"
      export AV_CA="$HOME/.agent-vault/mitm-ca.pem"
      unset _AVT
    fi
    if command -v infisical >/dev/null 2>&1 && [ "${STACK_NO_INFISICAL:-0}" != 1 ]; then
      echo "  • litellm secrets ← Infisical (${INFISICAL_ENV:-dev}:${INFISICAL_PATH:-/litellm})"
      start_one litellm http://127.0.0.1:4000/health \
        infisical run --env "${INFISICAL_ENV:-dev}" --path "${INFISICAL_PATH:-/litellm}" -- "${LITELLM_CMD[@]}"
    else
      [ -n "${OPENROUTER_API_KEY:-}" ] || echo "  ⚠ OPENROUTER_API_KEY unset — cloud routes will 401" >&2
      [ -n "${LITELLM_MASTER_KEY:-}" ] || echo "  ⚠ LITELLM_MASTER_KEY unset — no admin/virtual keys" >&2
      start_one litellm http://127.0.0.1:4000/health "${LITELLM_CMD[@]}"
    fi
    # Dictation rewrite backend is llama-swap `rewrite` (vLLM E4B NVFP4 + MTP, thinking off) — the
    # STANDALONE fixed-:8001 vLLM container was retired 2026-07-20 (its boot race dropped dictation;
    # the :8083 hyprwhspr-rewrite-e4b.service dupe also removed). The SAME vLLM engine is now a normal
    # llama-swap-managed model on a dynamic port; everything flows through llama-swap: hyprwhspr-ai
    # dictation, litellm summarize-cheap + rewrite-fast. `rewrite` is ttl:0 (resident) but lazy-load-
    # on-first-request, so fire one warm request THROUGH llama-swap right after `stack up`. Non-blocking.
    ( curl -s -o /dev/null --max-time 120 http://127.0.0.1:9292/v1/chat/completions \
        -H 'Content-Type: application/json' \
        -d '{"model":"rewrite","messages":[{"role":"user","content":"hi"}],"max_tokens":1}' \
        && echo "  ▶ rewrite warmed via llama-swap → :9292 (vLLM E4B NVFP4+MTP · dictation/summarize-cheap)" \
        || echo "  ⚠ rewrite warm request failed — check llama-swap logs" ) &
    echo "  ▶ rewrite warming via llama-swap (:9292, background, vLLM cold start ~40s)…"
    # Dashboards (glance :8088 + uptime-kuma :3009) are monitoring, not serving → opt-in.
    # `STACK_DASH=1 stack up` (or run `stack dash`) brings them up. Keeps `stack up` minimal:
    # just the gateway + always-on light models; heavy/monitoring bits load on demand.
    if [ "${STACK_DASH:-0}" = 1 ]; then ensure_dashboards; fi
    echo "  stack up (minimal). gateway → :4000 · rewrite/E4B → llama-swap :9292  (obs off: 'stack obs' · dashboards off: 'stack dash')"
    ;;
  dash) ensure_dashboards; echo "  dashboards up → glance :8088 · uptime-kuma :3009"; ;;
  gateway)  # JUST the litellm router (:4000) — NO models, 0 GB VRAM. It's a pure OpenAI proxy:
    # cloud routes (code→OpenRouter, and everything under LITELLM_ENVIRONMENT=production) + virtual-
    # key/config mgmt work immediately. Local logical names (summarize/rewrite→llama-swap :9292) 5xx
    # until you `stack up` their backends. Handy for config testing or cloud-only use. `stack down`
    # stops it. Shares the up) launch logic — just omits llama-swap + its local models.
    if [ "${STACK_OBS:-0}" = 1 ]; then ensure_obs; else ensure_gateway_db; fi
    wait_tcp 127.0.0.1:5433 15 && echo "  • gateway DB ready :5433" \
      || echo "  ⚠ litellm-db not ready — virtual keys (/key/generate) may fail until it is"
    export LITELLM_OTEL_V2=true OTEL_EXPORTER="${OTEL_EXPORTER:-otlp_grpc}" \
      OTEL_ENDPOINT="${OTEL_ENDPOINT:-http://localhost:4317}" \
      OTEL_SERVICE_NAME=litellm OTEL_ENVIRONMENT_NAME="${OTEL_ENV:-local}"
    export LITELLM_ENVIRONMENT="${LITELLM_ENVIRONMENT:-development}"
    echo "  • litellm environment: $LITELLM_ENVIRONMENT ($([ "$LITELLM_ENVIRONMENT" = production ] && echo 'CLOUD/OpenRouter' || echo 'LOCAL/llama-swap'))"
    LITELLM_CMD=(litellm --config "$LITELLM_CFG" --port 4000)
    if command -v agent-vault >/dev/null 2>&1 && _AVT="$(agent-vault vault token --vault default 2>/dev/null)" && [ -n "$_AVT" ]; then
      export AV_HTTPS_PROXY="https://${_AVT}:default@127.0.0.1:14322"
      export AV_CA="$HOME/.agent-vault/mitm-ca.pem"
      unset _AVT
    fi
    if command -v infisical >/dev/null 2>&1 && [ "${STACK_NO_INFISICAL:-0}" != 1 ]; then
      echo "  • litellm secrets ← Infisical (${INFISICAL_ENV:-dev}:${INFISICAL_PATH:-/litellm})"
      start_one litellm http://127.0.0.1:4000/health \
        infisical run --env "${INFISICAL_ENV:-dev}" --path "${INFISICAL_PATH:-/litellm}" -- "${LITELLM_CMD[@]}"
    else
      [ -n "${OPENROUTER_API_KEY:-}" ] || echo "  ⚠ OPENROUTER_API_KEY unset — cloud routes will 401" >&2
      [ -n "${LITELLM_MASTER_KEY:-}" ] || echo "  ⚠ LITELLM_MASTER_KEY unset — no admin/virtual keys" >&2
      start_one litellm http://127.0.0.1:4000/health "${LITELLM_CMD[@]}"
    fi
    echo "  gateway up → :4000 (no models · 'stack up' adds llama-swap + vLLM E4B)"
    ;;
  pro)  # PREMIUM summary window: diffusiongemma (:8002, summarize-pro). Measured: the 26B MoE
        # NVFP4 needs ~24GB, which does NOT fit alongside BOTH the E4B slot (~15GB) AND the
        # parakeet STT (~5.7GB) on a 32GB card. So `pro on` evicts BOTH (summarize-cheap +
        # dictation fully DOWN for the window); `pro off` restores both. Explicit, on-demand,
        # fully reversible. Parakeet's permanent config is untouched — it's only stopped while open.
    case "${2:-on}" in
      on|start)
        command -v docker >/dev/null 2>&1 || { echo "  ⚠ docker not found"; exit 1; }
        echo "  ▶ premium window: freeing VRAM (evicting E4B + parakeet STT) for diffusiongemma…"
        # `rewrite` (E4B) is a llama-swap-managed model — unload it through llama-swap's own
        # API instead of killing a process, so llama-swap's internal state (loaded/unloaded)
        # stays truthful for anyone else querying /running or /v1/models.
        curl -s --max-time 5 'http://127.0.0.1:9292/unload?model=rewrite' >/dev/null 2>&1 \
          && echo "  ■ rewrite (E4B) unloaded via llama-swap — summarize-cheap DOWN until 'stack pro off'"
        systemctl --user stop hyprwhspr.service 2>/dev/null && echo "  ■ hyprwhspr STT stopped — dictation DOWN until 'stack pro off'"
        docker rm -f vllm-diffusiongemma >/dev/null 2>&1
        ( PORT=8002 setsid /home/nullsense/bin/llm-servers/vllm-diffusiongemma >/tmp/vllm-diffusiongemma.log 2>&1 < /dev/null & )
        echo "  ▶ vllm-diffusiongemma → :8002 (summarize-pro · warming ~40-60s). Watch: tail -f /tmp/vllm-diffusiongemma.log"
        ;;
      off|stop)
        echo "  ▶ closing premium window: diffusiongemma → E4B + parakeet…"
        docker rm -f vllm-diffusiongemma >/dev/null 2>&1 && echo "  ■ vllm-diffusiongemma stopped (:8002)"
        systemctl --user start hyprwhspr.service 2>/dev/null && echo "  ▶ hyprwhspr STT restored (dictation back up)"
        # Reload through llama-swap (`rewrite` model) instead of a bare process start —
        # same reasoning as `pro on` above.
        ( curl -s -o /dev/null --max-time 90 http://127.0.0.1:9292/v1/chat/completions \
            -H 'Content-Type: application/json' \
            -d '{"model":"rewrite","messages":[{"role":"user","content":"hi"}],"max_tokens":1}' \
            && echo "  ▶ rewrite restored via llama-swap → :9292 (summarize-cheap + dictation back up)" \
            || echo "  ⚠ rewrite warm request failed — check llama-swap logs" ) &
        echo "  ▶ rewrite reloading via llama-swap (:9292, background)…"
        ;;
      *) echo "usage: stack pro [on|off]"; exit 1 ;;
    esac
    ;;
  down)  # stops the LLM serving stack only — leaves observability + dashboards monitoring
    sweep_swap_children   # reap llama-server backends BEFORE killing llama-swap (else they orphan + pin VRAM)
    for entry in litellm:4000 llama-swap:9292; do
      name="${entry%%:*}"; port="${entry##*:}"
      # kill the actual port listener via ss (the infisical-run litellm child IS the listener).
      kill_port "$port" && echo "  ■ stopped $name (:$port)" || echo "  • $name not running"
      rm -f "$RUN/$name.pid"
    done
    # `rewrite` (E4B) is a llama-swap-managed vLLM CONTAINER (dynamic port, name vllm-gemma4b).
    # sweep_swap_children reaps llama-swap's `docker run` client, but a --rm container can outlive
    # that, so stop it explicitly here (same as vllm-diffusiongemma, the stack-pro premium container).
    if command -v docker >/dev/null 2>&1; then
      docker ps -q --filter name=vllm-gemma4b | grep -q . && docker rm -f vllm-gemma4b >/dev/null 2>&1 && echo "  ■ stopped vllm-gemma4b (rewrite)"
      docker ps -q --filter name=vllm-diffusiongemma | grep -q . && docker rm -f vllm-diffusiongemma >/dev/null 2>&1 && echo "  ■ stopped vllm-diffusiongemma (:8002)"
    fi
    echo "  (observability + dashboards left running — 'stack mon-down' to stop those too)"
    ;;
  mon-down)
    systemctl --user stop glance 2>/dev/null && echo "  ■ glance" || true
    if command -v docker >/dev/null 2>&1; then
      docker stop uptime-kuma >/dev/null 2>&1 && echo "  ■ uptime-kuma" || true
      ( cd "$(dirname "$COLLECTOR_COMPOSE")" && docker compose --env-file ../langfuse/.env down >/dev/null 2>&1 ) && echo "  ■ collector" || true
      ( cd "$(dirname "$OWUI_COMPOSE")" && docker compose --env-file .env down >/dev/null 2>&1 ) && echo "  ■ open-webui" || true
      ( cd "$(dirname "$LANGFUSE_COMPOSE")" && docker compose --env-file .env down >/dev/null 2>&1 ) && echo "  ■ langfuse" || true
      docker compose -f "$OBS_COMPOSE" down >/dev/null 2>&1 && echo "  ■ observability" || true
    fi
    ;;
  obs)   # bring up the heavy observability stack (otel-lgtm + Langfuse + collector) on demand
    ensure_obs
    echo "  observability up · Grafana → :3000 · Langfuse → :3002  (stop with: stack mon-down)"
    ;;
  restart) "$0" down; sleep 1; "$0" up ;;
  status)
    command -v llms >/dev/null && llms
    for n in "glance:8088" "uptime-kuma:3009" "grafana:3000" "langfuse:3002" "collector:4318" "open-webui:8090"; do
      printf "  %-12s HTTP %s\n" "${n%%:*}" "$(curl -s -o /dev/null -w '%{http_code}' --max-time 2 http://127.0.0.1:${n##*:}/ 2>/dev/null || echo down)"
    done
    printf "  %-12s %s\n" "rewrite" "$(curl -s --max-time 2 http://127.0.0.1:9292/running 2>/dev/null | grep -q rewrite && echo 'loaded (llama-swap)' || echo 'idle — llama-swap loads on demand')"
    ;;
  db-init)  # one-time per machine (or after a litellm upgrade): prisma client + LiteLLM_* tables.
            # litellm virtual keys (/key/generate, llm-vkey) need these. Install prep — ALL extras
            # the gateway needs (prisma=DB/keys, diskcache=exact response cache, opentelemetry=otel
            # tracing). Use the FULL line on every (re)install; `--force` drops anything omitted:
            #   uv tool install 'litellm[proxy]' --with prisma --with diskcache \
            #     --with opentelemetry-api --with opentelemetry-sdk --with opentelemetry-exporter-otlp --force
            #   stack db-init   # re-run after any --force reinstall (it wipes the generated prisma client)
    TB="$HOME/.local/share/uv/tools/litellm/bin"
    SCHEMA=$(find "$HOME/.local/share/uv/tools/litellm" -path '*proxy_extras*schema.prisma' 2>/dev/null | head -1)
    [ -n "$SCHEMA" ] || { echo "  ⚠ litellm prisma schema not found — run: uv tool install 'litellm[proxy]' --with prisma --with diskcache --with opentelemetry-api --with opentelemetry-sdk --with opentelemetry-exporter-otlp --force"; exit 1; }
    PATH="$TB:$PATH" "$TB/prisma" generate --schema "$SCHEMA" 2>&1 | tail -2 || true
    DATABASE_URL="${DATABASE_URL:-postgresql://litellm@127.0.0.1:5433/litellm}" \
      PATH="$TB:$PATH" "$TB/prisma" db push --schema "$SCHEMA" --skip-generate --accept-data-loss 2>&1 | tail -2
    echo "  ✓ prisma generated + LiteLLM_* tables ready — 'stack restart' then llm-vkey works"
    ;;
  logs) tail -n 40 -F "$RUN"/*.log ;;
  *) echo "usage: stack {up|gateway|dash|pro|obs|down|mon-down|restart|status|logs|db-init}"; exit 1 ;;
esac
