#!/usr/bin/env bash
# Interactive aliases. Sourced from ~/.zshrc.
#
# Skip in any AI agent shell AND any non-interactive shell.
#
# Background: the 2026-05-08 incident happened because `alias ls=eza` got
# captured into Claude Code's shell snapshot. eza prints `name -> target`
# for symlinks even without -l; combined with `xargs -I {}` (unquoted
# substitution into sh -c), the `->` was parsed as `> target` and truncated
# ~600 user-writable files to their own absolute path. See
# ~/the-night-an-ai-ate-my-home-directory.md for the postmortem.
#
# Agent-shell guard. Two architectures, both detected here:
#   1. agent-vault: `agent-vault vault run --vault default -- <agent>` sets
#      AGENT_VAULT_SESSION_TOKEN for the wrapped child.
#   2. agent-isolated (bubblewrap, current default for claude/codex/opencode):
#      sets AGENT_ISOLATED=1 in the sandbox env. The wrapper also propagates
#      AGENT_VAULT_SESSION_TOKEN only when --agent-vault is passed; otherwise
#      it scrubs that env var entirely.
# Either signal short-circuits alias loading so an interactive alias
# (cf. the 2026-05-08 `alias ls=eza` incident) never gets captured into an
# agent's shell snapshot. Non-interactive shells skip too.
[[ -n "${AGENT_VAULT_SESSION_TOKEN:-}" ]] && return 0
[[ -n "${AGENT_ISOLATED:-}" ]] && return 0
[[ -o interactive ]] || return 0

# Aliases
# Pacman
alias psyu="sudo pacman -Syu"

alias vim="nvim"
alias se="sudoedit"
#
# Docker
alias dcu="docker-compose up"
alias dcd="docker-compose down"
alias dcr="docker-compose restart"

# git aliases
alias gs='git st'
alias gl='git_log_pretty'
alias gri='git rebase -i'
alias grc='git rebase --continue'
alias grm="git rebase master"
alias gc="git checkout"

alias rsync='rsync --info=progress2'
alias l='ls -Fh --color=auto --group-directories-first'
alias ll='ls -alF --color=auto --group-directories-first'
alias dropdown='nohup alacritty -t dropdown_term > /dev/null 2>&1 &|' # dropdown terminal
alias ls="eza"
alias cat="bat"
alias find="fd"
alias pytest="pytest --reuse-db --reruns 0 -n auto"
alias pyl="pytest --reuse-db --lf -n0 -fsvv"

# Modern CLI tools
alias top="btop"
alias help='tldr'
alias z='zoxide'
alias zi='zoxide query -i'

# Handy shortcuts
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias mk='mkdir -p'
alias h='history'
alias path='echo -e ${PATH//:/\\n}'
alias ports='ss -tulanp'

# Safety nets
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# Sway/Wayland
alias wayrestart="killall -SIGUSR2 waybar"
alias wayreload="swaymsg reload"

# Audio — restart pipewire stack AND xdg portals together so browser/Discord
# regain mic access after chain edits. Edit ~/.config/pipewire/pipewire.conf.d/
# then run `audio-restart`.
alias audio-restart="systemctl --user restart pipewire pipewire-pulse wireplumber xdg-desktop-portal xdg-desktop-portal-gtk xdg-desktop-portal-wlr"

# Git shortcuts (additional to git aliases in gitconfig)
alias gd='git diff'
alias ga='git add'
alias gaa='git add --all'
alias gp='git push'
alias gpl='git pull'

# System info
alias cleanup='sudo pacman -Sc && paru -Sc'
alias orphans='sudo pacman -Qtdq | sudo pacman -Rns -'

# NOTE: claude/codex/opencode are NOT aliased here. dot_zshrc defines them
# as shell functions (after sourcing this file) that route through
# ~/bin/agent-isolated for OS-level bubblewrap isolation. To get the old
# agent-vault credential-injection behaviour, pass --agent-vault:
#     claude --agent-vault   # binds the MITM CA + propagates AGENT_VAULT_SESSION_TOKEN
# Direct bypass: `command claude` or `AGENT_UNSANDBOX=1 claude`.
