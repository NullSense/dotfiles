#!/usr/bin/env bash
# llama-server wrapper for Gemma4-12B-it Claude-Opus-distill + MTP via Vulkan (RADV)
# Hardware: AMD Ryzen 9700X (8c/16t Zen 5) + RX 6750 XT (12GB, NAVI22/gfx1031) + 64GB DDR5-5800
# Model:    yuxinlu1/gemma-4-12B-it-Claude-4.6-4.8-Opus-GGUF (Q4_K_M, 7.4GB, dense 12B)
#           + MTP draft head (gemma-4-12B-it-MTP-Q8_0.gguf, 0.44GB) — lossless self-spec.
# Card:     https://huggingface.co/yuxinlu1/gemma-4-12B-it-Claude-4.6-4.8-Opus-GGUF
#
# MTP needs llama.cpp b9553+ (Gemma 4 MTP merged 2026-06-07); this box runs b9585.
# Card-recommended sampling: temp 1.0, top_p 0.95, top_k 64, thinking ON
# (enable_thinking template kwarg — template is the one EMBEDDED in the GGUF, no
# external .jinja exists for this repo; --jinja activates it).
#
# Why Vulkan, not ROCm/HIP: same story as llama-qwen36 — ROCm 7.2.3 has no gfx1031
# Tensile library. Vulkan/RADV is the stable path on RDNA2.
#
# Unlike the Qwen3.6 MoE setup there is NO --n-cpu-moe here: dense 12B at Q4_K_M
# fits entirely in 12GB VRAM, so decode runs full-speed on GPU. Gemma 4 is
# mostly sliding-window attention (5:1 SWA:full, tiny global KV heads), and
# llama.cpp's default window-sized SWA cache makes 131k ctx cheap enough to
# keep on-GPU. NOTE the SWA trade-off: prompt-cache reuse only works for
# strict prefix-extension (normal chat appends are fine); --cache-reuse /
# context-shift are unsupported for SWA models, hence absent below.
set -euo pipefail

# Constrain Vulkan to the discrete GPU (0); index 1 is the Raphael iGPU.
export GGML_VK_VISIBLE_DEVICES=0

# RADV dedicated transfer queue (see llama-qwen36 for rationale; harmless here
# since we're fully offloaded, still reduces compositor contention).
# RADV_PERFTEST=transfer_queue is deprecated on this Mesa — the knob moved.
export RADV_EXPERIMENTAL="${RADV_EXPERIMENTAL:+$RADV_EXPERIMENTAL,}transfer_queue"

MODEL_DIR="$HOME/.lmstudio/models/yuxinlu1/gemma-4-12B-it-Claude-4.6-4.8-Opus-GGUF"
MODEL="${MODEL:-$MODEL_DIR/gemma4-opus48-Q4_K_M.gguf}"
DRAFT="${DRAFT:-$MODEL_DIR/gemma-4-12B-it-MTP-Q8_0.gguf}"
SLOTS_DIR="${SLOTS_DIR:-$HOME/.cache/llama-cpp/slots-gemma4}"
PORT="${PORT:-8082}"   # 8080 = llama-qwen36, 8081 = taken (system), 1234 = LM Studio
# Context: 131072 (card max) DOES fit on paper — measured 65.9 t/s in isolation —
# but it leaves only ~0.5 GiB VRAM slack next to a live desktop. The moment the
# browser/Discord/Steam allocate, amdgpu evicts ~2.5 GiB of llama buffers to GTT
# and decode craters to ~15-21 t/s (measured 2026-06-11; check with
# mem_info_gtt_used on card1 — >1 GiB while serving = you're spilling).
# 65536 frees ~1 GiB of headroom and is still plenty for ChatGPTBox/coding.
# Use CTX=131072 only when the GPU is otherwise idle.
# (GGUF metadata claims n_ctx_train=262144, but the card says 131k max.)
CTX="${CTX:-65536}"
mkdir -p "$SLOTS_DIR"

# MODE selects thinking + sampler defaults. Clients can override BOTH per request:
# samplers via the usual OpenAI params, thinking via "chat_template_kwargs":
# {"enable_thinking": false} in the request body (hyprwhspr-rewrite does this).
#   think — Opus-distill reasoning (card-recommended sampling). ChatGPTBox, coding.
#   fast  — thinking disabled server-side for minimum latency. Dictation-only server.
MODE="${MODE:-think}"
case "$MODE" in
  think) REASON=on;  TEMP=1.0; TOPP=0.95; TOPK=64 ;;
  fast)  REASON=off; TEMP=0.7; TOPP=0.95; TOPK=64 ;;
  *) echo "MODE must be think | fast"; exit 1 ;;
esac

# MTP speculative decoding. The card recommends n-max 4, but it also warns the
# stock drafter has a lower hit rate on this finetune — live sessions measured
# 23-42% acceptance (~1.1 accepted per 4-token draft round), where 4-deep
# drafting is mostly waste. BUT this wrapper now serves summarize-strong only
# (long outputs) — dictation moved to the E4B — and for long generations n-max 4
# amortizes draft overhead across far more verified tokens per round, matching the
# card's own recommendation (~1.3x greedy / ~1.2x thinking). Speculation is lossless,
# so the only risk is wasted draft compute on low-acceptance spans; default 4 per the
# card. SPECN=2 reverts to the conservative dictation-era value, SPEC=off disables it.
SPEC="${SPEC:-on}"
SPECN="${SPECN:-4}"
SPEC_ARGS=()
if [[ "$SPEC" == "on" ]]; then
  SPEC_ARGS=(
    --model-draft "$DRAFT"
    --spec-type draft-mtp
    --spec-draft-n-max "$SPECN"
    --n-gpu-layers-draft 99
  )
fi

# --cache-ram 2048: cap the host-RAM prompt cache (default 8192). It saves KV
# states of past prompts in system RAM (it is NOT a VRAM spill), but its
# bookkeeping cost grows with size — measured up to 430ms per request at ~2 GiB.
#
# NP (--parallel) + KVU (--kv-unified), 2026-06-11: two slots let a short
# dictation rewrite be scheduled alongside a long request instead of queueing
# 5-18s behind it (hyprwhspr hook caps at 4.5s → raw ASR injected). KVU pools
# the full -c across slots dynamically (no per-slot ctx halving, ~zero extra
# VRAM); idle overflow spills to --cache-ram.
# ⚠ MEASURED COST on this box (b9585 Vulkan, 2026-06-11): ANY NP>1 drops the
# 12B's single-stream generation 55 → ~33 tok/s — with or without MTP, with or
# without KVU — and NP=2 aggregate (~30-39 tok/s) never beats NP=1 sequential
# (55 tok/s). Parallel slots are a strict loss on this model+backend, so the
# default is 1. The dictation-queueing problem that motivated NP=2 was caused
# by benchmark traffic; if rewrites queue again, point hyprwhspr at the E4B
# (`hyprwhspr-ai backend` + llama-gemma4b) instead — it scales to 4 slots at
# 2.3x aggregate (171 tok/s) and is 2x faster per request anyway.
NP="${NP:-1}"
KVU="${KVU:-on}"
PAR_ARGS=(--parallel "$NP")
if [[ "$NP" != 1 && "$KVU" == "on" ]]; then
  PAR_ARGS+=(--kv-unified)
fi
exec -a "gemma4-12b@${PORT}.llama-server" llama-server \
  --model "$MODEL" \
  --alias "gemma4-opus-distill" \
  --host 127.0.0.1 --port "$PORT" \
  --device Vulkan0 \
  --fit off \
  --n-gpu-layers 99 \
  --ctx-size "$CTX" \
  --slot-save-path "$SLOTS_DIR" \
  --slot-prompt-similarity 0.5 \
  --flash-attn on \
  --cache-type-k q8_0 \
  --cache-type-v q8_0 \
  --threads 8 \
  --threads-batch 8 \
  "${PAR_ARGS[@]}" \
  --no-mmap \
  --temp "$TEMP" \
  --top-p "$TOPP" \
  --top-k "$TOPK" \
  --min-p 0.0 \
  --repeat-penalty 1.0 \
  --jinja \
  --reasoning "$REASON" \
  --cache-ram 2048 \
  "${SPEC_ARGS[@]}" \
  --metrics
