#!/usr/bin/env bash
# llama-server wrapper for Qwen3.6-35B-A3B APEX-MTP via CUDA (RTX 5090)
# Hardware: AMD Ryzen 9700X (8c/16t Zen 5) + RTX 5090 (32GB, Blackwell sm_120) + 64GB DDR5-5800
# Model:    mudler/Qwen3.6-35B-A3B-APEX-MTP-GGUF (I-Quality, ~24GB)
# Features: MTP self-spec, 128k ctx, FULL GPU offload, persistent slot cache.
#           (ngram-map-k4v was dropped 2026-05-21 — see the note above the spec flags)
#
# Backend: CUDA on the RTX 5090 (llama.cpp-cuda build); AMD/Vulkan retired 2026-06. The
# whole ~24GB Q4 MoE now lives in 32GB VRAM, so --n-cpu-moe is GONE — every expert layer
# runs on the GPU (the old gfx1031 box could only fit attention + ~12 expert layers, the
# rest streamed off CPU RAM over PCIe and capped decode at ~31 t/s).
set -euo pipefail

# Single CUDA GPU (RTX 5090).
export CUDA_VISIBLE_DEVICES=0

MODEL="${MODEL:-$HOME/.lmstudio/models/mudler/Qwen3.6-35B-A3B-APEX-MTP-GGUF/Qwen3.6-35B-A3B-APEX-MTP-I-Quality.gguf}"
TEMPLATE="${TEMPLATE:-$HOME/.config/llama-cpp/qwen36-merged-fakezeta-allanchan-froggeric.jinja}"
SLOTS_DIR="${SLOTS_DIR:-$HOME/.cache/llama-cpp/slots}"
PORT="${PORT:-8080}"
# Context: weights alone are ~21.3GB, so on the 32GB card the full 131k compute buffer
# only fits when this model runs SOLO. With the always-on dictation server (:8083, ~4.4GB)
# resident, 131k OOMs — 65536 keeps the compute buffer small enough to coexist and is
# ample for coding/reasoning. Bump CTX=131072 when dictation is stopped and qwen runs alone.
CTX="${CTX:-65536}"
mkdir -p "$SLOTS_DIR"

# MODE selects sampler + reasoning. preserve_thinking is a template-kwarg (no CLI flag).
MODE="${MODE:-code}"
case "$MODE" in
  code)   TEMP=0.6; TOPP=0.95; PRES=0.0; REASON=on;  PRESERVE=true  ;;  # precise coding (Qwen-recommended)
  chat)   TEMP=1.0; TOPP=0.95; PRES=1.5; REASON=on;  PRESERVE=false ;;  # general tasks
  fast)   TEMP=0.7; TOPP=0.8;  PRES=1.5; REASON=off; PRESERVE=false ;;  # non-thinking, low latency
  *) echo "MODE must be code | chat | fast"; exit 1 ;;
esac

# MoE CPU offload — default 0 (full GPU) on the 5090: the ~21.3GB weights + Q8 KV + compute
# fit in 32GB and every expert runs on-GPU (the gfx1031 12GB box used --n-cpu-moe 28, which
# capped decode at ~31 t/s). ESCAPE HATCH: weights alone are 21.3GB, so if a busy desktop /
# game + the always-on dictation server (:8083, ~4.4GB) + Whisper leave <~24GB free, the
# full-GPU load OOMs. Set NCPUMOE=8..16 to stream that many expert layers off CPU RAM and
# load anyway (slower). 0 = the fast path this migration is built around.
NCPUMOE="${NCPUMOE:-0}"
#
# --- Notes on the flags below (kept OUT of the exec block on purpose: an inline comment
#     inside a backslash-continued command truncates it — the previous revision silently
#     dropped every flag after --ubatch-size, i.e. threads/sampling/MTP/metrics) ---
#
# batch-size 2048 (default): the 3072 bump was a CPU+GPU MoE optimization (fewer CPU→GPU
#   expert-transfer rounds) — pointless now that all experts are GPU-resident, and the
#   compute buffer scales with batch-size. 2048 trims ~1GB of compute VRAM so the 24GB model
#   can co-exist with the always-on dictation server (:8083, ~4.4GB) inside 32GB.
#
# ngram-map-k4v removed 2026-05-21: caused a vector OOB crash when slot context was
#   rewound across an opencode session boundary (idle + new conversation). In live logs
#   it gave only ~21% of accepted tokens (388/1822) vs MTP's 79% — not worth the
#   instability. MTP self-spec (draft-mtp) alone carries the bulk of the spec speedup.
exec -a "qwen3.6-a3b@${PORT}.llama-server" llama-server \
  --model "$MODEL" \
  --alias "qwen3.6-35b-a3b-apex" \
  --chat-template-file "$TEMPLATE" \
  --host 127.0.0.1 --port "$PORT" \
  --device CUDA0 \
  --fit off \
  --n-gpu-layers 99 \
  --n-cpu-moe "$NCPUMOE" \
  --ctx-size "$CTX" \
  --keep -1 \
  --cache-reuse 256 \
  --slot-save-path "$SLOTS_DIR" \
  --slot-prompt-similarity 0.5 \
  --flash-attn on \
  --cache-type-k q8_0 \
  --cache-type-v q8_0 \
  --batch-size 2048 \
  --ubatch-size 512 \
  --threads 8 \
  --threads-batch 8 \
  --parallel 1 \
  --no-mmap \
  --temp "$TEMP" \
  --top-p "$TOPP" \
  --top-k 20 \
  --min-p 0.0 \
  --presence-penalty "$PRES" \
  --repeat-penalty 1.0 \
  --jinja \
  --reasoning "$REASON" \
  --chat-template-kwargs "{\"preserve_thinking\":$PRESERVE}" \
  --spec-type draft-mtp \
    --spec-draft-n-max 2 \
    --spec-draft-p-min 0.0 \
  --metrics
