# ~/.bashrc — minimal, since zsh is the daily driver
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
PS1='[\u@\h \W]\$ '
export EDITOR=nvim

# mise (replaces pyenv/nvm/conda)
command -v mise &>/dev/null && eval "$(mise activate bash)"

# Secrets (gitignored)
[[ -f ~/.secrets ]] && source ~/.secrets
