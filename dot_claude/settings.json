{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 9999,
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "permissions": {
    "allow": [
      "Read(~/Programming/**)",
      "Read(~/.local/share/chezmoi/**)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(jq:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm tsc:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm lint:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo clippy:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git stash list:*)",
      "Bash(rtk proxy git diff:*)",
      "Bash(rtk proxy git apply:*)",
      "Bash(rtk proxy git format-patch:*)",
      "Bash(chezmoi status:*)",
      "Bash(chezmoi diff:*)",
      "Bash(chezmoi managed:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./server/.env)",
      "Read(./server/.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/id_*)",
      "Read(~/.aws/credentials)",
      "Read(~/.config/gh/hosts.yml)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/deny-secrets.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bunx cc-safety-net@0.9.0 --claude-code"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|NotebookEdit|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/deny-secrets.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/attention.sh set"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/attention.sh clear"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/attention.sh clear"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowAllUnixSockets": true
    },
    "filesystem": {
      "allowWrite": [
        "~/.config/mise",
        "~/.cache/mise",
        "~/.local/share/mise",
        "~/Programming",
        "/run/user/1000/gnupg",
        "~/.gnupg"
      ],
      "allowRead": [
        "~/Programming"
      ]
    }
  },
  "effortLevel": "high",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true,
  "additionalDirectories": [
    "~/Programming",
    "~/.cargo"
  ]
}
