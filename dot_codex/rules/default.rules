prefix_rule(pattern=["node", "-e", "const { chromium } = require('playwright'); (async () => { const pageErrors=[]; const consoleErrors=[]; const browser=await chromium.launch({headless:true}); const page=await browser.newPage({viewport:{width:1440,height:1000}}); page.on('pageerror', e => pageErrors.push(String(e))); page.on('console', msg => { if (msg.type()==='error') consoleErrors.push(msg.text()); }); await page.goto('http://127.0.0.1:5174/', {waitUntil:'domcontentloaded'}); await page.waitForSelector('.category-overlay-title', {timeout:30000}); await page.waitForSelector('.category-overlay-item', {timeout:30000}); await page.waitForTimeout(1500); const data = await page.evaluate(() => { const title = document.querySelector('.category-overlay-title')?.textContent?.trim() ?? null; const topicTitle = Array.from(document.querySelectorAll('.category-overlay-title')).some((n) => n.textContent?.trim() === 'Topics'); const buttons = Array.from(document.querySelectorAll('.category-overlay-item')).slice(0, 24).map((b) => ({ text: b.textContent?.replace(/\\s+/g, ' ').trim() ?? '', category: b.getAttribute('data-category'), topic: b.getAttribute('data-topic') })); const grid = document.querySelector('.icon-grid-scroll'); const cards = Array.from(document.querySelectorAll('[data-grid-item=true]')).slice(0, 8).map((n) => n.textContent?.replace(/\\s+/g, ' ').trim() ?? ''); return { title, topicTitle, buttons, gridScrollTop: grid?.scrollTop ?? null, cards }; }); const target = page.locator('.category-overlay-item').filter({ hasText: 'Maps & Travel' }).first(); const before = await page.locator('.icon-grid-scroll').evaluate((el) => el.scrollTop); await target.click(); await page.waitForTimeout(800); const after = await page.locator('.icon-grid-scroll').evaluate((el) => el.scrollTop); const active = await page.locator('.category-overlay-item.active').first().textContent().catch(() => null); console.log(JSON.stringify({ data, scrollMoved: after !== before, before, after, active: active?.replace(/\\s+/g,' ').trim() ?? null, pageErrors, consoleErrors: consoleErrors.slice(0,5) }, null, 2)); await browser.close(); })().catch((e) => { console.error(e); process.exit(1); });"], decision="allow")
prefix_rule(pattern=["node", "-e", "const { chromium } = require('playwright'); (async () => { const browser=await chromium.launch({headless:true}); const page=await browser.newPage({viewport:{width:1440,height:1000}}); const consoleMessages=[]; page.on('console', msg => consoleMessages.push({type:msg.type(), text:msg.text()})); page.on('pageerror', e => consoleMessages.push({type:'pageerror', text:String(e)})); await page.goto('http://127.0.0.1:5174/', {waitUntil:'domcontentloaded'}); await page.waitForTimeout(5000); const data=await page.evaluate(() => ({ title: document.title, bodyText: document.body.innerText.slice(0,2000), categoryTitle: document.querySelector('.category-overlay-title')?.textContent?.trim() ?? null, categoryCount: document.querySelectorAll('.category-overlay-item').length, gridCount: document.querySelectorAll('.icon-grid-scroll').length, mainHtml: document.querySelector('main')?.outerHTML.slice(0,2000) ?? null, classes: Array.from(document.querySelectorAll('[class]')).slice(0,80).map(n => n.getAttribute('class')) })); console.log(JSON.stringify({data, consoleMessages: consoleMessages.slice(-20)}, null, 2)); await browser.close(); })().catch(e=>{ console.error(e); process.exit(1); });"], decision="allow")
