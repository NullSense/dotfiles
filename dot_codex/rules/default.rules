lay:rect('.category-overlay'), categoryCollapsed:document.querySelector('.category-overlay')?.classList.contains('collapsed') ?? null }; }); await page.close(); return { viewport, before, after, errors }; } const desktop=await probe({width:1440,height:1000}); const mobile=await probe({width:390,height:844}); console.log(JSON.stringify({desktop,mobile}, null, 2)); await browser.close(); })().catch(e=>{ console.error(e); process.exit(1); });"], decision="allow")
