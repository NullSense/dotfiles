prefix_rule(pattern=["node", "-e", "const { chromium } = require('playwright'); (async () => { const browser=await chromium.launch({headless:true}); async function probe(viewport){ const page=await browser.newPage({viewport}); const errors=[]; page.on('pageerror', e => errors.push(String(e))); page.on('console', msg => { if (msg.type()==='error') errors.push(msg.text()); }); await page.goto('http://127.0.0.1:5175/', {waitUntil:'domcontentloaded'}); await page.waitForSelector('.icon-grid-scroll', {timeout:45000, state:'attached'}); await page.waitForSelector('.category-overlay', {timeout:45000, state:'attached'}); await page.waitForTimeout(6000); const before=await page.evaluate(() => { const rect = (sel) => { const el=document.querySelector(sel); if(!el) return null; const r=el.getBoundingClientRect(); return {x:r.x,y:r.y,w:r.width,h:r.height}; }; return { title:document.querySelector('.category-overlay-title')?.textContent?.trim() ?? null, categoryClass:document.querySelector('.category-overlay')?.className ?? null, sideSlot:rect('.side-slot'), sideRail:rect('.side-slot-rail'), rightOverlay:rect('.category-overlay'), rightContent:rect('.category-overlay-content'), grid:rect('.icon-grid-scroll'), firstCards:Array.from(document.querySelectorAll('[data-grid-item=true]')).slice(0,20).map(n=>({id:n.getAttribute('data-entry-id'), text:n.textContent?.replace(/\\s+/g,' ').trim()})) }; }); let after=null; if (viewport.width >= 900) { await page.locator('.side-slot-rail').click({timeout:10000}); await page.waitForTimeout(500); await page.locator('[data-grid-item=true]').first().click({timeout:10000}); await page.waitForTimeout(1000); after=await page.evaluate(() => { const rect = (sel) => { const el=document.querySelector(sel); if(!el) return null; const r=el.getBoundingClientRect(); return {x:r.x,y:r.y,w:r.width,h:r.height}; }; return { sideSlot:rect('.side-slot'), detailPanel:rect('.detail-panel'), detailTags:Array.from(document.querySelectorAll('.detail-tags .tag')).slice(0,12).map(n=>n.textContent?.trim()), detailTopic:document.querySelector('.detail-topic')?.textContent?.replace(/\\s+/g,' ').trim() ?? null }; }); } await page.close(); return { viewport, before, after, errors }; } const desktop=await probe({width:1440,height:1000}); const mobile=await probe({width:390,height:844}); console.log(JSON.stringify({desktop,mobile}, null, 2)); await browser.close(); })().catch(e=>{ console.error(e); process.exit(1); });"], decision="allow")
prefix_rule(pattern=["node", "-e", "const { chromium } = require('playwright'); (async () => { const browser=await chromium.launch({headless:true}); async function probe(viewport){ const page=await browser.newPage({viewport}); const errors=[]; page.on('pageerror', e => errors.push(String(e))); page.on('console', msg => { if (msg.type()==='error') errors.push(msg.text()); }); await page.goto('http://127.0.0.1:5175/', {waitUntil:'domcontentloaded'}); await page.waitForTimeout(7000); const before=await page.evaluate(() => { const rect = (sel) => { const el=document.querySelector(sel); if(!el) return null; const r=el.getBoundingClientRect(); return {x:r.x,y:r.y,w:r.width,h:r.height}; }; return { title:document.querySelector('.category-overlay-title')?.textContent?.trim() ?? null, categoryClass:document.querySelector('.category-overlay')?.className ?? null, sideRailCount:document.querySelectorAll('.side-slot-rail').length, cardCount:document.querySelectorAll('[data-grid-item=true]').length, sideSlot:rect('.side-slot'), sideRail:rect('.side-slot-rail'), rightOverlay:rect('.category-overlay'), rightContent:rect('.category-overlay-content'), grid:rect('.icon-grid-scroll'), firstCards:Array.from(document.querySelectorAll('[data-grid-item=true]')).slice(0,20).map(n=>({id:n.getAttribute('data-entry-id'), text:n.textContent?.replace(/\\s+/g,' ').trim()})) }; }); let after=null; if (viewport.width >= 900) { await page.evaluate(() => document.querySelector('.side-slot-rail')?.dispatchEvent(new MouseEvent('click',{bubbles:true}))); await page.waitForTimeout(500); await page.evaluate(() => document.querySelector('[data-grid-item=true]')?.dispatchEvent(new MouseEvent('click',{bubbles:true}))); await page.waitForTimeout(1000); after=await page.evaluate(() => { const rect = (sel) => { const el=document.querySelector(sel); if(!el) return null; const r=el.getBoundingClientRect(); return {x:r.x,y:r.y,w:r.width,h:r.height}; }; return { sideSlot:rect('.side-slot'), detailPanel:rect('.detail-panel'), detailTags:Array.from(document.querySelectorAll('.detail-tags .tag')).slice(0,12).map(n=>n.textContent?.trim()), detailTopic:document.querySelector('.detail-topic')?.textContent?.replace(/\\s+/g,' ').trim() ?? null }; }); } await page.close(); return { viewport, before, after, errors }; } const desktop=await probe({width:1440,height:1000}); const mobile=await probe({width:390,height:844}); console.log(JSON.stringify({desktop,mobile}, null, 2)); await browser.close(); })().catch(e=>{ console.error(e); process.exit(1); });"], decision="allow")
prefix_rule(pattern=["pnpm", "exec", "tsx", "-e", "import fs from 'node:fs'; import path from 'node:path'; import { classifyIconCategory } from './src/lib/icon-categories.ts'; const ids=[['carbon','align-box--bottom-left'],['carbon','align--horizontal-left'],['fontawesome','angle-left'],['lucide','arrow-left'],['carbon','aggregator--recalculation']]; for (const [cid,id] of ids) { const m=JSON.parse(fs.readFileSync(path.join('public/corpora',cid,'manifest.json'),'utf8')); const entries=JSON.parse(fs.readFileSync(path.join('public/corpora',cid,m.assets.entries.replace(/^\\\\.\\\\//,'')),'utf8')); const e=entries.find((x:any)=>x.id===id); const r=classifyIconCategory(e); console.log(cid,id,r.primaryCategory,r.primarySubcategory,r.categoryConfidence,r.categoryEvidence); }"], decision="allow")
prefix_rule(pattern=["node", "-e", "const { chromium } = require('playwright'); (async () => { const browser=await chromium.launch({headless:true}); async function probe(viewport){ const page=await browser.newPage({viewport}); const errors=[]; page.on('pageerror', e => errors.push(String(e))); page.on('console', msg => { if (msg.type()==='error') errors.push(msg.text()); }); await page.goto('http://127.0.0.1:5175/', {waitUntil:'domcontentloaded'}); await page.waitForTimeout(7000); const before=await page.evaluate(() => { const rect = (sel) => { const el=document.querySelector(sel); if(!el) return null; const r=el.getBoundingClientRect(); return {x:r.x,y:r.y,w:r.width,h:r.height}; }; return { categoryClass:document.querySelector('.category-overlay')?.className ?? null, sideSlot:rect('.side-slot'), sideRail:rect('.side-slot-rail'), rightOverlay:rect('.category-overlay'), rightContent:rect('.category-overlay-content'), grid:rect('.icon-grid-scroll'), firstCards:Array.from(document.querySelectorAll('[data-grid-item=true]')).slice(0,20).map(n=>({id:n.getAttribute('data-entry-id'), text:n.textContent?.replace(/\\s+/g,' ').trim()})) }; }); let after=null; if (viewport.width >= 900) { await page.evaluate(() => document.querySelector('.side-slot-rail')?.dispatchEvent(new MouseEvent('click',{bubbles:true}))); await page.waitForTimeout(500); await page.evaluate(() => document.querySelector('[data-grid-item=true]')?.dispatchEvent(new MouseEvent('click',{bubbles:true}))); await page.waitForTimeout(1000); after=await page.evaluate(() => ({ detailTags:Array.from(document.querySelectorAll('.detail-tags .tag')).slice(0,12).map(n=>n.textContent?.trim()), hasDetailTopic:!!document.querySelector('.detail-topic'), detailText:document.querySelector('.detail-panel')?.textContent?.replace(/\\s+/g,' ').trim().slice(0,500) ?? null })); } await page.close(); return { viewport, before, after, errors }; } const desktop=await probe({width:1440,height:1000}); const mobile=await probe({width:390,height:844}); console.log(JSON.stringify({desktop,mobile}, null, 2)); await browser.close(); })().catch(e=>{ console.error(e); process.exit(1); });"], decision="allow")
prefix_rule(pattern=["pnpm", "index"], decision="allow")
prefix_rule(pattern=["pnpm", "tsx"], decision="allow")
