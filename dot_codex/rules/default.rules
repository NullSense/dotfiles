 !== before, before, after, active: active?.replace(/\\s+/g,' ').trim() ?? null, pageErrors, consoleErrors: consoleErrors.slice(0,5) }, null, 2)); await browser.close(); })().catch((e) => { console.error(e); process.exit(1); });"], decision="allow")
prefix_rule(pattern=["pnpm", "exec", "tsx", "-e", "import fs from 'node:fs'; import path from 'node:path'; import { classifyIconCategory } from './src/lib/icon-categories.ts'; const ids=[['fontawesome','3'],['bootstrap','3-circle-fill'],['fontawesome','9'],['bootstrap','9-circle'],['lucide','arrow-down'],['lucide','map-pin']]; for (const [cid,id] of ids) { const m=JSON.parse(fs.readFileSync(path.join('public/corpora',cid,'manifest.json'),'utf8')); const entries=JSON.parse(fs.readFileSync(path.join('public/corpora',cid,m.assets.entries.replace(/^\\\\.\\\\//,'')),'utf8')); const e=entries.find((x:any)=>x.id===id); console.log(cid,id, classifyIconCategory(e)); }"], decision="allow")
