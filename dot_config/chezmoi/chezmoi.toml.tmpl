[edit]
    command = "nvim"
    # Apply to the live target automatically when the editor exits, so
    # `chezmoi edit <file>` never leaves source and target out of sync.
    # For live-tuning loops use `chezmoi edit --watch <file>` (applies on
    # every save). Revert an unwanted edit with `git checkout` in the source.
    apply = true
[diff]
    command = "delta"
[data]
    user = "nullsense"

# Auto-commit (local) for chezmoi-driven source changes; push is MANUAL.
#
# autoCommit triggers ONLY when chezmoi itself modifies the source dir:
#   • chezmoi add / re-add / forget / destroy / edit <path>
# It does NOT trigger when you edit files under ~/.local/share/chezmoi/
# directly with $EDITOR — commit those with `chezmoi git -- commit -am ...`.
#
# autoPush is OFF (2026-07-14). Repo github.com/NullSense/dotfiles is PUBLIC,
# so instant-push-on-every-action exposed work publicly the moment any chezmoi
# command ran, and bundled unrelated drift into surprise commits. Local commits
# keep work safe in git; publishing is now a deliberate `chezmoi git -- push`.
# `private_*` is a permission marker only — NOT encryption; treat pushes as
# immediately public.
[git]
    autoCommit = true
    autoPush = false
