# Ghostty — colors flip via omarchy theme; everything else is set here.
#
# `?` makes the include optional so a fresh checkout (no theme rendered yet)
# doesn't error on first launch.
config-file = ?~/.config/omarchy/current/theme/ghostty.conf

font-family = "Hack Nerd Font Mono"
font-size = 10

# Ghostty 1.3+ defaults `grapheme-width-method = unicode`, which computes
# grapheme cluster widths via the Unicode standard. TUIs like Claude Code
# still calculate widths via legacy `wcswidth`, so glyphs that the two sides
# disagree on (Nerd-Font icons, `⏺ ✻ ✽` spinner glyphs, `·`, `↓`, U+2500 box
# rules) progressively desync the cursor — visible as duplicated status bars,
# mid-word breaks ("Pl ywright"), and a stray single-character column on the
# right edge. `legacy` aligns Ghostty with the TUI's width model. The Ghostty
# docs explicitly call this out as the fix for cursor-desync with programs
# using wcswidth. Programs that opt into terminal mode 2027 still get exact
# Unicode widths regardless of this setting, so it costs nothing for modern
# apps and rescues legacy ones.
grapheme-width-method = legacy

window-padding-x = 10
window-padding-y = 10
window-decoration = false

cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true
unfocused-split-opacity = 0.85

clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true

scrollback-limit = 10000000
copy-on-select = true

shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Single-instance dispatches `ghostty` CLI calls as new-window messages to
# the running primary, which would lose any --class / --font-family on the
# child window. Off → each invocation is an independent process honoring
# its CLI flags (cost: ~150ms slower startup per window).
gtk-single-instance = false

confirm-close-surface = false
quit-after-last-window-closed = true

# Hack Nerd Font Mono has excellent native TrueType hints; respect them
# instead of letting ghostty 1.3+ default to the FreeType autohinter, which
# is measurably softer for well-hinted monospaces. `hinting` re-enables full
# native hinting; the rest (no-force-autohint, no-autohint, light) became
# defaults in 1.3, but pinning `hinting` is forwards-safe.
freetype-load-flags = hinting
