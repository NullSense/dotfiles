# kanshi: dynamic monitor profiles for sway.
# Profiles are matched top-to-bottom; the first one whose listed outputs are
# all connected wins. The final fallback profile has no `output` matchers
# (only wildcards) so it always matches when nothing else does.
#
# Find your displays' make/model/serial with:
#   swaymsg -t get_outputs | jq '.[] | {name, make, model, serial}'
#
# Then write profiles using the criteria string "make model serial".
# Empty fields become "Unknown" (note the literal capital U).

# ---------- DESKTOP: AORUS OLED + MSI MAG274QRF-QD ----------
# AORUS at 0,0 with 1.5x scale (handles OLED HiDPI), MSI to the right.
# Update make/model/serial after first boot via swaymsg -t get_outputs.
profile desktop-dual {
    output "GIGA-BYTE TECHNOLOGY CO. LTD. AORUS FO27Q3 *" mode 2560x1440 position 0,0 scale 1.5 adaptive_sync off
    output "MSI MAG274QRF-QD *"                          mode 2560x1440@165Hz position 1707,0 adaptive_sync off
}

# ---------- DESKTOP: single MSI only (AORUS off / unplugged) ----------
profile desktop-msi-only {
    output "MSI MAG274QRF-QD *" mode 2560x1440@165Hz position 0,0 adaptive_sync off
}

# ---------- DESKTOP: single AORUS only ----------
profile desktop-aorus-only {
    output "GIGA-BYTE TECHNOLOGY CO. LTD. AORUS FO27Q3 *" mode 2560x1440 position 0,0 scale 1.5
}

# ---------- LAPTOP: docked (built-in panel + external) ----------
# Replace eDP-1 + external criteria when used on a laptop.
# profile laptop-docked {
#     output eDP-1 disable
#     output "Dell Inc. DELL U2723QE *" mode 3840x2160 position 0,0 scale 1.5
# }

# ---------- LAPTOP: undocked ----------
# profile laptop-mobile {
#     output eDP-1 enable scale 1.5
# }

# ---------- FALLBACK: enable every connected output at native mode ----------
# Matches when none of the above profiles do. Sway's defaults handle layout.
profile fallback {
    output "*" enable
}
