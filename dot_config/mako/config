# mako — Wayland-native notification daemon, replaces dunst.
#
# Layered config:
#   1. omarchy's core.ini (anchor, timeouts, app-name rules, summary
#      hooks for Setup Wi-Fi / Update System / Screenshot copied)
#   2. theme colors (text/border/background, regenerated by
#      omarchy-theme-set from default/themed/mako.ini.tpl)
#   3. our overrides at the bottom (font choice, anchor tweaks if needed)
#
# Reload after edits: makoctl reload

include=~/.local/share/omarchy/default/mako/core.ini
include=~/.config/omarchy/current/theme/mako.ini

# Override: omarchy ships sans-serif 14px; we run Hack Nerd Font Mono
# everywhere else and want consistency. 11px is a touch denser than
# omarchy's default so longer notification bodies fit in 420px width.
font=Hack Nerd Font Mono 11
