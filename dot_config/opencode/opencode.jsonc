{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "env",
        "-u",
        "HTTPS_PROXY",
        "-u",
        "HTTP_PROXY",
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--executable-path",
        "/usr/bin/chromium",
        "--headless"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "env",
        "-u",
        "HTTPS_PROXY",
        "-u",
        "HTTP_PROXY",
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "react-grab-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@react-grab/mcp",
        "--stdio"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ]
}
