{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/local-model-rules.md"
  ],
  "provider": {
    "llama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (Qwen3.6-35B-A3B APEX-MTP local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "sk-local"
      },
      "models": {
        "qwen3.6-35b-a3b-apex": {
          "name": "Qwen3.6 35B-A3B APEX-MTP (local)",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "env",
        "-u",
        "HTTPS_PROXY",
        "-u",
        "HTTP_PROXY",
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--executable-path",
        "/usr/bin/chromium",
        "--headless"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "env",
        "-u",
        "HTTPS_PROXY",
        "-u",
        "HTTP_PROXY",
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "react-grab-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@react-grab/mcp",
        "--stdio"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ]
}
