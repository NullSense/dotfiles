[Unit]
Description=Event-driven sudo flag watcher → waybar pill signaller
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/sudo-pill-daemon
Restart=always
RestartSec=2
# Light touch on the system; this is a single bash + a couple of
# transient inotifywait/tail subprocesses.
Nice=10
IOSchedulingClass=idle

[Install]
WantedBy=graphical-session.target
