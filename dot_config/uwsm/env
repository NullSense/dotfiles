# uwsm — environment variables exported into every process the user's
# graphical session spawns (waybar, hyprlock, exec-once apps, walker,
# etc.). Sourced shell-style at session start. Format: `export KEY=VAL`.
#
# Why this file exists:
#   The bare systemd-user PATH is tiny (/usr/local/sbin:/usr/local/bin:/usr
#   /bin:...). Interactive shells fatten it via zshrc/zinit/mise, but
#   non-interactive children (uwsm `exec-once`, systemd user units like
#   waybar.service) inherit only the slim systemd PATH. Without these lines
#   helium / wl-gammarelay-rs / omarchy-hyprland-monitor-watch fail to
#   resolve at boot with "Command not found", even though the binaries
#   exist on disk.
#
# Putting PATH here (not in environment.d) keeps the slimmer Wayland-related
# overrides separate from the heavier shell PATH, and confines the addition
# to the graphical session only — Xorg/login sessions are unaffected.

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/.local/share/omarchy/bin:$HOME/bin:$HOME/.bun/bin:$HOME/.local/share/pnpm:$PATH"

# OMARCHY_PATH is NOT defined here on purpose — `uwsm aux prepare-env` is a
# Type=oneshot that runs once at session start. wayland-wm-app-daemon.service
# (gateway for `uwsm app --` → elephant → omarchy-theme-set) snapshots its
# env at that moment, so after-the-fact edits don't propagate to running
# services until next login. OMARCHY_PATH lives in
# ~/.config/environment.d/omarchy.conf instead, which systemd --user reads at
# user-manager startup AND exports to D-Bus, reaching every spawn path.
