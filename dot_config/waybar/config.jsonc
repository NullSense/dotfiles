// Waybar — canonical fat config (status-first ordering).
//
// Single config file (not config-hypr or any split) — this matches omarchy's
// expected layout. Modules are inlined here, not include'd from sidecar files,
// so config diffs/upstream merges have one place to land.
{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 0,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
        "custom/workspaces",
        "hyprland/window",
        "custom/media",
        "hyprland/submap"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/agents",
        "custom/sudo",
        "custom/aiquota",
        "custom/hyprwhspr",
        "custom/xt3-status",
        "custom/notifications",
        "idle_inhibitor",
        "custom/llamaswap",
        "custom/gpu",
        "custom/memory",
        "group/storage",
        "group/display",
        "pulseaudio",
        "battery#mouse",
        "tray"
    ],
    "group/display": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "children-class": "disp-child",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/brightness",
            "custom/colortemp"
        ]
    },
    // Storage drawer — the ~ pill is the always-visible handle; hovering
    // slides the / pill in. Both fixed to the same physical filesystem here,
    // so the % matches; the value is each pill's tooltip, which ranks the
    // largest directories under that path (computed off the hot path — see
    // disk-usage.sh). This is the ONLY hover-to-expand group on the right now
    // (display is the other); GPU + RAM sit inline, always visible.
    "group/storage": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "children-class": "storage-child",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/disk-home",
            "custom/disk-root"
        ]
    },
    "custom/gpu": {
        // VRAM used/total (RTX 5090). Tooltip ranks the top VRAM consumers
        // with REAL names — a bare "python" is resolved to the script it runs
        // (e.g. the hyprwhspr dictation model), which is exactly what a raw
        // process monitor can't tell you.
        "exec": "$HOME/.config/waybar/gpu-status.sh",
        "return-type": "json",
        "interval": 5,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "markup": "pango",
        "on-click": "$HOME/.config/waybar/gpu-status.sh nvtop",
        "on-click-right": "$HOME/.config/waybar/gpu-status.sh smi"
    },
    "custom/memory": {
        // RAM used/total in G, with a swap segment that only appears when swap
        // is actually in use (zram-only box → usually hidden). Replaces the
        // built-in `memory` module so swap can be conditional and the tooltip
        // can rank top-RSS processes.
        "exec": "$HOME/.config/waybar/mem-status.sh",
        "return-type": "json",
        "interval": 5,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "markup": "pango",
        "on-click": "$HOME/.config/waybar/mem-status.sh btop"
    },
    "custom/llamaswap": {
        // What the local LLM server (llama-swap :9292) currently has resident.
        // Collapses out of the bar when the server is down. Click → web UI.
        "exec": "$HOME/.config/waybar/llamaswap-status.sh",
        "return-type": "json",
        "interval": 5,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "markup": "pango",
        "on-click": "$HOME/.config/waybar/llamaswap-status.sh ui"
    },
    "custom/disk-home": {
        "exec": "$HOME/.config/waybar/disk-usage.sh pill $HOME home 󰋜",
        "return-type": "json",
        "interval": 30,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "markup": "pango",
        "on-click": "$HOME/.config/waybar/disk-usage.sh ncdu $HOME",
        "on-click-right": "$HOME/.config/waybar/disk-usage.sh refresh $HOME home"
    },
    "custom/disk-root": {
        "exec": "$HOME/.config/waybar/disk-usage.sh pill / root 󰋊",
        "return-type": "json",
        "interval": 30,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "markup": "pango",
        "on-click": "$HOME/.config/waybar/disk-usage.sh ncdu /",
        "on-click-right": "$HOME/.config/waybar/disk-usage.sh refresh / root"
    },
    "custom/workspaces": {
        // Replaces `hyprland/workspaces` so each digit can be Pango-colored
        // dynamically: per-agent brand color when an attention tag is set,
        // gruvbox @yellow when the user is on it, @aqua for active-on-other-
        // monitor, @fg3 for occupied, @bg4 for empty/persistent. waybar's
        // built-in module can't do this — `format-icons` is static config.
        // Trade-off: lost per-button click-to-switch. Compensated by:
        //   left-click  = workspace e+1     middle-click = focus attention
        //   right-click = workspace e-1     scroll       = step ±1
        // Direct selection still works via Super+1..6 (Hyprland keybinds).
        // Refresh is signal-driven via SIGRTMIN+8 — fired by
        // `hypr-waybar-bridge.service` on workspace/window/urgent events
        // and by Claude Code hooks on attention-tag changes.
        "exec": "$HOME/.config/waybar/workspaces-pill.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 8,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "markup": "pango",
        "on-click": "$HOME/.config/waybar/workspaces-pill.sh next",
        "on-click-right": "$HOME/.config/waybar/workspaces-pill.sh prev",
        "on-click-middle": "$HOME/.config/waybar/workspaces-pill.sh focus-attention",
        "on-scroll-up": "$HOME/.config/waybar/workspaces-pill.sh next",
        "on-scroll-down": "$HOME/.config/waybar/workspaces-pill.sh prev"
    },
    "hyprland/window": {
        "format": "{title}",
        "max-length": 80,
        "separate-outputs": true,
        "escape": false,
        "markup": "pango",
        "rewrite": {
            "^.\\[claude\\] (.*)$":   "<span foreground='#D97757' face='Font Awesome 7 Brands'></span>  $1",
            "^.\\[codex\\] (.*)$":    "<span foreground='#10A37F' face='Font Awesome 7 Brands'></span>  $1",
            "^.\\[opencode\\] (.*)$": "<span foreground='#FF5C00'>󰂩</span>  $1",
            "^.\\[gemini\\] (.*)$":   "<span foreground='#8E75B2'>󰲾</span>  $1",
            "^.\\[copilot\\] (.*)$":  "<span foreground='#6E5494' face='Font Awesome 7 Brands'></span>  $1",
            "^.\\[sudo\\] (.*)$":     "<span foreground='#F0C674'>󰄔</span>  $1",
            "(.*) — Mozilla Firefox":     "🦊  $1",
            "(.*) - Visual Studio Code":  "  $1",
            "(.*) - Alacritty":             "  $1",
            "(.*) - Foot":                "  $1"
        }
    },
    "hyprland/submap": {
        "format": "   {}",
        "tooltip": false
    },
    "clock": {
        "format": "{:%a  %H:%M}",
        "format-alt": "{:%a %d %b · W%V %Y}",
        "tooltip-format": "<big>{:%A, %d %B %Y\n%H:%M:%S}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#fabd2f'><b>{}</b></span>",
                "days": "<span color='#ebdbb2'>{}</span>",
                "weeks": "<span color='#8ec07c'><b>W{}</b></span>",
                "weekdays": "<span color='#83a598'><b>{}</b></span>",
                "today": "<span color='#fb4934'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "custom/aiquota": {
        // Wrapped via aiquota-wrap.sh so any failure (binary missing, timeout,
        // panic, non-JSON output) surfaces as a "⚠ aiquota" pill with the
        // error in the tooltip — instead of waybar silently dropping the
        // module (which is what happens when exec fails or prints garbage).
        "exec": "$HOME/.config/waybar/aiquota-wrap.sh",
        "return-type": "json",
        "interval": 30,
        "signal": 9,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "markup": "pango",
        // Clicks go through the wrapper too, so the binary path lives in ONE
        // place (aiquota-wrap.sh) — this config never names it directly.
        "on-click": "$HOME/.config/waybar/aiquota-wrap.sh cycle",
        "on-click-right": "xdg-terminal-exec $HOME/.config/waybar/aiquota-wrap.sh tui"
    },
    "custom/agents": {
        "exec": "$HOME/.config/waybar/agent-attention.sh",
        "return-type": "json",
        "interval": 5,
        "signal": 8,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "markup": "pango",
        "on-click": "$HOME/.config/waybar/agent-attention.sh focus",
        "on-click-right": "$HOME/.config/waybar/agent-attention.sh dismiss-all"
    },
    "custom/sudo": {
        "exec": "$HOME/.config/waybar/sudo-indicator.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 10,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "markup": "pango",
        "on-click": "$HOME/.config/waybar/sudo-indicator.sh focus"
    },
    "custom/hyprwhspr": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/hyprwhspr-rewrite-wrap.sh",
        "interval": 1,
        "signal": 12,
        "return-type": "json",
        "exec-on-event": true,
        // L = record · R = restart STT service · M = toggle the rewrite pass
        // (on/off, unloads the rewrite model's VRAM when off). The pill's
        // tooltip carries live rewrite health; a genuine backend failure also
        // fires a rate-limited desktop notification.
        "on-click": "/usr/lib/hyprwhspr/config/hyprland/hyprwhspr-tray.sh record",
        "on-click-right": "/usr/lib/hyprwhspr/config/hyprland/hyprwhspr-tray.sh restart",
        "on-click-middle": "$HOME/.config/waybar/hyprwhspr-rewrite-ctl.sh toggle",
        "tooltip": true
    },
    "custom/xt3-status": {
        "exec": "$HOME/.config/waybar/xt3-status.sh",
        "return-type": "json",
        "interval": 2,
        "signal": 8,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "markup": "pango",
        "on-click": "$HOME/.config/waybar/xt3-action.sh restart",
        "on-click-right": "$HOME/.config/waybar/xt3-action.sh stop",
        "on-click-middle": "$HOME/.config/waybar/xt3-action.sh status"
    },
    "custom/notifications": {
        // mako state pill: 󰂜 idle · 󰂚 pending/cinema · 󰂛 do-not-disturb.
        // Refresh is signal-driven (SIGRTMIN+11, fired by click actions and the
        // hypr-cinema-mode watcher on fullscreen) with a slow interval fallback
        // for pending-count freshness (mako has no change signal to subscribe).
        "exec": "$HOME/.config/waybar/notifications.sh",
        "return-type": "json",
        "interval": 10,
        "signal": 11,
        "format": "{}",
        "tooltip": true,
        "escape": false,
        "markup": "pango",
        "on-click": "sh -c 'makoctl mode -t do-not-disturb; pkill -SIGRTMIN+11 -u $(id -u) waybar'",
        "on-click-right": "sh -c 'makoctl dismiss -a; pkill -SIGRTMIN+11 -u $(id -u) waybar'",
        "on-click-middle": "sh -c 'makoctl restore; pkill -SIGRTMIN+11 -u $(id -u) waybar'"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "󰒳",
            "deactivated": "󰒲"
        },
        "tooltip-format-activated": "Idle inhibitor: ON  (display + sleep blocked)",
        "tooltip-format-deactivated": "Idle inhibitor: off"
    },
    "custom/brightness": {
        "format": "󰃠  {}%",
        "exec": "$HOME/bin/brightness-ctl get",
        "tooltip-format": "Display brightness (real backlight via DDC/CI — saves wattage)\n   scroll       ±5%   (clamped 0–100%)\n   left-click   100%\n   middle-click 30%   (low / night-friendly)\nNote: scroll updates the actual backlight, not just gamma.",
        "on-scroll-up": "$HOME/bin/brightness-ctl +5",
        "on-scroll-down": "$HOME/bin/brightness-ctl -5",
        "on-click": "$HOME/bin/brightness-ctl 100",
        "on-click-middle": "$HOME/bin/brightness-ctl 30",
        "interval": 5,
        "signal": 8
    },
    "custom/colortemp": {
        "format": "  {}",
        "exec": "wl-gammarelay-rs watch {t}K",
        "tooltip-format": "Color temperature  (synced across all monitors)\n   scroll      ±100K\n   left-click   6500K  day\n   right-click  4000K  warm\n   middle-click 6500K  +  reset brightness/gamma  (true-color / editing)",
        "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n +100",
        "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n -100",
        "on-click": "busctl --user set-property rs.wl-gammarelay / rs.wl.gammarelay Temperature q 6500",
        "on-click-right": "busctl --user set-property rs.wl-gammarelay / rs.wl.gammarelay Temperature q 4000",
        "on-click-middle": "$HOME/bin/color-neutral"
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "   {volume}%",
        "format-bluetooth-muted": "   muted",
        "format-muted": "   muted",
        "format-source": "   {volume}%",
        "format-source-muted": "  ",
        "format-icons": {
            "headphones": "  ",
            "handsfree": "  ",
            "headset": "  ",
            "phone": "  ",
            "portable": "  ",
            "car": "  ",
            "default": [
                "  ",
                "  ",
                "  "
            ]
        },
        "scroll-step": 2,
        "on-click": "pavucontrol",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "$HOME/bin/audio-cycle-sink",
        "tooltip-format": "Sink: {desc}\n  L-click  pavucontrol\n  R-click  cycle (headphones ↔ Aorus)\n  M-click  mute\n  scroll   ±2%"
    },
    "battery#mouse": {
        "bat": "hidpp_battery_0",
        "interval": 15,
        "format": "   {capacity}%",
        "format-charging": "   {capacity}%",
        "format-discharging": "   {capacity}%",
        "format-plugged": "   {capacity}%",
        "format-full": "   full",
        "format-not-charging": "   {capacity}%",
        "tooltip-format": "Logitech PRO X — {capacity}%  {time}\n  L-click  bluetoothctl info",
        "tooltip-format-charging": "Logitech PRO X — {capacity}% (charging )",
        "tooltip-format-full": "Logitech PRO X — fully charged",
        "tooltip-format-not-charging": "Logitech PRO X — {capacity}% (idle)",
        "states": {
            "warning": 25,
            "critical": 10
        },
        "on-click": "alacritty --class=com.local.floating-monitor -e sh -c 'upower -i $(upower -e | grep hidpp); echo; read -r _'"
    },
    "tray": {
        "spacing": 12,
        "icon-size": 16
    },
    "custom/media": {
        "format": "{icon} {text}",
        "return-type": "json",
        "max-length": 55,
        "format-icons": {
            "spotify": "  ",
            "default": "  "
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer-wrap.sh 2> /dev/null",
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-click-middle": "playerctl previous",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "tooltip": true,
        "tooltip-format": "{}\n  L-click   play / pause\n  R-click   next\n  M-click   previous\n  scroll    skip ±1"
    }
}
