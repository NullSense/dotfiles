#!/bin/sh
# trufflehog verifies if pattern-matched secrets are ACTUALLY live credentials
# scans the range being pushed; only fails on verified live secrets (low false positives)
# bypass with: git push --no-verify
#
# trufflehog reads pre-push hook stdin format: <local_ref> <local_sha> <remote_ref> <remote_sha>
# we extract the local_sha range and scan it

set -e
remote="$1"; url="$2"

# If trufflehog isn't installed, exit silently — gitleaks at commit time still applies
command -v trufflehog >/dev/null 2>&1 || exit 0

zero="0000000000000000000000000000000000000000"
found=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip deletes
  [ "$local_sha" = "$zero" ] && continue

  # New branch: scan only the new commits (not the entire history)
  if [ "$remote_sha" = "$zero" ]; then
    range="$local_sha"
  else
    range="${remote_sha}..${local_sha}"
  fi

  # --fail returns non-zero on findings; --results=verified filters to live creds only
  if ! trufflehog git "file://$(git rev-parse --show-toplevel)" \
      --since-commit="${remote_sha}" --branch="${local_sha}" \
      --results=verified --fail 2>&1; then
    found=1
  fi
done

if [ "$found" -ne 0 ]; then
  echo
  echo "✗ trufflehog found VERIFIED live credentials in commits being pushed." >&2
  echo "  Rotate the credentials, then either:" >&2
  echo "  - rewrite history to remove (git rebase -i / git filter-repo)" >&2
  echo "  - or push anyway: git push --no-verify (NOT RECOMMENDED)" >&2
  exit 1
fi

exit 0
