#!/usr/bin/env bash
# av-add-credential — register one Agent Vault credential without putting
# the value in shell history or scrollback.
#
# Usage:
#   av-add-credential <CREDENTIAL_NAME>           # prompts silently for value
#   av-add-credential <CREDENTIAL_NAME> --service # also adds a service mapping
#
# After running, the script reminds you to back up the value in Bitwarden as
# a secure note named  agent-vault-cred:<CREDENTIAL_NAME>  for disaster
# recovery. The local Agent Vault DB is the working store; Bitwarden is the
# canonical backup.

set -euo pipefail

VAULT="${AGENT_VAULT_DEFAULT:-default}"

usage() {
    cat <<EOF
Usage: av-add-credential <CREDENTIAL_NAME> [--vault <name>]

Reads the credential value silently from your terminal, then registers it
in Agent Vault. Does NOT add a service mapping — do that separately via
\`agent-vault vault service add\` or the web UI.

Examples:
    av-add-credential ANTHROPIC_API_KEY
    av-add-credential OPENAI_API_KEY --vault company

Defaults: --vault $VAULT  (override via AGENT_VAULT_DEFAULT env var)
EOF
}

[[ $# -eq 0 ]] && { usage >&2; exit 2; }

NAME=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        --vault) VAULT="$2"; shift 2 ;;
        -*) printf 'Unknown flag: %s\n' "$1" >&2; usage >&2; exit 2 ;;
        *) NAME="$1"; shift ;;
    esac
done

[[ -z "$NAME" ]] && { printf 'Error: credential name required.\n' >&2; usage >&2; exit 2; }

# Verify daemon is reachable before prompting
if ! curl -sf -o /dev/null http://127.0.0.1:14321/health; then
    printf 'Agent Vault daemon not reachable at http://127.0.0.1:14321/health\n' >&2
    printf 'Check: systemctl --user status agent-vault.service\n' >&2
    exit 1
fi

# Silent read — value never enters shell history or scrollback
printf 'Paste value for %s (input hidden, Enter to confirm): ' "$NAME" >&2
IFS= read -rs VALUE
printf '\n' >&2

if [[ -z "$VALUE" ]]; then
    printf 'Error: empty value, aborting.\n' >&2
    exit 1
fi

# Register
agent-vault vault credential set "$NAME=$VALUE" --vault "$VAULT" >/dev/null

# Wipe value from this shell
VALUE=""
unset VALUE

printf '\n✓ Registered %s in vault "%s"\n' "$NAME" "$VAULT"
printf '\nNext steps:\n'
printf '  1. Save the original value in Bitwarden as a Secure Note named:\n'
printf '       agent-vault-cred:%s\n' "$NAME"
printf '     (disaster-recovery copy; re-register if local DB is ever lost)\n'
printf '\n  2. If this is a new service, also add a service mapping:\n'
printf '       agent-vault vault service add --host <host> --auth-type <bearer|api-key|basic> ... --vault %s\n' "$VAULT"
printf '     See ~/dotfiles/arch-install/AGENT-VAULT.md for per-provider examples.\n'
