#!/bin/sh
# cliphist-secret-filter — content-based secret detection for clipboard storage.
#
# Pipeline: wl-paste --watch → (Wayland signal filter) → THIS → cliphist store
# If this script detects a secret-shaped payload it drops the entry and emits a
# critical notification via mako. Otherwise it forwards stdin to `cliphist store`.
#
# Defense-in-depth on top of the two Wayland signals already filtered upstream:
#   1. CLIPBOARD_STATE=sensitive
#   2. x-kde-passwordManagerHint MIME
# Those catch explicit password-manager copies. This catches commands like
# `echo $TOKEN | wl-copy` where no app-level signal is attached.

set -e

content="$(cat)"

# High-confidence secret patterns. Conservative — only patterns with a fixed
# prefix or unambiguous shape, to keep false positives near zero.
# All patterns on a single line: shell single-quoted strings treat backslash-
# newline as literal characters, which would break the regex with grep
# "Trailing backslash" errors. (Learned the hard way.)
patterns='AKIA[A-Z0-9]{16}|ASIA[A-Z0-9]{16}|ghp_[A-Za-z0-9]{36}|gho_[A-Za-z0-9]{36}|ghs_[A-Za-z0-9]{36}|ghu_[A-Za-z0-9]{36}|ghr_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{82}|glpat-[A-Za-z0-9_-]{20}|sk-ant-[A-Za-z0-9_-]{32,}|sk-proj-[A-Za-z0-9_-]{32,}|sk-[A-Za-z0-9]{48,}|sk_live_[A-Za-z0-9]{24,}|sk_test_[A-Za-z0-9]{24,}|pk_live_[A-Za-z0-9]{24,}|rk_live_[A-Za-z0-9]{24,}|xox[abprs]-[A-Za-z0-9-]{10,}|AIza[A-Za-z0-9_-]{35}|BEGIN (RSA|OPENSSH|EC|DSA|PGP|ENCRYPTED) PRIVATE KEY'

if printf '%s' "$content" | grep -qE "$patterns"; then
  # Sample of the matched line for the notification (redacted middle)
  detector="$(printf '%s' "$content" | grep -oE "$patterns" | head -n1 | sed 's/\(.\{6\}\).*\(.\{4\}\)/\1…\2/')"
  notify-send -u critical -t 6000 \
    "🚨 Secret blocked from clipboard history" \
    "Pattern: ${detector}\nNot stored in cliphist. Paste still works for this copy."
  exit 0
fi

# No match → store normally
printf '%s' "$content" | cliphist store
