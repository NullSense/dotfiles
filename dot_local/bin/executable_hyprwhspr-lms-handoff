#!/usr/bin/env bash
# hyprwhspr-lms-handoff — open content in LM Studio's GUI chat for follow-up.
#
# LM Studio has no programmatic chat-open API:
#   - `lms chat --prompt` is terminal-only, no GUI surfacing
#   - no `lmstudio://chat` URI handler exists (only `add_mcp` + `open_from_hf`)
#   - the `~/.lmstudio/conversations/*.conversation.json` files are Zod-
#     validated against an undocumented, version-bumped schema — hand-rolled
#     writes break on app updates
#   - the Python/JS SDKs are headless; the OpenAI REST API is stateless
#
# So we do the only reliable thing: copy content to the Wayland clipboard,
# focus LM Studio's window, synthesize Ctrl+V via ydotool. Works regardless
# of LM Studio version.
#
# Usage:
#   hyprwhspr-lms-handoff text  "<text>"
#   hyprwhspr-lms-handoff image <path>
#   hyprwhspr-lms-handoff both  <image_path> "<text>"
#
# For the `both` form: image is pasted first, then text in a second
# clipboard cycle — wl-clipboard holds only one MIME at a time, and LM
# Studio's chat input accepts multiple paste operations naturally.

set -euo pipefail

LMS_CLASS="LM-Studio"
PASTE_DELAY_S=0.45   # let the renderer settle after focus before paste
INTER_PASTE_S=0.30   # gap between image paste and text paste

notify() { command -v notify-send >/dev/null && notify-send -a hyprwhspr-handoff "$@" || true; }

require() {
  for bin in "$@"; do
    command -v "$bin" >/dev/null || { notify -u critical "Missing tool" "$bin not in PATH"; exit 1; }
  done
}

lms_running() {
  hyprctl clients -j 2>/dev/null | jq -e --arg c "$LMS_CLASS" '.[] | select(.class == $c)' >/dev/null
}

focus_lms() {
  if ! lms_running; then
    notify -u normal "LM Studio not open" "Start LM Studio first, then retry the handoff."
    exit 1
  fi
  hyprctl dispatch focuswindow "class:${LMS_CLASS}" >/dev/null 2>&1
  sleep "$PASTE_DELAY_S"
}

# Synthesize Ctrl+V. Linux input keycodes: 29 = LEFTCTRL, 47 = V.
paste_keys() {
  ydotool key 29:1 47:1 47:0 29:0
}

case "${1:-}" in
  text)
    require wl-copy ydotool jq hyprctl
    text="${2:?text required}"
    [[ -z "$text" ]] && { notify -u low "Empty text" "Nothing to hand off."; exit 0; }
    printf '%s' "$text" | wl-copy
    focus_lms
    paste_keys
    ;;

  image)
    require wl-copy ydotool jq hyprctl
    img="${2:?image path required}"
    [[ -f "$img" ]] || { notify -u normal "File not found" "$img"; exit 1; }
    wl-copy --type image/png < "$img"
    focus_lms
    paste_keys
    ;;

  both)
    require wl-copy ydotool jq hyprctl
    img="${2:?image path required}"
    text="${3:?text required}"
    [[ -f "$img" ]] || { notify -u normal "File not found" "$img"; exit 1; }
    wl-copy --type image/png < "$img"
    focus_lms
    paste_keys
    sleep "$INTER_PASTE_S"
    printf '%s' "$text" | wl-copy
    paste_keys
    ;;

  *)
    cat >&2 <<'EOF'
hyprwhspr-lms-handoff — open content in LM Studio for follow-up

Usage:
  hyprwhspr-lms-handoff text  "<text>"
  hyprwhspr-lms-handoff image <path>
  hyprwhspr-lms-handoff both  <image_path> "<text>"

Behavior:
  Copies content to Wayland clipboard, focuses LM Studio, pastes via ydotool.
  Requires LM Studio to already be running.
EOF
    exit 2
    ;;
esac
