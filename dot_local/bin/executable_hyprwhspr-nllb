#!/usr/bin/env bash
# hyprwhspr-nllb — translation client for the local NLLB-200 server.
#
# Usage:
#   echo "Hello world" | hyprwhspr-nllb eng_Latn lit_Latn
#   hyprwhspr-nllb eng_Latn deu_Latn "Hello world"
#
# Auto-starts the NLLB server (systemd user service) on first call. Server
# idle-exits after 10 min; next call restarts it transparently. Cold-load
# adds ~1s on first call after idle exit. Warm calls are 200-700ms.

set -euo pipefail

SOCK="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hyprwhspr-nllb.sock"
SRC="${1:?source NLLB code (e.g. eng_Latn)}"
TGT="${2:?target NLLB code (e.g. lit_Latn)}"

# Read text from arg or stdin.
if [[ $# -ge 3 ]]; then
  TEXT="$3"
else
  TEXT="$(cat)"
fi

[[ -z "$TEXT" ]] && { echo "no input text" >&2; exit 1; }

# Auto-start the server if the socket isn't there.
if [[ ! -S "$SOCK" ]]; then
  systemctl --user start hyprwhspr-nllb 2>/dev/null || true
  # Wait up to 30s for the socket (1s usual; up to 30 if cold systemd start).
  for i in $(seq 1 60); do
    [[ -S "$SOCK" ]] && break
    sleep 0.5
  done
  [[ -S "$SOCK" ]] || { echo "NLLB server failed to start" >&2; exit 1; }
fi

# Build request, send, read one-line response.
REQ="$(jq -nc --arg src "$SRC" --arg tgt "$TGT" --arg text "$TEXT" \
  '{text:$text, src:$src, tgt:$tgt}')"

# Talk to the Unix socket via a tiny inline python (socat isn't installed
# by default and netcat-openbsd's `nc -U` was inconsistent across distros).
# `python -c` so the heredoc doesn't shadow stdin (the request).
RESP="$(printf '%s\n' "$REQ" | "$HOME/.local/share/hyprwhspr-translate/.venv/bin/python" -c '
import socket, sys
sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
sock.connect(sys.argv[1])
sock.sendall(sys.stdin.buffer.read())
sock.shutdown(socket.SHUT_WR)
buf = b""
while True:
    chunk = sock.recv(65536)
    if not chunk: break
    buf += chunk
sys.stdout.buffer.write(buf)
' "$SOCK")"

# Extract translation or surface error.
if [[ -z "$RESP" ]]; then
  echo "empty response from NLLB server" >&2; exit 1
fi
if printf '%s' "$RESP" | jq -e '.error' >/dev/null 2>&1; then
  printf '%s' "$RESP" | jq -r '.error' >&2
  exit 1
fi
printf '%s' "$RESP" | jq -r '.translation'
