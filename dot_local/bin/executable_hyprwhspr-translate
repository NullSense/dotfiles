#!/usr/bin/env bash
# hyprwhspr-translate — translation pipeline.
#
# Translation engine: NLLB-200 distilled-1.3B (INT8 CTranslate2) via the
# local hyprwhspr-nllb server (Unix socket, lazy-loaded, idle-exits after
# 10 min). Specialized NMT model — better quality on low-resource targets
# (Lithuanian, Latvian, Estonian, etc.) than running translation through
# a general LLM, with smaller VRAM footprint (~1.5GB on CPU).
#
# Subcommands:
#   region          drag a region → Gemma 4 OCRs the image → NLLB translates
#   clipboard       translate current wl-clipboard contents directly
#   text "<txt>"    translate stdin or arg text
#
# Target language UX: favorites at top (from ~/.config/hyprwhspr/languages.txt),
# "Other…" at bottom opens a walker input for free-text. The picker takes
# human names ("Lithuanian") or NLLB BCP-47-ish codes ("lit_Latn") — we
# map names → codes via a hardcoded table (top ~35 languages).

set -euo pipefail

LMS_URL_BASE="${HYPRWHSPR_LMS_URL_BASE:-http://127.0.0.1:1234}"
LMS_MODEL="${HYPRWHSPR_LMS_MODEL:-google_gemma-4-e4b-it}"
LANGS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/hyprwhspr/languages.txt"
TIMEOUT=30

# Language name → NLLB code (BCP-47-ish: ISO 639-3 + script). Covers the
# 35+ first-class NLLB languages plus common ones the user mentioned.
# Lookup is case-insensitive on the human name; codes pass through.
declare -A LANG_CODE=(
  [english]=eng_Latn   [german]=deu_Latn        [lithuanian]=lit_Latn
  [latvian]=lav_Latn   [estonian]=est_Latn      [polish]=pol_Latn
  [russian]=rus_Cyrl   [french]=fra_Latn        [spanish]=spa_Latn
  [italian]=ita_Latn   [portuguese]=por_Latn    [dutch]=nld_Latn
  [czech]=ces_Latn     [slovak]=slk_Latn        [hungarian]=hun_Latn
  [romanian]=ron_Latn  [bulgarian]=bul_Cyrl     [croatian]=hrv_Latn
  [serbian]=srp_Cyrl   [slovenian]=slv_Latn     [ukrainian]=ukr_Cyrl
  [greek]=ell_Grek     [turkish]=tur_Latn       [arabic]=arb_Arab
  [hebrew]=heb_Hebr    [hindi]=hin_Deva         [bengali]=ben_Beng
  [vietnamese]=vie_Latn [thai]=tha_Thai          [indonesian]=ind_Latn
  [malay]=zsm_Latn     [japanese]=jpn_Jpan      [korean]=kor_Hang
  [chinese]=zho_Hans   [mandarin]=zho_Hans      [cantonese]=yue_Hant
  ["chinese (simplified)"]=zho_Hans  ["chinese (traditional)"]=zho_Hant
  [swedish]=swe_Latn   [norwegian]=nob_Latn     [danish]=dan_Latn
  [finnish]=fin_Latn   [icelandic]=isl_Latn
  [persian]=pes_Arab   [farsi]=pes_Arab         [urdu]=urd_Arab
  [swahili]=swh_Latn   [zulu]=zul_Latn          [afrikaans]=afr_Latn
)

# Resolve a human name or pass-through code to an NLLB code.
# Returns empty string if unknown.
to_nllb_code() {
  local input="$1"
  # Already an NLLB code? (xxx_Yyyy pattern)
  if [[ "$input" =~ ^[a-z]{3}_[A-Z][a-z]{3}$ ]]; then
    printf '%s' "$input"; return
  fi
  local key
  key="$(printf '%s' "$input" | /usr/bin/tr '[:upper:]' '[:lower:]')"
  printf '%s' "${LANG_CODE[$key]:-}"
}

WALKER="$(command -v omarchy-launch-walker || command -v walker)"
WDIMS=(--width 295 --minheight 1 --maxheight 630)

notify() {
  command -v notify-send >/dev/null && \
    notify-send -a hyprwhspr-translate "$@" 2>/dev/null || true
}

walker_input() {
  printf '' | "$WALKER" --dmenu -I "${WDIMS[@]}" -p "${1}…" 2>/dev/null || true
}

walker_pick() {
  "$WALKER" --dmenu "${WDIMS[@]}" -p "${1}…" 2>/dev/null || true
}

# --- Pre-flight (mirror the rewrite hook's pattern) --------------------------
preflight() {
  local state
  state="$(curl -fsS --max-time 1 "${LMS_URL_BASE}/api/v0/models" 2>/dev/null \
    | jq -r --arg id "$LMS_MODEL" '.data[] | select(.id == $id) | .state' 2>/dev/null)"
  if [[ "$state" == "loaded" ]]; then return 0; fi
  if [[ -z "$state" || "$state" == "null" ]]; then
    notify -u normal "LM Studio unavailable" "Cannot reach :1234 or model not registered"
    return 1
  fi
  notify -u normal "Loading model" "${LMS_MODEL} is ${state}. Triggering background load."
  ( setsid "$HOME/.local/bin/hyprwhspr-warmup" >/dev/null 2>&1 & ) &
  return 1
}

# --- Target language picker --------------------------------------------------
# Favorites + "Other…" entry. Returns the picked language name, or empty
# string if the user cancelled.
pick_target_language() {
  local favs
  favs="$(grep -vE '^\s*(#|$)' "$LANGS_FILE" 2>/dev/null || printf 'English\nGerman\nLithuanian\n')"
  local picked
  picked="$(printf '%s\n  Other…\n' "$favs" | walker_pick 'Translate to')"
  [[ -z "$picked" ]] && return 1
  if [[ "$picked" == *Other* ]]; then
    picked="$(walker_input 'Language (name or ISO code, e.g. \"Polish\" or \"pl\")')"
    [[ -z "$picked" ]] && return 1
  fi
  printf '%s' "$picked"
}

# --- Capture helpers ---------------------------------------------------------
capture_region() {
  local geom; geom="$(slurp -d -b 28282880 -c fabd2fee -w 2 2>/dev/null)" || return 1
  [[ -z "$geom" ]] && return 1
  local f; f="$(mktemp --suffix=.png)"
  grim -g "$geom" "$f" 2>/dev/null && printf '%s' "$f"
}

# --- LLM calls ---------------------------------------------------------------
# Translate text via NLLB (auto-starts the server, idle-exits after 10min).
# Source language defaults to eng_Latn. NLLB doesn't auto-detect, but for
# our use case (mostly EN→other) this is fine. Future: add a detection
# step (Gemma can do "detect the language of: ...") if it matters.
translate_text() {
  local tgt_code="$1" text="$2"
  local src_code="${HYPRWHSPR_TRANSLATE_SRC:-eng_Latn}"
  printf '%s' "$text" | hyprwhspr-nllb "$src_code" "$tgt_code" 2>&1
}

# OCR an image via Gemma 4 vision (already loaded for the rewrite pipeline),
# then send extracted text to NLLB. Two-stage so each model does what it's
# best at — Gemma reads pixels, NLLB translates.
ocr_image() {
  local image_path="$1"
  local b64file body
  b64file="$(mktemp)"; body="$(mktemp)"
  base64 -w0 "$image_path" > "$b64file"
  jq -n --rawfile b "$b64file" --arg model "$LMS_MODEL" '
    {model: $model,
     messages: [
       {role:"user", content:[
         {type:"image_url", image_url:{url:"data:image/png;base64,\($b)"}},
         {type:"text", text:"Extract the text visible in this image verbatim. Preserve line breaks and structure. Output ONLY the extracted text — no preamble, no quotes, no commentary."}
       ]}],
     max_tokens: 1024, temperature: 0.0, stream: false}' > "$body"
  curl -fsS --max-time "$TIMEOUT" -H 'Content-Type: application/json' \
    --data-binary "@${body}" "${LMS_URL_BASE}/v1/chat/completions" 2>/dev/null \
    | jq -r '.choices[0].message.content // ""'
  rm -f "$b64file" "$body"
}

# --- Subcommands -------------------------------------------------------------
# Resolve picked language → NLLB code. Returns empty string + notifies on
# unknown name. Echoes the code on success.
resolve_target() {
  local picked="$1"
  local code; code="$(to_nllb_code "$picked")"
  if [[ -z "$code" ]]; then
    notify -u normal "Unknown language" "Could not map '${picked}' to an NLLB code. Try a name from languages.txt or a code like 'lit_Latn'."
    return 1
  fi
  printf '%s' "$code"
}

case "${1:-}" in
  region)
    img="$(capture_region)" || { notify -u low "Region capture cancelled"; exit 0; }
    target_name="$(pick_target_language)" || { rm -f "$img"; notify -u low "Translation cancelled"; exit 0; }
    target_code="$(resolve_target "$target_name")" || { rm -f "$img"; exit 0; }
    preflight || { rm -f "$img"; exit 0; }
    notify -u low -t 2000 "Reading image with Gemma…"
    text="$(ocr_image "$img")"
    rm -f "$img"
    [[ -z "$text" ]] && { notify -u normal "OCR returned nothing" "Try again with a clearer region"; exit 1; }
    notify -u low -t 2000 "Translating to ${target_name}…"
    translate_text "$target_code" "$text"
    ;;

  clipboard)
    text="$(wl-paste 2>/dev/null)"
    [[ -z "$text" ]] && { notify -u normal "Clipboard empty" "Nothing to translate"; exit 0; }
    target_name="$(pick_target_language)" || { notify -u low "Translation cancelled"; exit 0; }
    target_code="$(resolve_target "$target_name")" || exit 0
    notify -u low -t 2000 "Translating to ${target_name}…"
    translate_text "$target_code" "$text"
    ;;

  text)
    shift
    if [[ $# -ge 1 && "$1" != "-" ]]; then
      text="$1"
    else
      text="$(cat)"
    fi
    [[ -z "$text" ]] && { notify -u normal "No input" "Nothing to translate"; exit 1; }
    target_name="$(pick_target_language)" || exit 0
    target_code="$(resolve_target "$target_name")" || exit 0
    notify -u low -t 2000 "Translating to ${target_name}…"
    translate_text "$target_code" "$text"
    ;;

  *)
    cat >&2 <<'EOF'
hyprwhspr-translate — local Gemma 4 translation

Usage:
  hyprwhspr-translate region        drag region → translate text in it
  hyprwhspr-translate clipboard     translate current clipboard
  hyprwhspr-translate text "<txt>"  translate arg or stdin
  hyprwhspr-translate text -        read from stdin

Languages:
  Top of picker comes from ~/.config/hyprwhspr/languages.txt
  "Other…" entry takes any language name or ISO code via walker input.
EOF
    exit 2
    ;;
esac
