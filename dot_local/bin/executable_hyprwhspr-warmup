#!/usr/bin/env bash
# Send a tiny no-op request to LM Studio to keep Gemma 4 (or whatever model is
# pinned) hot. JIT TTL in LM Studio is ~60min, so a 20-min cadence keeps the
# model resident indefinitely. Designed to be cheap (1 token, ~50ms warm).
#
# Invoked by:
#   - hyprwhspr.service ExecStartPost (initial warmup after daemon start)
#   - hyprwhspr-warmup.timer (periodic keep-alive)
#
# Silent on success; logs failures to journald via systemd.

set -euo pipefail

LMS_URL_BASE="${HYPRWHSPR_LMS_URL_BASE:-http://127.0.0.1:1234}"
LMS_MODEL="${HYPRWHSPR_LMS_MODEL:-google_gemma-4-e4b-it}"

# If LM Studio isn't running, bail quietly.
curl -fsS --max-time 1 "${LMS_URL_BASE}/v1/models" >/dev/null 2>&1 || exit 0

# Tiny ping. The JIT loader will load the model if cold; otherwise it's a
# ~50ms inference. We don't care about the response.
curl -fsS --max-time 60 \
  -H 'Content-Type: application/json' \
  -X POST "${LMS_URL_BASE}/v1/chat/completions" \
  -d "{\"model\":\"${LMS_MODEL}\",\"messages\":[{\"role\":\"user\",\"content\":\"hi\"}],\"max_tokens\":1}" \
  >/dev/null 2>&1 || exit 0
