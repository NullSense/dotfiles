#!/usr/bin/env bash
# Send a tiny no-op request to LM Studio to keep the rewrite model hot.
# JIT TTL in LM Studio is ~60min; a 20-min cadence keeps it resident
# indefinitely. Designed to be cheap: ~50ms warm, up to ~15s on cold load.
#
# Invoked by:
#   - hyprwhspr-warmup.timer (periodic keep-alive)
#   - hyprwhspr-rewrite     (when pre-flight detects model not loaded)
#
# Notification policy: silent on warm pings; notifies on cold→loaded
# transition (so the user knows when their next dictation will start
# being rewritten again) and on errors that aren't transient.

set -euo pipefail

LMS_URL_BASE="${HYPRWHSPR_LMS_URL_BASE:-http://127.0.0.1:1234}"
LMS_MODEL="${HYPRWHSPR_LMS_MODEL:-google_gemma-4-e4b-it}"
NOTIFY="${HYPRWHSPR_WARMUP_NOTIFY:-1}"

notify() {
  [[ "$NOTIFY" == "0" ]] && return 0
  command -v notify-send >/dev/null || return 0
  notify-send -a hyprwhspr-warmup "$@" 2>/dev/null || true
}

# Bail quietly if LM Studio is down.
curl -fsS --max-time 1 "${LMS_URL_BASE}/v1/models" >/dev/null 2>&1 || exit 0

# Capture state BEFORE the ping so we can tell if this call triggered a load.
state_before="$(curl -fsS --max-time 1 "${LMS_URL_BASE}/api/v0/models" 2>/dev/null \
  | jq -r --arg id "$LMS_MODEL" '.data[] | select(.id == $id) | .state' 2>/dev/null)"

# Tiny ping. JIT loader pulls the model in if cold (~5-15s); otherwise ~50ms.
if curl -fsS --max-time 60 \
  -H 'Content-Type: application/json' \
  -X POST "${LMS_URL_BASE}/v1/chat/completions" \
  -d "{\"model\":\"${LMS_MODEL}\",\"messages\":[{\"role\":\"user\",\"content\":\"hi\"}],\"max_tokens\":1}" \
  >/dev/null 2>&1; then
  # Notify only on the cold→loaded transition so periodic pings stay silent.
  if [[ "$state_before" != "loaded" && -n "$state_before" ]]; then
    notify -u low -t 2500 "Rewrite model loaded" "${LMS_MODEL} is ready"
  fi
  exit 0
else
  # Failed even with a 60s budget — likely a real problem.
  notify -u normal -t 4500 "Rewrite model load failed" \
    "${LMS_MODEL} did not load within 60s. Check LM Studio."
  exit 1
fi
