#!/usr/bin/env bash
# sudo-pill-daemon â€” event-driven watcher for the sudo-active flag.
#
# Single long-lived process, runs as a systemd user service. Signals
# waybar (SIGRTMIN+10) on every state transition. waybar's custom/sudo
# module is configured with `interval: "once"` + `signal: 10`, so it
# only re-runs sudo-indicator.sh when this daemon says something changed.
# Zero polling anywhere in the pipeline.
#
# Event sources, all kernel-driven:
#   inotifywait -t  â†’ flag create/modify/delete  AND  TTL deadline.
#                     The -t timeout doubles as a deadline timer (timerfd
#                     under the hood). When the cache TTL expires with no
#                     other event, inotifywait returns via timeout and we
#                     signal waybar to flip the pill to idle.
#   tail --pid      â†’ sudo process death during auth_prompt. On exit it
#                     touches a sentinel inside flag_dir, which trips the
#                     same inotifywait â†’ unified single primitive.
#
# Why a daemon (not a waybar streaming-exec):
#   - Survives waybar restarts; one inotify watch on the flag dir at all
#     times (no race where a brief watcher-less window misses an event).
#   - waybar 0.15's `interval: "once"` and `restart-interval` neither
#     reliably respawn the script after kill, so the streaming-exec
#     pattern was leaking dead bars (one watcher per output, one died,
#     one stayed â†’ asymmetric pill state across monitors).
#   - systemd's `Restart=always` is the canonical robust answer.
set -u

UID_=$(id -u)
flag="/run/user/$UID_/sudo-active"
flag_dir=$(dirname "$flag")
pid_marker="$flag_dir/.sudo-pill-pid-died"
ttl=${SUDO_CACHE_SEC:-300}
prompt_ttl=${SUDO_PROMPT_TTL:-60}

mkdir -p "$flag_dir"
rm -f "$pid_marker" 2>/dev/null || true

# Background subprocess registry â€” kill them all on exit.
WATCHERS=()
cleanup() {
  local pid
  for pid in "${WATCHERS[@]}"; do
    kill "$pid" 2>/dev/null || true
  done
  rm -f "$pid_marker" 2>/dev/null || true
}
trap 'cleanup; exit 0' INT TERM
trap cleanup EXIT

signal_waybar() {
  pkill -SIGRTMIN+10 -u "$UID_" waybar 2>/dev/null || true
}

# Mako notification IDs are 32-bit; we pick a stable one derived from a
# constant string so the ID stays the SAME across daemon restarts. The
# old `$$ % 65000` rotated on every restart (Restart=always + any unit
# restart from env-reload/full-reload), so a prompt-popup fired with
# one ID, the resolve-replace tried to match a different ID, mako
# created a new notification instead of replacing, and the original
# popup orphaned â€” only its --expire-time could clear it, and critical
# urgency popups commonly stick past their hint. cksum is in coreutils,
# deterministic, and identical across machines.
NOTIFY_ID=$(printf 'sudo-pill' | cksum | awk '{print ($1 % 64000) + 1000}')

notify_transition() {
  local from="$1" to="$2"
  # Pick a stable icon: prefer Adwaita's system-lock-screen vector
  # (always present on glibc systems with default icon theme), fall back
  # to icon-name lookup so mako resolves whatever the active theme has.
  local lock_icon=system-lock-screen
  for cand in \
      /usr/share/icons/Adwaita/symbolic/status/system-lock-screen-symbolic.svg \
      /usr/share/icons/Adwaita/scalable/devices/system-lock-screen-symbolic.svg \
      /usr/share/icons/breeze/status/22/system-lock-screen.svg; do
    [[ -f "$cand" ]] && { lock_icon="$cand"; break; }
  done
  local ws_label=""
  if [[ -n "${F[ws]:-}" ]]; then
    case "${F[ws]}" in
      special:*) ws_label="scratch:${F[ws]#special:}" ;;
      *)         ws_label="ws${F[ws]}" ;;
    esac
  fi

  # UX rules:
  #   - PROMPT       â†’ critical popup (actionable). Carries an --expire-time
  #                     fallback equal to prompt_ttl, so it self-clears even
  #                     if subsequent transitions don't fire (daemon crash,
  #                     unreliable inotify, etc.).
  #   - PROMPTâ†’AUTH  â†’ silently dismiss the prompt popup. No "Sudo
  #                     authenticated" toast â€” you just typed your password,
  #                     a confirmation popup is just noise.
  #   - PROMPTâ†’FAIL  â†’ brief warning toast (Ctrl+C, wrong password).
  #   - Anything else (cachedâ†’idle, runningâ†’cached, etc.) is invisible.
  case "$fromâ†’$to" in
    *â†’prompt)
      local detail="tty: ${F[tty]:-?}"
      [[ -n "$ws_label" ]] && detail+="   $ws_label"
      [[ -n "${F[user]:-}" ]] && detail+="   user: ${F[user]}"
      notify-send \
        --urgency=critical \
        --replace-id="$NOTIFY_ID" \
        --icon="$lock_icon" \
        --app-name=sudo \
        --hint=string:x-canonical-private-synchronous:sudo-pill \
        --expire-time="$((prompt_ttl * 1000))" \
        "Sudo wants your password" \
        "$detail" \
        2>/dev/null || true
      ;;
    promptâ†’running|promptâ†’cached)
      # Auth succeeded â€” dismiss the prompt popup directly by id. The
      # previous approach (notify-send a 1ms-expire stub + `makoctl
      # dismiss --group`) had two failure modes: (a) `--replace-id`
      # didn't match when NOTIFY_ID rotated across daemon restarts,
      # and (b) `--group` dismisses the LAST notification's group, not
      # ours â€” any other notification fired since the prompt (Reloaded
      # toast, chat ping, etc.) hijacks the dismiss target. Targeting
      # the popup by its own id avoids both. Now that NOTIFY_ID is
      # stable, this matches even if the daemon restarted mid-prompt.
      makoctl dismiss -n "$NOTIFY_ID" 2>/dev/null || true
      ;;
    promptâ†’idle)
      # Auth attempt that never reached running = failed (wrong password,
      # 3-strike out, Ctrl+C). Brief warning, then write type=failed so
      # the indicator paints red briefly (3s self-decay).
      notify-send \
        --urgency=normal \
        --replace-id="$NOTIFY_ID" \
        --icon="$lock_icon" \
        --app-name=sudo \
        --hint=string:x-canonical-private-synchronous:sudo-pill \
        --expire-time=2500 \
        "Sudo authentication failed" \
        "wrong password or cancelled" \
        2>/dev/null || true
      {
        echo "user=${F[user]:-$(id -un "$UID_")}"
        echo "epoch=$(date +%s)"
        echo "type=failed"
        echo "tty=${F[tty]:-?}"
      } > "$flag" 2>/dev/null || true
      chown "$UID_" "$flag" 2>/dev/null || true
      ;;
    # All other transitions (runningâ†’cached, cachedâ†’idle, runningâ†’idle,
    # failedâ†’idle, idleâ†’cached, etc.) are silent. Either no popup ever
    # showed, or the prompt popup already self-expired via --expire-time.
  esac
}

# â”€â”€ flag introspection â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
read_flag() {
  declare -gA F=()
  AGE=0
  [[ -f "$flag" ]] || return 1
  local mtime k v
  mtime=$(stat -c %Y "$flag" 2>/dev/null || echo 0)
  AGE=$(( $(date +%s) - mtime ))
  while IFS='=' read -r k v; do
    [[ -n "$k" ]] && F[$k]="$v"
  done < "$flag"
  return 0
}

# Determine the deadline for the current state, in seconds. Returns 0
# when no deadline applies (idle â€” waits indefinitely for inotify).
state_deadline() {
  if read_flag; then
    if [[ "${F[type]:-}" == "auth_prompt" ]]; then
      local d=$(( prompt_ttl - AGE ))
      (( d < 1 )) && d=1
      echo "$d"
      return
    fi
    if (( AGE < ttl )); then
      echo $(( ttl - AGE ))
      return
    fi
  fi
  echo 0
}

# Spawn one tail --pid per active auth_prompt (cleared on next iteration).
spawn_pid_watcher() {
  if read_flag && [[ "${F[type]:-}" == "auth_prompt" ]]; then
    local sudo_pid="${F[sudo_pid]:-}"
    if [[ -n "$sudo_pid" ]] && kill -0 "$sudo_pid" 2>/dev/null; then
      ( tail --pid="$sudo_pid" -f /dev/null 2>/dev/null
        # Touch + remove to fire create+delete events; ensures inotify
        # wakes regardless of which event mask the parent's listening for.
        touch "$pid_marker" 2>/dev/null
        rm -f "$pid_marker" 2>/dev/null
      ) </dev/null >/dev/null 2>&1 &
      WATCHERS+=("$!")
    fi
  fi
}

# Cleanup expired flags so the indicator returns idle on next read.
expire_stale_flag() {
  if read_flag; then
    if [[ "${F[type]:-}" == "auth_prompt" ]]; then
      local sudo_pid="${F[sudo_pid]:-}"
      if [[ -n "$sudo_pid" ]] && ! kill -0 "$sudo_pid" 2>/dev/null; then
        rm -f "$flag" 2>/dev/null
        return
      fi
      if (( AGE > prompt_ttl )); then
        rm -f "$flag" 2>/dev/null
        return
      fi
    elif (( AGE >= ttl )); then
      rm -f "$flag" 2>/dev/null
    fi
  fi
}

current_state() {
  if read_flag; then
    case "${F[type]:-}" in
      auth_prompt)   echo prompt;  return ;;
      open_session)  (( AGE < ttl )) && { echo running; return; } ;;
      close_session) (( AGE < ttl )) && { echo cached;  return; } ;;
      failed)        (( AGE < 3 ))   && { echo failed;  return; } ;;
    esac
  fi
  echo idle
}

# â”€â”€ main loop â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Flow: signal waybar (so it re-reads), check expiry, decide next deadline,
# block on inotify with that timeout (or forever when idle).
PREV_STATE="$(current_state)"
while true; do
  expire_stale_flag
  NEW_STATE="$(current_state)"
  if [[ "$NEW_STATE" != "$PREV_STATE" ]]; then
    notify_transition "$PREV_STATE" "$NEW_STATE"
    PREV_STATE="$NEW_STATE"
  fi
  signal_waybar
  spawn_pid_watcher

  timeout=$(state_deadline)

  if (( timeout > 0 )); then
    inotifywait -qq -t "$timeout" \
      -e modify,create,delete,close_write,moved_to,moved_from \
      "$flag_dir" 2>/dev/null || true
  else
    inotifywait -qq \
      -e modify,create,delete,close_write,moved_to,moved_from \
      "$flag_dir" 2>/dev/null || true
  fi

  # Reap finished pid watchers.
  for i in "${!WATCHERS[@]}"; do
    kill -0 "${WATCHERS[$i]}" 2>/dev/null || unset "WATCHERS[$i]"
  done
done
