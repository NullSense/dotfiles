# ~/.zshrc — interactive shell config
# Stack: zinit (plugins) · mise (tooling) · atuin (history) · starship (prompt)
# fzf-tab (completion) · zoxide (cd) · zsh-vi-mode (modal editing)

# ─── Environment ────────────────────────────────────────────────────────────
typeset -U path PATH fpath
path=(
  $HOME/bin
  $HOME/.local/bin
  $HOME/.cargo/bin
  $HOME/.bun/bin
  $HOME/.local/share/pnpm
  $path
)

# Setting LC_ALL forces every LC_* category and makes per-program locale
# overrides impossible (e.g. `LC_TIME=C ls -l` for sortable timestamps). LANG
# alone is enough for utf-8 default behavior; let programs override the rest.
export LANG=en_US.UTF-8
export EDITOR=nvim VISUAL=nvim MANPAGER='nvim +Man!'
export COLORTERM=truecolor TERMINAL=alacritty

# Wayland / Qt / Mozilla
# Don't hardcode XDG_CURRENT_DESKTOP / XDG_SESSION_TYPE — the compositor and
# systemd-logind set them per session. Hardcoding lies if we ever land on
# TTY / X11. Only fall back if the session left them empty.
: "${XDG_CURRENT_DESKTOP:=$XDG_SESSION_DESKTOP}"
export XDG_CURRENT_DESKTOP
export MOZ_ENABLE_WAYLAND=1
export QT_QPA_PLATFORM=wayland QT_WAYLAND_DISABLE_WINDOWDECORATION=1

export BUN_INSTALL="$HOME/.bun"
export PNPM_HOME="$HOME/.local/share/pnpm"

# ─── Plugins (zinit) ────────────────────────────────────────────────────────
# Install: bash -c "$(curl -fsSL https://git.io/zinit-install)"
ZINIT_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
source "$ZINIT_HOME/zinit.zsh"

# Vi-mode loads eagerly: deferred loading breaks the first prompt's keymap.
# ZVM_INIT_MODE=sourcing prevents zvm from clobbering bindings set after it.
ZVM_INIT_MODE=sourcing
ZVM_VI_INSERT_ESCAPE_BINDKEY=jk
# zvm only defines ZVM_MODE_INSERT="i" *after* the plugin is sourced, so the
# old `ZVM_LINE_INIT_MODE=$ZVM_MODE_INSERT` line expanded to an empty string
# and the setting was silently a no-op (zvm fell back to "last mode"). Use
# the literal value so each new prompt actually starts in insert mode.
ZVM_LINE_INIT_MODE=i
# ZVM's NEX read engine uses TWO independent timeouts (plugin lines ~606-616):
#   ZVM_KEYTIMEOUT (default 0.4s) — wait for the 2nd key of any NON-ESC vi
#     sequence: `gg`, `dd`, `cw`, text objects, visual-mode motions, and the
#     `jk` escape chord. Too low → these multi-key commands abort mid-sequence.
#   ZVM_ESCAPE_KEYTIMEOUT (default 0.03s) — wait after a BARE ESC to swallow
#     arrow-key CSI sequences. THIS is the real "ESC then quickly `gg`" knob;
#     it's already fast by default, so we leave it alone.
# 0.05 was a misdiagnosis: it capped every multi-key command at 50ms (you can't
# press `gg`/`dd`/`vi(` that fast) yet did nothing for the ESC race. 0.2s:
# deliberate `gg`/`dd` land easily, the `jk` chord still fires, and a literal
# `j` in insert mode lags only 200ms. Raise toward 0.3-0.4 if `gg` feels flaky;
# drop to ~0.15 for snappier literal-`j` typing.
ZVM_KEYTIMEOUT=0.2
zinit ice depth=1
zinit light jeffreytse/zsh-vi-mode

# Turbo: load after first prompt. Order matters — fzf-tab must wrap compadd
# before fast-syntax-highlighting / zsh-autosuggestions wrap widgets.
zinit wait lucid for \
  atinit"zicompinit; zicdreplay" \
    Aloxaf/fzf-tab \
  zdharma-continuum/fast-syntax-highlighting \
  atload"_zsh_autosuggest_start; bindkey '^ ' autosuggest-accept" \
    zsh-users/zsh-autosuggestions \
  blockf \
    zsh-users/zsh-completions \
  OMZP::git \
  OMZP::sudo \
  OMZP::command-not-found \
  wfxr/forgit \
  junegunn/fzf-git.sh
# fzf-git.sh: Ctrl-G prefix for git objects — Ctrl-G then Ctrl-F (files),
# Ctrl-B (branches), Ctrl-T (tags), Ctrl-R (remotes), Ctrl-H (hashes/commits),
# Ctrl-S (stashes), Ctrl-L (reflogs), Ctrl-W (worktrees), Ctrl-E (each-ref).
# forgit MUST load after OMZP::git so its interactive aliases (ga/gd/glo/gss/
# gcb/gco/gbd/grh/gcf/gcp/grb/grl/gbl/gclean…) override OMZ-git's plain ones.
# These are now INTERACTIVE fzf pickers; use real `git add`/`git diff` for plain.
# Set FORGIT_NO_ALIASES=1 (before this line) to keep only the forgit::* funcs.

# ─── Completion styling ─────────────────────────────────────────────────────
zstyle ':completion:*' menu no                       # required by fzf-tab
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':fzf-tab:*' fzf-bindings 'ctrl-space:toggle' 'tab:accept'
zstyle ':fzf-tab:*' continuous-trigger '/'
zstyle ':fzf-tab:*' switch-group ',' '.'
zstyle ':fzf-tab:complete:cd:*'      fzf-preview 'eza -1 --color=always --icons --group-directories-first $realpath'
zstyle ':fzf-tab:complete:(\\|*/|)ls:*' fzf-preview 'eza -1 --color=always --icons --group-directories-first $realpath'

# ─── Tool integrations ──────────────────────────────────────────────────────
# fzf widgets (Ctrl-T file, Alt-C cd; Ctrl-R is owned by atuin below)
source /usr/share/fzf/key-bindings.zsh
# Do NOT source /usr/share/fzf/completion.zsh: it eagerly binds Tab (^I) to
# fzf-completion at startup, but zicompinit + fzf-tab load later in turbo
# (wait lucid). So on the first prompt Tab is bound to a completion widget
# before the completion system exists → Tab does nothing until turbo fires.
# fzf-tab owns Tab post-turbo and is mutually exclusive with fzf's
# completion.zsh (per fzf-tab docs), so the `**<Tab>` trigger is dead anyway.

command -v mise     &>/dev/null && eval "$(mise activate zsh)"
# mise task/CLI completions (task args complete via their `usage` specs).
# Cached: regenerating on every shell start costs ~50ms; the cache is
# refreshed when older than the mise binary.
if command -v mise &>/dev/null; then
  _mise_comp="${XDG_CACHE_HOME:-$HOME/.cache}/mise-completion.zsh"
  if [[ ! -s $_mise_comp || $(command -v mise) -nt $_mise_comp ]]; then
    mkdir -p "${_mise_comp:h}" && mise completion zsh >| "$_mise_comp" 2>/dev/null
  fi
  # compinit is deferred to zinit turbo (fzf-tab must wrap it), but this mise
  # completion is sourced eagerly and calls `compdef` before it exists → error.
  # Shim compdef to QUEUE into zinit's replay array; the `zicdreplay` in the
  # turbo atinit replays these after compinit. Only define if compdef is absent.
  (( $+functions[compdef] )) || compdef() { ZINIT_COMPDEF_REPLAY+=( "${(j: :)${(q)@}}" ) }
  source "$_mise_comp"
  unset _mise_comp
fi
command -v atuin    &>/dev/null && eval "$(atuin init zsh)"
command -v direnv   &>/dev/null && eval "$(direnv hook zsh)"
command -v starship &>/dev/null && eval "$(starship init zsh)"

# ─── Keybindings ────────────────────────────────────────────────────────────
# Ctrl-Space → accept autosuggestion is bound in the atload hook above, so it
# happens after the widget is actually defined (avoids fast-syntax-highlighting
# "unhandled ZLE widget" warning). fzf-tab's ctrl-space:toggle only fires
# inside the picker, so they don't conflict.
#
# Ctrl-\ → yazi launcher. Under ZVM_INIT_MODE=sourcing, zvm_init runs at
# source-time (line 74), so its after_init pass iterates zvm_after_init_commands
# while it's empty. Any later `zvm_after_init_commands+=(…)` is appended to a
# dead array. Direct bindkey works because sourcing-mode zvm does not rebind
# the main keymap after this point — that's the whole reason for sourcing mode.
bindkey -s '^\' 'yy\n'

# ─── Hooks & functions ──────────────────────────────────────────────────────
autoload -U add-zsh-hook
_eza_on_cd() { emulate -L zsh; eza -ah --icons=always --group-directories-first; print }
add-zsh-hook chpwd _eza_on_cd

# yazi launcher with cwd-on-exit (in the current terminal). In Alacritty this
# shows chafa block-art previews; run it inside kitty for real-pixel previews.
yy() {
  local tmp; tmp=$(mktemp -t yazi-cwd.XXXXXX)
  yazi "$@" --cwd-file="$tmp"
  local cwd; cwd=$(<"$tmp")
  [[ -n $cwd && $cwd != $PWD ]] && builtin cd -- "$cwd"
  command rm -f -- "$tmp"
}

# yk — open yazi in a detached kitty window for REAL image previews (kitty
# graphics protocol), while Alacritty stays the daily driver. The chafa.yazi
# plugin auto-detects kitty and hands off to Yazi's built-in image renderer.
# No cwd-on-exit here: it's a separate window, so it can't cd this shell.
yk() { command -v kitty >/dev/null && kitty --detach yazi "$@"; }

# ─── Local config & secrets ─────────────────────────────────────────────────
[[ -f ~/bin/zshaliases ]] && source ~/bin/zshaliases
[[ -f ~/bin/zshfzfrc  ]] && source ~/bin/zshfzfrc
[[ -f ~/.secrets       ]] && source ~/.secrets

# ─── AI agent isolation (bubblewrap) ────────────────────────────────────────
# Agent isolation lives in ~/bin/{claude,codex,opencode} — real on-disk shims
# that PATH-shadow the real binaries (~/.local/bin/claude, /usr/bin/codex,
# /usr/bin/opencode). Each shim execs ~/bin/_agent-shim which dispatches
# through ~/bin/agent-isolated (bwrap sandbox).
#
# Why shims, not zsh functions: a function only intercepts zsh invocations.
# Anything else — `command claude`, /usr/bin/env claude, any non-zsh shell,
# an exec() syscall from a program, a systemd unit — would bypass the
# wrapper and reach the real binary. Binary shims in ~/bin (first on $PATH)
# catch all PATH-based lookups regardless of shell or context.
#
# Escape hatches per invocation: --ssh / --gpg / --rbw / --agent-vault
# Sandbox bypasses (deliberate, no longer accidental):
#   • AGENT_UNSANDBOX=1 claude …      — env-var gate
#   • ~/.local/bin/claude …           — invoke real binary by full path
#
# unalias the names in case a legacy alias snuck back in via zshaliases
# (some omarchy/agent-vault setups define `alias claude='agent-vault …'`).
# `unalias` returns 1 on the first missing name and skips the rest, so loop
# per-name to guarantee all three get cleared regardless of which (if any)
# alias actually exists.
for _agent in claude codex opencode; do unalias "$_agent" 2>/dev/null; done
unset _agent

# Deliberate-unsandbox convenience: <name>-raw runs the agent outside bwrap.
# Implementation: invoke the real binary directly at ~/.local/bin/<agent>,
# skipping the ~/bin shim entirely. This avoids a chicken-and-egg loop where
# AGENT_UNSANDBOX=1 routes through the shim, which routes through agent-
# isolated, which would re-resolve "claude" back to the shim.
#
# Use when you need to write to paths the sandbox doesn't bind (systemd unit
# files, /etc, ~/.config/* outside chezmoi source, etc.) Full host access,
# all secrets exposed — the bwrap sandbox was the only in-sandbox secret
# boundary and -raw mode skips it entirely. Last resort only.
alias claude-raw='$HOME/.local/bin/claude'
alias codex-raw='/usr/bin/codex'
alias opencode-raw='/usr/bin/opencode'

# zoxide MUST be last: it installs a chpwd hook + precmd, and zoxide's doctor
# warns if any later sourced file (aliases, hooks, secrets) registers chpwd
# after it. Keep this at the very bottom of zshrc.
command -v zoxide   &>/dev/null && eval "$(zoxide init zsh --cmd cd)"

# LM Studio CLI: PATH entry consolidated to dot_zshenv (single canonical source).


# proto
export PROTO_HOME="$XDG_DATA_HOME/proto";
export PATH="$PROTO_HOME/shims:$PROTO_HOME/bin:$PATH";
# hyprwhspr-ai learn-from-corrections push adapter: reports the command line
# on Enter, but ONLY during the brief armed window after a voice dictation
# (arm-file in $XDG_RUNTIME_DIR; absent otherwise — zero overhead/privacy
# impact between dictations). Must load after zsh-vi-mode (sourced at line
# ~74 with ZVM_INIT_MODE=sourcing, so ZLE is already re-initialized here).
# Registers a zle line-finish hook, not chpwd — safe below zoxide.
[[ -r ~/Programming/hyprwhspr-ai/integration/zsh/hyprwhspr-learn.zsh ]] && \
  source ~/Programming/hyprwhspr-ai/integration/zsh/hyprwhspr-learn.zsh

# pnpm
# NOTE: this adds $PNPM_HOME/bin — where pnpm/pnpx/vercel actually live. The
# `path` array near the top adds the parent dir (no /bin), which misses them,
# so this block is what makes the pnpm global bins work. Captured from the live
# ~/.zshrc (pnpm installer had appended it out-of-band; never was in source).
export PNPM_HOME="/home/nullsense/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac
# pnpm end
