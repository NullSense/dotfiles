#%PAM-1.0

# Local override: -auth/-password pam_gnome_keyring lines stripped to match
# Omarchy's passwordless-keyring design (see Omarchy migration 1771682500.sh).
# With a passwordless login.keyring (display-name=login, lock-on-idle=false,
# lock-after=false), letting PAM try to unlock or encrypt with the login
# password is undesirable. The -session line below is kept — it just starts
# the daemon, which then serves the passwordless keyring directly.
#
# Source of truth: chezmoi:root/etc/pam.d/sddm
# Stock Arch ships -auth/-password lines too; we deliberately drop them.

auth        include     system-login
-auth       optional    pam_kwallet5.so

account     include     system-login

password    include     system-login

session     optional    pam_keyinit.so          force revoke
session     include     system-login
-session    optional    pam_gnome_keyring.so    auto_start
-session    optional    pam_kwallet5.so         auto_start
